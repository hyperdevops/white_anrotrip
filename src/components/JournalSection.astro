---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { getTourStyleBadge } from '../lib/tourDestinationBadge';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featuredPost = sortedPosts.find((p) => p.data.featured === true);
const latestPosts = sortedPosts
  .filter((p) => (featuredPost ? p.id !== featuredPost.id : true))
  .slice(0, 3);
---

<section
  id="journal"
  class="pt-14 pb-10 md:pb-16 bg-[linear-gradient(to_bottom,transparent_0,rgb(240_249_255)_120px,rgb(255_255_255)_40%,rgb(249_250_251)_100%)] overflow-hidden"
>
  <div class="container mx-auto px-4 sm:px-6 max-w-7xl">

    <!-- Заголовок секции — паттерн как в PopularTours -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-10 md:mb-12 reveal-hidden">
      <div>
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/8 border border-primary/15 mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-primary md:animate-pulse"></span>
          <span class="text-xs font-semibold text-primary uppercase tracking-widest font-montserrat">Журнал</span>
        </div>
        <h2 class="font-montserrat font-extrabold text-gray-900 uppercase tracking-tight leading-none" style="font-size: clamp(2rem, 1.5rem + 3vw, 4rem);">
          Наш <span class="text-primary">журнал</span>
        </h2>
      </div>
      <div class="flex flex-col items-start md:items-end gap-3 md:pb-2">
        <p class="text-gray-400 text-sm max-w-xs leading-relaxed md:text-right">
          Вдохновляющие идеи, советы экспертов<br class="hidden md:block" />и путеводители по лучшим направлениям.
        </p>
        <a
          href={`${base}/blog`}
          class="group inline-flex items-center gap-2 text-sm font-semibold text-gray-400 hover:text-primary transition-[color,transform] duration-fast cursor-pointer"
        >
          Все статьи
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Сетка: крупная карточка + три колонки -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5" data-reveal-stagger>
      {
        featuredPost && (
          <article class="group reveal-hidden md:col-span-3 flex flex-col lg:flex-row rounded-3xl overflow-hidden bg-white border border-primary/15 shadow-[0_8px_40px_rgba(0,171,179,0.18)] hover:shadow-[0_12px_48px_rgba(0,171,179,0.28)] transition-[opacity,transform,box-shadow] duration-slow [content-visibility:auto]">
            <a
              href={`${base}/blog/${featuredPost.id}`}
              class="relative block overflow-hidden aspect-16/10 lg:w-[58%] lg:shrink-0 lg:aspect-auto lg:min-h-[min(22rem,52vh)]"
              aria-label={`Читать статью: ${featuredPost.data.title}`}
            >
              {(featuredPost.data.heroImages && featuredPost.data.heroImages.length >= 2) ? (
                <div class="absolute inset-0 transition-transform duration-slow ease-out group-hover:scale-[1.02]" data-slideshow={`featured-${featuredPost.id}`}>
                  {featuredPost.data.heroImages.slice(0, 8).map((img, i) => (
                    <div class="absolute inset-0 transition-opacity duration-700 ease-in-out" data-slide={i} data-slideshow-group={`featured-${featuredPost.id}`}>
                      <Image
                        src={img}
                        alt={`${featuredPost.data.title} — фото ${i + 1}`}
                        width={1200}
                        height={675}
                        loading={i === 0 ? 'eager' : 'lazy'}
                        class="w-full h-full object-cover"
                      />
                    </div>
                  ))}
                </div>
              ) : (featuredPost.data.heroImage ? (
                <Image
                  src={featuredPost.data.heroImage}
                  alt={featuredPost.data.title}
                  width={1200}
                  height={675}
                  loading="eager"
                  class="object-cover w-full h-full transition-transform duration-slow ease-out group-hover:scale-[1.02]"
                />
              ) : (
                <div class="w-full h-full bg-linear-to-br from-primary/10 to-primary/20 flex items-center justify-center min-h-48">
                  <svg class="w-16 h-16 text-primary/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              ))}
              <div class="absolute top-4 left-4 flex flex-wrap items-center gap-2">
                <span class="bg-cta text-gray-900 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider font-montserrat shadow-sm">
                  Выбор редакции
                </span>
                {featuredPost.data.destination && (
                  <span
                    class:list={[
                      'inline-block rounded-full px-3 py-1 text-[10px] font-black uppercase tracking-wider font-montserrat',
                      getTourStyleBadge(featuredPost.data.destination).className,
                    ]}
                  >
                    {getTourStyleBadge(featuredPost.data.destination).label}
                  </span>
                )}
              </div>
            </a>

            <div class="p-6 md:p-8 lg:p-10 flex flex-col grow lg:max-w-[42%]">
              <time
                datetime={featuredPost.data.pubDate.toISOString()}
                class="text-xs text-gray-400 font-inter mb-3 block"
              >
                {featuredPost.data.pubDate.toLocaleDateString('ru-RU', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <h3 class="text-xl md:text-2xl lg:text-[1.65rem] font-extrabold text-gray-900 mb-3 font-montserrat leading-tight tracking-tight line-clamp-3 group-hover:text-primary transition-colors duration-fast">
                <a href={`${base}/blog/${featuredPost.id}`}>
                  {featuredPost.data.title}
                </a>
              </h3>
              <p class="text-sm md:text-base text-gray-600 line-clamp-4 mb-6 grow font-inter leading-relaxed">
                {featuredPost.data.description}
              </p>
              <div class="flex flex-wrap items-center justify-between gap-4 pt-4 border-t border-gray-100 mt-auto">
                <span class="text-xs font-semibold text-gray-500 font-inter">
                  {featuredPost.data.author}
                </span>
                <a
                  href={`${base}/blog/${featuredPost.id}`}
                  class="group/link inline-flex items-center gap-2 text-sm font-bold text-primary hover:text-primary-dark transition-colors duration-fast font-montserrat uppercase tracking-wide"
                  aria-label={`Читать: ${featuredPost.data.title}`}
                >
                  Читать материал
                  <svg class="w-4 h-4 group-hover/link:translate-x-0.5 transition-transform duration-fast" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        )
      }
      {
        latestPosts.map((post, index) => (
          <article class="group reveal-hidden flex flex-col rounded-3xl overflow-hidden bg-white border border-white/10 shadow-[0_4px_24px_rgba(0,171,179,0.15)] hover:shadow-[0_8px_32px_rgba(0,171,179,0.25)] transition-[opacity,transform,box-shadow] duration-slow [content-visibility:auto]">
            <!-- Изображение -->
            <a
              href={`${base}/blog/${post.id}`}
              class="block relative overflow-hidden aspect-4/3"
              aria-label={`Читать статью: ${post.data.title}`}
            >
              {(post.data.heroImages && post.data.heroImages.length >= 2) ? (
                <!-- Слайд-шоу с плавной сменой -->
                <div class="absolute inset-0 transition-transform duration-slow ease-out group-hover:scale-[1.04]" data-slideshow={`${post.id}-${index}`}>
                  {post.data.heroImages.slice(0, 8).map((img, i) => (
                    <div class="absolute inset-0 transition-opacity duration-700 ease-in-out" data-slide={i} data-slideshow-group={`${post.id}-${index}`}>
                      <Image
                        src={img}
                        alt={`${post.data.title} — фото ${i + 1}`}
                        width={600}
                        height={450}
                        loading={i === 0 ? 'eager' : 'lazy'}
                        class="w-full h-full object-cover"
                      />
                    </div>
                  ))}
                </div>
              ) : (post.data.heroImage ? (
                <Image
                  src={post.data.heroImage!}
                  alt={post.data.title}
                  width={600}
                  height={450}
                  loading={index === 0 ? 'eager' : 'lazy'}
                  class="object-cover w-full h-full transition-transform duration-slow ease-out group-hover:scale-[1.04]"
                />
              ) : (
                <div class="w-full h-full bg-linear-to-br from-primary/10 to-primary/20 flex items-center justify-center">
                  <svg class="w-12 h-12 text-primary/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              ))}
              <!-- Тег направления -->
              {post.data.destination && (
                <div class="absolute top-4 left-4">
                  <span
                    class:list={[
                      'inline-block rounded-full px-3 py-1 text-[10px] font-black uppercase tracking-wider font-montserrat',
                      getTourStyleBadge(post.data.destination).className,
                    ]}
                  >
                    {getTourStyleBadge(post.data.destination).label}
                  </span>
                </div>
              )}
            </a>

            <!-- Контент карточки -->
            <div class="p-5 md:p-6 flex flex-col grow">
              <!-- Дата -->
              <time
                datetime={post.data.pubDate.toISOString()}
                class="text-xs text-gray-400 font-inter mb-2 block"
              >
                {post.data.pubDate.toLocaleDateString('ru-RU', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>

              <!-- Заголовок -->
              <h3 class="text-base font-extrabold text-gray-900 mb-2 font-montserrat leading-snug line-clamp-2 group-hover:text-primary transition-colors duration-fast">
                <a href={`${base}/blog/${post.id}`}>
                  {post.data.title}
                </a>
              </h3>

              <!-- Описание -->
              <p class="text-sm text-gray-500 line-clamp-2 mb-4 grow font-inter leading-relaxed">
                {post.data.description}
              </p>

              <!-- Футер карточки -->
              <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                <span class="text-xs font-semibold text-gray-500 font-inter">
                  {post.data.author}
                </span>
                <a
                  href={`${base}/blog/${post.id}`}
                  class="group/link inline-flex items-center gap-1.5 text-xs font-semibold text-primary hover:text-primary-dark transition-colors duration-fast font-montserrat uppercase tracking-wide"
                  aria-label={`Читать: ${post.data.title}`}
                >
                  Читать
                  <svg class="w-3.5 h-3.5 group-hover/link:translate-x-0.5 transition-transform duration-fast" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>

  </div>
</section>

<script>
  /** Сброс предыдущего таймера на контейнере — иначе при VT накапливаются setInterval */
  const journalSlideshowTimers = new WeakMap<HTMLElement, ReturnType<typeof setInterval>>();

  function initSlideshows() {
    const slideshows = document.querySelectorAll('[data-slideshow]');

    slideshows.forEach((container) => {
      const el = container as HTMLElement;
      const prev = journalSlideshowTimers.get(el);
      if (prev !== undefined) {
        clearInterval(prev);
        journalSlideshowTimers.delete(el);
      }

      const group = container.getAttribute('data-slideshow');
      const slides = container.querySelectorAll(`[data-slideshow-group="${group}"]`);

      if (slides.length < 2) return;

      slides.forEach((slide, i) => {
        (slide as HTMLElement).style.opacity = i === 0 ? '1' : '0';
      });

      let current = 0;
      const intervalMs = 5000;

      const nextSlide = () => {
        const next = (current + 1) % slides.length;
        (slides[current] as HTMLElement).style.opacity = '0';
        (slides[next] as HTMLElement).style.opacity = '1';
        current = next;
      };

      journalSlideshowTimers.set(el, setInterval(nextSlide, intervalMs));
    });
  }

  document.addEventListener('DOMContentLoaded', initSlideshows);
  document.addEventListener('astro:page-load', initSlideshows);
</script>
