---
// src/components/ScrollToTop.astro
---

<!-- Кнопка "Наверх" - изначально скрыта -->
<button
  id="scroll-to-top"
  aria-label="Вернуться наверх"
  class="fixed bottom-5 right-4 z-2147483646 pointer-events-none opacity-0 translate-y-20 transition-all duration-slow rounded-full bg-white/20 backdrop-blur p-3 text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 sm:bottom-6 sm:right-6 hover:-translate-y-1 hover:scale-110 active:scale-95 cursor-pointer"
  style="filter: drop-shadow(0 10px 10px rgba(0,0,0,0.6));"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="h-6 w-6"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2.5"
      d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
  </svg>
</button>

<script is:inline>
  (function () {
    // Ждем загрузки DOM
    function initScrollToTop() {
      const scrollBtn = document.getElementById('scroll-to-top');

      if (!scrollBtn) {
        console.warn('ScrollToTop: кнопка не найдена');
        return;
      }

      let ticking = false;

      // Функция обновления видимости кнопки
      function updateButtonVisibility() {
        // Высота всего документа
        const docHeight = document.documentElement.scrollHeight;
        // Текущая позиция низа экрана (scrollY + высота окна)
        const scrollPos = window.scrollY + window.innerHeight;

        // Порог срабатывания: 50px до самого конца страницы
        // Если разница меньше 50px — значит мы в самом низу
        if (docHeight - scrollPos < 50) {
          scrollBtn.classList.remove(
            'opacity-0',
            'translate-y-20',
            'pointer-events-none',
          );
          scrollBtn.classList.add(
            'opacity-100',
            'translate-y-0',
            'pointer-events-auto',
          );
        } else {
          scrollBtn.classList.remove(
            'opacity-100',
            'translate-y-0',
            'pointer-events-auto',
          );
          scrollBtn.classList.add(
            'opacity-0',
            'translate-y-20',
            'pointer-events-none',
          );
        }

        ticking = false;
      }

      // Обработчик скролла с throttling
      function onScroll() {
        if (!ticking) {
          window.requestAnimationFrame(updateButtonVisibility);
          ticking = true;
        }
      }

      // Обработчик клика
      function onClick() {
        if (navigator.vibrate) {
          navigator.vibrate(10);
        }

        window.scrollTo({
          top: 0,
          behavior: 'smooth',
        });
      }

      // Подключаем обработчики
      window.addEventListener('scroll', onScroll, { passive: true });
      scrollBtn.addEventListener('click', onClick);

      // Проверяем начальное состояние
      updateButtonVisibility();

      console.log('ScrollToTop: инициализирован');
    }

    // Запускаем инициализацию
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initScrollToTop);
    } else {
      initScrollToTop();
    }
  })();
</script>
