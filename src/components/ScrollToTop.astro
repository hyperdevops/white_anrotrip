---
// src/components/ScrollToTop.astro
---

<!-- Кнопка "Наверх" - изначально скрыта. Без backdrop-blur и filter — остаётся чёткой при scale -->
<button
  id="scroll-to-top"
  aria-label="Вернуться наверх"
  class="scroll-to-top-btn fixed bottom-5 right-4 z-2147483646 pointer-events-none opacity-0 translate-y-20 rounded-full bg-gray-900/95 p-3 text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 sm:bottom-6 sm:right-6 active:scale-[0.98] active:translate-y-0.5 cursor-pointer"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="h-6 w-6"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2.5"
      d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
  </svg>
</button>

<script is:inline>
  (function () {
    let scrollHandler = null;
    let clickHandler = null;

    function initScrollToTop() {
      const scrollBtn = document.getElementById('scroll-to-top');

      if (!scrollBtn) {
        return;
      }

      // Удаляем старые обработчики при повторной инициализации (astro:page-load)
      if (scrollHandler) {
        window.removeEventListener('scroll', scrollHandler, { passive: true });
      }
      if (clickHandler) {
        scrollBtn.removeEventListener('click', clickHandler);
      }

      let ticking = false;

      function updateButtonVisibility() {
        const docHeight = document.documentElement.scrollHeight;
        const scrollPos = window.scrollY + window.innerHeight;

        if (docHeight - scrollPos < 50) {
          scrollBtn.classList.remove(
            'opacity-0',
            'translate-y-20',
            'pointer-events-none',
          );
          scrollBtn.classList.add(
            'opacity-100',
            'translate-y-0',
            'pointer-events-auto',
          );
        } else {
          scrollBtn.classList.remove(
            'opacity-100',
            'translate-y-0',
            'pointer-events-auto',
          );
          scrollBtn.classList.add(
            'opacity-0',
            'translate-y-20',
            'pointer-events-none',
          );
        }

        ticking = false;
      }

      scrollHandler = function onScroll() {
        if (!ticking) {
          window.requestAnimationFrame(updateButtonVisibility);
          ticking = true;
        }
      };

      clickHandler = function onClick() {
        if (navigator.vibrate) {
          navigator.vibrate(10);
        }

        // Mobile: плавная медленная прокрутка наверх (700ms)
        if (window.matchMedia('(max-width: 767px)').matches) {
          const start = window.scrollY;
          const startTime = performance.now();
          const duration = 700;
          const easeInOutCubic = function (t) {
            return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
          };
          const step = function () {
            const elapsed = performance.now() - startTime;
            const progress = Math.min(1, elapsed / duration);
            const eased = easeInOutCubic(progress);
            window.scrollTo(0, start * (1 - eased));
            if (progress < 1) requestAnimationFrame(step);
          };
          requestAnimationFrame(step);
          return;
        }

        // Desktop: без изменений (как было)
        const start = window.scrollY;
        const startTime = performance.now();
        const duration = 0;

        function easeOutCubic(t) {
          return 1 - Math.pow(1 - t, 3);
        }

        function step() {
          const elapsed = performance.now() - startTime;
          const progress = Math.min(1, elapsed / duration);
          const eased = easeOutCubic(progress);
          window.scrollTo(0, start * (1 - eased));
          if (progress < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      };

      window.addEventListener('scroll', scrollHandler, { passive: true });
      scrollBtn.addEventListener('click', clickHandler);

      updateButtonVisibility();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initScrollToTop);
    } else {
      initScrollToTop();
    }

    document.addEventListener('astro:page-load', () => {
      requestAnimationFrame(initScrollToTop);
    });
  })();
</script>
