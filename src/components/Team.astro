const team = [
  { name: 'Екатерина Неделько',    role: 'Руководитель',       dept: 'Авиаотдел',           email: 'e.nedelko@anrotrip.ru',        phone: '8 (800) 222-44-73 доб. 115', img: eNedelkoImg      },
  { name: 'Елена Щербакова',       role: 'Авиакассир',         dept: 'Авиаотдел',           email: 'lena@anrotrip.ru',             phone: '8 (800) 222-44-73 доб. 114', img: eSherbakovaImg   },
  { name: 'Светлана Мосинцева',    role: 'Авиакассир',         dept: 'Авиаотдел',           email: 'svetlana.m@anrotrip.ru',       phone: '8 (800) 222-44-73 доб. 111', img: sMosincevaImg    },
  { name: 'Наталья Королёва',      role: 'Авиакассир',         dept: 'Авиаотдел',           email: 'koroleva@anrotrip.ru',         phone: '8 (800) 222-44-73 доб. 112', img: nKorolevaImg     },
  { name: 'Юлия Субботина',        role: 'Авиакассир',         dept: 'Авиаотдел',           email: 'iuliia.s@anrotrip.ru',         phone: '8 (800) 222-44-73 доб. 116', img: uSubotinaImg     },
  { name: 'Диана Семушова',        role: 'Авиакассир',         dept: 'Авиаотдел',           email: 'diana@anrotrip.ru',            phone: '8 (800) 222-44-73 доб. 110', img: dSemushinaImg    },
  { name: 'Татьяна Данкова',       role: 'Авиакассир',         dept: 'Авиаотдел',           email: 't.dankova@anrotrip.ru',        phone: '8 (800) 222-44-73',          img: tDankovaImg      },
  { name: 'Светлана Леднева',      role: 'Авиакассир',         dept: 'Авиаотдел',           email: 'svetlana.l@anrotrip.ru',       phone: '8 (800) 222-44-73 доб. 115', img: sLednevaImg      },
  { name: 'Ксения Мусина',         role: 'Менеджер',           dept: 'Отдел сервиса',       email: 'ksenia@anrotrip.ru',           phone: '8 (800) 222-44-73 доб. 666', img: kMusinaImg       },
  { name: 'Анна Денисова',         role: 'Руководитель',       dept: 'Туристический отдел', email: 'a.denisova@anrotrip.ru',       phone: '8 (800) 222-44-73',          img: aDenisovaImg     },
  { name: 'Анна Бочкарева',        role: 'Менеджер',           dept: 'Туристический отдел', email: 'bochkareva@anrotrip.ru',       phone: '8 (800) 222-44-73 доб. 120', img: aBochkarevaImg   },
  { name: 'Анастасия Крестовских', role: 'Менеджер',           dept: 'Туристический отдел', email: 'anastasiya@anrotrip.ru',       phone: '8 (800) 222-44-73 доб. 117', img: aKrestovskichImg },
  { name: 'Елена Голованова',      role: 'Менеджер',           dept: 'Туристический отдел', email: 'anro.chelyabinsk@anrotrip.ru', phone: '8 (800) 222-44-73 доб. 119', img: eGolovanovaImg   },
  { name: 'Юлия Пасынкова',        role: 'Менеджер',           dept: 'Туристический отдел', email: 'anro.chelyabinsk@anrotrip.ru', phone: '8 (800) 222-44-73 доб. 118', img: uPasynkovaImg    },
  { name: 'Анна Батенева',         role: 'Менеджер',           dept: 'Туристический отдел', email: 'a.bateneva@anrotrip.ru',       phone: '8 (800) 222-44-73 доб. 122', img: aBatenevaImg     },
  { name: 'Ольга Голикова',        role: 'Визовый специалист', dept: 'Туристический отдел', email: 'visa@anrotrip.ru',             phone: '8 (800) 222-44-73',          img: oGolikovaImg     },
  { name: 'Юлия Денисова',         role: 'Директор офиса',     dept: 'г. Челябинск',        email: 'online@anrotrip.ru',           phone: '8 (800) 222-44-73',          img: uDenisovaImg     },
  { name: 'Ольга Домашевская',     role: 'Главный бухгалтер',  dept: 'Финансовый отдел',    email: 'finance@anrotrip.ru',          phone: '8 (800) 222-44-73 доб. 333', img: oDomashevskayaImg},
  { name: 'Екатерина Мамыкина',    role: 'Бухгалтер',          dept: 'Финансовый отдел',    email: 'katya@anrotrip.ru',            phone: '8 (800) 222-44-73',          img: eMamikinaImg     },
  { name: 'Наталья Вафина',        role: 'Бухгалтер',          dept: 'Финансовый отдел',    email: 'natalia.v@anrotrip.ru',        phone: '8 (800) 222-44-73',          img: nVafinaImg       },
  { name: 'Кристина Наговицына',   role: 'Бухгалтер',          dept: 'Финансовый отдел',    email: 'buh1@anrotrip.ru',             phone: '8 (800) 222-44-73',          img: kNagovicynaImg   },
];
---

<!-- ═══ ОСНОВАТЕЛИ ═══ -->
<section id="team" class="relative -mt-7 py-16 md:py-24 bg-gray-950 text-white overflow-hidden">
  <!-- Декор -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-size-[60px_60px] pointer-events-none"></div>
  <div class="absolute top-0 right-0 w-96 h-96 bg-primary/8 rounded-full blur-none md:blur-3xl pointer-events-none translate-x-1/2 -translate-y-1/2"></div>

  <div class="container mx-auto px-4 sm:px-6 max-w-7xl relative z-10">

    <!-- Заголовок -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14 md:mb-16 reveal-hidden">
      <div>
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/8 border border-white/12 mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-primary md:animate-pulse"></span>
          <span class="text-xs font-semibold text-white/60 uppercase tracking-widest font-montserrat">Команда</span>
        </div>
        <h2 class="font-montserrat font-extrabold text-white uppercase tracking-tight leading-none" style="font-size: clamp(2rem, 1.5rem + 3vw, 4rem);">
          Команда<br />
          <span class="text-primary">ANRO TRIP</span>
        </h2>
      </div>
      <p class="text-white/35 text-sm max-w-xs leading-relaxed md:pb-2">
        Профессионалы, которые делают ваши путешествия идеальными — с первого звонка до возвращения домой
      </p>
    </div>

    <!-- Основатели + групповое фото: мобайл — колонка, десктоп — 3 в ряд (групповое шире) -->
    <div class="grid grid-cols-1 sm:grid-cols-[1fr_1fr_2fr] gap-4 md:gap-5 mb-14" data-reveal-stagger>

      <!-- Анна Рожкова -->
      <div class="reveal-hidden">
        <div class="team-founder-card group relative overflow-hidden rounded-3xl bg-white/5 border border-white/8 flex flex-col">
          <!-- Без градиента — артефакт исчез (градиент конфликтовал с рендерингом при scale) -->
          <div class="relative overflow-hidden h-[320px] sm:h-[360px] bg-gray-900">
            <Image
              src={annaRozhkovaImg}
              alt="Анна Рожкова"
              class="w-full h-full object-cover transition-transform duration-slow ease-out group-hover:scale-[1.04]"
              loading="lazy"
            />
          </div>
          <!-- Подпись внизу -->
          <div class="relative px-5 py-4 bg-white/4">
            <h3 class="font-montserrat font-extrabold text-white text-lg leading-tight">Анна Рожкова</h3>
            <p class="text-white/45 text-[10px] uppercase tracking-widest mt-1">Основатель и генеральный директор</p>
          </div>
        </div>
      </div>

      <!-- Никита Рожков -->
      <div class="reveal-hidden">
        <div class="team-founder-card group relative overflow-hidden rounded-3xl bg-white/5 border border-white/8 flex flex-col">
          <div class="relative overflow-hidden h-[320px] sm:h-[360px] bg-gray-900">
            <Image
              src={nikitaRozhkovImg}
              alt="Никита Рожков"
              class="w-full h-full object-cover transition-transform duration-slow ease-out group-hover:scale-[1.04]"
              loading="lazy"
            />
          </div>
          <div class="relative px-5 py-4 bg-white/4">
            <h3 class="font-montserrat font-extrabold text-white text-lg leading-tight">Никита Рожков</h3>
            <p class="text-white/45 text-[10px] uppercase tracking-widest mt-1">Исполнительный директор</p>
          </div>
        </div>
      </div>

      <!-- Групповое фото команды -->
      <div class="reveal-hidden">
        <div class="team-founder-card group relative overflow-hidden rounded-3xl bg-white/5 border border-white/8 flex flex-col">
          <div class="relative overflow-hidden h-[320px] sm:h-[360px] bg-gray-900">
            <Image
              src={teamGroupImg}
              alt="Команда ANRO TRIP"
              class="w-full h-full object-cover transition-transform duration-slow ease-out group-hover:scale-[1.04]"
              loading="lazy"
            />
          </div>
          <div class="relative px-5 py-4 bg-white/4">
            <h3 class="font-montserrat font-extrabold text-white text-lg leading-tight">Наша команда</h3>
            <p class="text-white/45 text-[10px] uppercase tracking-widest mt-1">Специалисты · Авиа · Туры · Визы</p>
          </div>
        </div>
      </div>

    </div>

  </div>

  <!-- Кнопка: открыть / свернуть список (всегда на месте) -->
  <div class="flex justify-center relative z-20 -mb-6" id="team-btn-wrapper">
    <button
      type="button"
      id="toggle-team-btn"
      aria-expanded="false"
      aria-controls="team-list"
      class="team-toggle-btn inline-flex items-center gap-2.5 px-8 py-4 rounded-full bg-white/10 border border-primary/15 text-white font-bold text-sm uppercase tracking-wider hover:bg-white/18 btn-ripple cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-gray-900 transition-[background-color,box-shadow] duration-slow ease-out"
    >
      <svg class="team-btn-icon-users w-4 h-4 shrink-0 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      <span class="team-btn-label font-montserrat">Вся команда</span>
      <svg class="team-btn-chevron w-4 h-4 shrink-0 text-primary transition-transform duration-slow ease-out" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </button>
  </div>
</section>

<!-- ═══ ВСЯ КОМАНДА ═══ -->
<section id="team-list" class="team-list-panel relative bg-gray-50 overflow-hidden transition-[max-height,opacity] duration-slow ease-in-out opacity-0 hidden border-t border-gray-100 motion-reduce:transition-none">
  <div class="container mx-auto px-4 sm:px-6 max-w-7xl pt-12 md:pt-16 pb-16 md:pb-20">

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {team.map((member) => (
        <div class="flex flex-col items-center text-center group transition-transform duration-slow ease-out hover:-translate-y-1">
          <!-- Фото -->
          <div class="w-40 h-40 sm:w-48 sm:h-48 rounded-2xl overflow-hidden mb-4 ring-2 ring-gray-100 group-hover:ring-primary/30 group-hover:shadow-xl transition-all duration-slow ease-out bg-gray-200 shrink-0">
            <Image
              src={member.img}
              alt={member.name}
              class="h-full w-full object-cover transition-transform duration-slow ease-out group-hover:scale-[1.04]"
              loading="lazy"
            />
          </div>

          {member.dept && (
            <div class="text-[9px] text-gray-400 uppercase tracking-widest mb-1 font-semibold">{member.dept}</div>
          )}
          <h3 class="font-montserrat font-bold text-gray-900 text-sm mb-0.5 leading-tight">{member.name}</h3>
          <p class="text-xs text-gray-400 mb-3">{member.role}</p>

          <div class="space-y-1 w-full">
            <a href={`mailto:${member.email}`}
              class="block text-[10px] text-primary hover:text-secondary transition-colors font-medium truncate px-1 cursor-pointer"
              title={member.email}>
              {member.email}
            </a>
            {member.phone && (
              <a href={`tel:${member.phone.replace(/[^\d+]/g, '')}`}
                class="block text-[10px] text-gray-400 hover:text-primary transition-colors truncate px-1 cursor-pointer"
                title={member.phone}>
                {member.phone}
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Свернуть список — после всех фото (как в главной кнопке «Вся команда») -->
    <div class="flex justify-center mt-12 md:mt-14">
      <button
        type="button"
        id="team-collapse-bottom"
        class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-white px-5 py-2.5 text-xs font-bold uppercase tracking-wider text-primary shadow-sm transition-[color,background-color,transform,box-shadow] duration-slow ease-out hover:bg-primary/10 hover:border-primary/35 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-gray-50 md:text-sm"
      >
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
        </svg>
        Свернуть
      </button>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    function initTeamListToggle() {
      var btn = document.getElementById('toggle-team-btn');
      var wrapper = document.getElementById('team-list');
      var collapseBottom = document.getElementById('team-collapse-bottom');
      var teamSection = document.getElementById('team');

      if (!btn || !wrapper) return;

      var panel = wrapper;
      var toggleBtn = btn;

      var labelEl = toggleBtn.querySelector('.team-btn-label');
      var chevronEl = toggleBtn.querySelector('.team-btn-chevron');

      var COLLAPSE_MS = 520;

      function isExpanded() {
        return toggleBtn.getAttribute('aria-expanded') === 'true';
      }

      function setExpandedUi(expanded) {
        toggleBtn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        if (labelEl) {
          labelEl.textContent = expanded ? 'Свернуть' : 'Вся команда';
        }
        if (chevronEl) {
          chevronEl.classList.toggle('rotate-180', expanded);
        }
      }

      function openList() {
        panel.classList.remove('hidden');
        panel.style.maxHeight = '0px';
        void panel.offsetHeight;
        requestAnimationFrame(function () {
          var h = panel.scrollHeight;
          if (h < 1) {
            panel.style.maxHeight = 'none';
          } else {
            panel.style.maxHeight = h + 'px';
          }
          panel.classList.remove('opacity-0');
          panel.classList.add('opacity-100');
        });
        setExpandedUi(true);
      }

      function closeList(opts) {
        var scrollToTeam = opts && opts.scrollToTeam === true;
        if (panel.classList.contains('hidden')) return;

        var h = panel.scrollHeight;
        panel.style.maxHeight = h + 'px';
        void panel.offsetHeight;
        panel.style.maxHeight = '0px';
        panel.classList.remove('opacity-100');
        panel.classList.add('opacity-0');
        setExpandedUi(false);

        var done = false;
        function finish() {
          if (done) return;
          done = true;
          panel.classList.add('hidden');
          panel.style.maxHeight = '';
          if (scrollToTeam && teamSection) {
            teamSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }

        function onEnd(e) {
          if (e.target !== panel || e.propertyName !== 'max-height') return;
          panel.removeEventListener('transitionend', onEnd);
          finish();
        }
        panel.addEventListener('transitionend', onEnd);
        window.setTimeout(finish, COLLAPSE_MS);
      }

      function toggle() {
        if (isExpanded()) {
          closeList({ scrollToTeam: false });
        } else {
          openList();
        }
      }

      toggleBtn.onclick = function () {
        toggle();
      };
      if (collapseBottom) {
        collapseBottom.onclick = function () {
          closeList({ scrollToTeam: true });
        };
      }
    }

    function runInit() {
      initTeamListToggle();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', runInit);
    } else {
      runInit();
    }
    if (!window.__anroTeamPageLoadInit) {
      window.__anroTeamPageLoadInit = true;
      document.addEventListener('astro:page-load', runInit);
    }
  })();
</script>
