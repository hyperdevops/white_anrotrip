<!-- 1. ТЕМНАЯ СЕКЦИЯ + КНОПКА -->
<section id="team" class="pt-24 pb-28 bg-[#262626] text-white relative z-10 border-t border-gray-800">
  <div class="container mx-auto px-4 max-w-7xl relative">

    <h2 class="font-montserrat text-3xl font-extrabold text-center text-white mb-16 reveal-hidden uppercase tracking-wider">
      Команда ANRO TRIP
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto reveal-hidden">
      {founders.map((person) => (
        <div class="flex flex-col sm:flex-row items-center gap-6 bg-[#333333] p-6 rounded-2xl border border-white/5 hover:border-primary/30 transition-all duration-300 shadow-xl group">
          <div class="w-32 h-32 shrink-0 rounded-xl overflow-hidden shadow-lg bg-[#2a2a2a]">
            <img
              src={person.image}
              alt={person.name}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 grayscale group-hover:grayscale-0"
              loading="lazy"
            />
          </div>
          <div class="text-center sm:text-left">
            <h3 class="font-montserrat text-xl font-bold text-white mb-1">{person.name}</h3>
            <p class="text-xs text-gray-400 mb-3 uppercase tracking-wider">{person.role}</p>
            <a href={`mailto:${person.email}`} class="text-primary font-bold hover:text-white transition-colors text-sm">
              {person.email}
            </a>
          </div>
        </div>
      ))}
    </div>

  </div>

  <!-- КНОПКА -->
	<div class="absolute -bottom-19 left-0 w-full flex justify-center z-30 transition-all duration-500" id="team-btn-wrapper">
    <button
      id="toggle-team-btn"
      class="inline-block px-12 py-4 rounded-full bg-secondary text-white border-2 border-secondary font-bold uppercase tracking-wider shadow-lg shadow-cyan-900/20 hover:bg-white hover:text-secondary hover:-translate-y-1 transition-all duration-300 cursor-pointer"
    >
      Показать еще
    </button>
  </div>
</section>

<!-- 2. БЕЛАЯ СЕКЦИЯ (ОСТАЛЬНАЯ КОМАНДА) -->
<!-- CLASS HIDDEN: Главное изменение! Блок физически убран со страницы -->
<section
id="team-list"
class="relative bg-white overflow-hidden transition-all duration-1000 ease-in-out max-h-0 opacity-0 hidden"
>
  <!-- Внутренний контейнер -->
  <!-- pt-20 создает отступ сверху ПОСЛЕ раскрытия -->
  <div class="container mx-auto px-4 max-w-7xl pt-20 pb-20 border-t border-gray-100">

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-16 gap-x-8">
      {team.map((member) => (
        <div class="flex flex-col items-center text-center group">

          <!-- Аватарка -->
          <div class="w-40 h-40 rounded-full overflow-hidden mb-5 border-4 border-white shadow-xl group-hover:scale-105 transition-all duration-300 relative bg-gray-100 ring-1 ring-gray-100">
            {member.img ? (
              <img src={member.img} alt={member.name} class="w-full h-full object-cover" loading="lazy" />
            ) : (
              <div class="w-full h-full flex items-center justify-center bg-gray-200 text-gray-400 text-4xl font-bold">
                {member.name.charAt(0)}
              </div>
            )}
          </div>

          <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-1">{member.name}</h3>

          {member.dept && <p class="text-[10px] text-gray-400 uppercase tracking-widest mb-1">{member.dept}</p>}
          <p class="text-sm text-gray-500 mb-3 font-medium">{member.role}</p>

          <div class="space-y-1 text-sm flex flex-col items-center">
            <a href={`mailto:${member.email}`} class="text-primary hover:text-secondary transition-colors font-medium">{member.email}</a>
            {member.phone && <a href={`tel:${member.phone.replace(/[^\d+]/g, '')}`} class="text-secondary hover:text-primary transition-colors font-bold whitespace-nowrap">{member.phone}</a>}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  const btn = document.getElementById('toggle-team-btn');
  const btnWrapper = document.getElementById('team-btn-wrapper');
  const wrapper = document.getElementById('team-list');

  if (btn && wrapper && btnWrapper) {
    btn.addEventListener('click', () => {
      // 1. Убираем класс hidden, чтобы блок появился в DOM
      wrapper.classList.remove('hidden');

      // Небольшая пауза (requestAnimationFrame), чтобы браузер успел отрисовать блок перед стартом анимации
      requestAnimationFrame(() => {
          wrapper.style.maxHeight = wrapper.scrollHeight + "px";
          wrapper.classList.remove('opacity-0');
          wrapper.classList.add('opacity-100');
      });

      // 2. Скрываем кнопку
      btnWrapper.style.opacity = '0';
      btnWrapper.style.pointerEvents = 'none';

      setTimeout(() => {
         btnWrapper.style.display = 'none';
      }, 500);
    });
  }
</script>
