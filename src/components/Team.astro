---

<!-- ═══ ОСНОВАТЕЛИ ═══ -->
<section id="team" class="relative py-16 md:py-24 bg-gray-950 text-white overflow-hidden">
  <!-- Декор -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:60px_60px] pointer-events-none"></div>
  <div class="absolute top-0 right-0 w-96 h-96 bg-primary/8 rounded-full blur-3xl pointer-events-none translate-x-1/2 -translate-y-1/2"></div>

  <div class="container mx-auto px-4 sm:px-6 max-w-7xl relative z-10">

    <!-- Заголовок -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14 md:mb-16 reveal-hidden">
      <div>
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/8 border border-white/12 mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
          <span class="text-xs font-semibold text-white/60 uppercase tracking-widest font-montserrat">Команда</span>
        </div>
        <h2 class="font-montserrat font-extrabold text-white uppercase tracking-tight leading-[1.0]" style="font-size: clamp(2rem, 1.5rem + 3vw, 4rem);">
          Команда<br />
          <span class="text-primary">ANRO TRIP</span>
        </h2>
      </div>
      <p class="text-white/35 text-sm max-w-xs leading-relaxed md:pb-2">
        Профессионалы, которые делают ваши путешествия идеальными — с первого звонка до возвращения домой
      </p>
    </div>

    <!-- Основатели: 2 карточки горизонтально -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 max-w-4xl mx-auto reveal-hidden mb-14">
      {founders.map((person) => (
        <div class="group relative overflow-hidden rounded-3xl bg-white/5 border border-white/8 hover:border-primary/30 hover:bg-white/8 transition-all duration-400 p-6 sm:p-8 flex flex-col sm:flex-row items-center gap-6">
          <!-- Фото -->
          <div class="shrink-0 w-28 h-28 sm:w-32 sm:h-32 rounded-2xl overflow-hidden ring-2 ring-white/10 group-hover:ring-primary/30 transition-all duration-400">
            <Image
              src={person.image}
              alt={person.name}
              class="w-full h-full object-cover object-top grayscale group-hover:grayscale-0 scale-105 group-hover:scale-110 transition-all duration-500"
              loading="lazy"
            />
          </div>
          <!-- Текст -->
          <div class="text-center sm:text-left flex-1">
            <!-- Бейдж роли -->
            <div class="inline-block px-2.5 py-1 rounded-full bg-primary/15 text-primary text-[10px] font-bold uppercase tracking-widest mb-3">
              {person.role.includes('Основатель') ? 'Основатель' : 'Директор'}
            </div>
            <h3 class="font-montserrat font-extrabold text-white text-xl mb-1">{person.name}</h3>
            <p class="text-white/40 text-xs mb-4 uppercase tracking-wide">{person.role}</p>
            <a href={`mailto:${person.email}`}
              class="inline-flex items-center gap-2 text-primary font-semibold text-sm hover:text-white transition-colors group/mail">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              {person.email}
            </a>
          </div>
        </div>
      ))}
    </div>

  </div>

  <!-- Кнопка "Показать всю команду" -->
  <div class="flex justify-center relative z-20 -mb-6" id="team-btn-wrapper">
    <button id="toggle-team-btn"
      class="inline-flex items-center gap-2.5 px-8 py-4 rounded-full bg-white/8 border border-white/15 text-white font-bold text-sm uppercase tracking-wider hover:bg-white/15 hover:-translate-y-0.5 transition-all duration-300 backdrop-blur-sm btn-magnetic cursor-pointer"
    >
      <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      Вся команда
    </button>
  </div>
</section>

<!-- ═══ ВСЯ КОМАНДА ═══ -->
<section id="team-list" class="relative bg-gray-50 overflow-hidden transition-all duration-1000 ease-in-out max-h-0 opacity-0 hidden border-t border-gray-100">
  <div class="container mx-auto px-4 sm:px-6 max-w-7xl pt-20 pb-16 md:pb-20">

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6 md:gap-8">
      {team.map((member) => (
        <div class="flex flex-col items-center text-center group">
          <!-- Фото -->
          <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-2xl overflow-hidden mb-4 ring-2 ring-gray-100 group-hover:ring-primary/30 group-hover:shadow-lg transition-all duration-300 bg-gray-200 shrink-0">
            <Image
              src={member.img}
              alt={member.name}
              class="w-full h-full object-cover object-top transition-transform duration-400 group-hover:scale-105"
              loading="lazy"
            />
          </div>

          {member.dept && (
            <div class="text-[9px] text-gray-400 uppercase tracking-widest mb-1 font-semibold">{member.dept}</div>
          )}
          <h3 class="font-montserrat font-bold text-gray-900 text-sm mb-0.5 leading-tight">{member.name}</h3>
          <p class="text-xs text-gray-400 mb-3">{member.role}</p>

          <div class="space-y-1 w-full">
            <a href={`mailto:${member.email}`}
              class="block text-[10px] text-primary hover:text-secondary transition-colors font-medium truncate px-1">
              {member.email}
            </a>
            {member.phone && (
              <a href={`tel:${member.phone.replace(/[^\d+]/g, '')}`}
                class="block text-[10px] text-gray-400 hover:text-primary transition-colors whitespace-nowrap">
                {member.phone}
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const btn        = document.getElementById('toggle-team-btn');
  const btnWrapper = document.getElementById('team-btn-wrapper');
  const wrapper    = document.getElementById('team-list');

  if (btn && wrapper && btnWrapper) {
    btn.addEventListener('click', () => {
      wrapper.classList.remove('hidden');
      requestAnimationFrame(() => {
        wrapper.style.maxHeight = wrapper.scrollHeight + 'px';
        wrapper.classList.remove('opacity-0');
        wrapper.classList.add('opacity-100');
      });
      btnWrapper.style.opacity = '0';
      btnWrapper.style.pointerEvents = 'none';
      setTimeout(() => { btnWrapper.style.display = 'none'; }, 500);
    });
  }
</script>
