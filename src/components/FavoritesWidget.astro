---
// src/components/FavoritesWidget.astro
---

<a
  href="#"
  id="favorites-widget"
  class="fixed bottom-6 left-4 z-2147483630 items-center justify-center gap-3 rounded-full bg-white/80 p-3 sm:p-4 sm:pr-6 text-gray-800 shadow-lg backdrop-blur-md transition-all duration-300 hover:scale-105 hover:bg-white hover:text-primary hover:shadow-primary/20 active:scale-95 group border border-white/40 cursor-pointer w-12 h-12 sm:w-auto sm:h-auto hidden sm:flex"
>
  <!-- Иконка с индикатором -->
  <div class="relative">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-6 w-6 transition-transform duration-300 group-hover:scale-110 text-primary"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
      ></path>
    </svg>

    <!-- Индикатор -->
    <span
      id="fav-count"
      class="absolute -top-1 -right-1 flex h-3 w-3 items-center justify-center rounded-full bg-cta text-[8px] font-bold text-black opacity-0 transition-opacity duration-300"
    >
      0
    </span>
  </div>

  <span
    class="text-xs font-bold uppercase tracking-wider font-montserrat hidden sm:inline-block"
  >
    Избранное
  </span>
</a>

<script>
  const widget = document.getElementById('favorites-widget');

  // Функция обновления счетчика
  const updateCount = () => {
    const countEl = document.querySelector('.TVCartPreviewCompactCount');
    const myCount = document.getElementById('fav-count');

    if (countEl && myCount) {
      const txt = countEl.textContent?.trim();
      // Если цифра не 0 и не скрыта
      if (txt && txt !== '0' && !countEl.classList.contains('TVHide')) {
        myCount.textContent = txt;
        myCount.classList.remove('opacity-0');
      } else {
        myCount.classList.add('opacity-0');
      }
    }
  };

  // Следим за DOM
  const observer = new MutationObserver(() => {
    updateCount();
  });
  observer.observe(document.body, { childList: true, subtree: true });

  // Клик
  widget?.addEventListener('click', (e) => {
    e.preventDefault();

    // Ищем внутреннюю кнопку, на которой висит клик
    const innerBtn = document.querySelector(
      '.TVCartPreviewControl',
    ) as HTMLElement;
    const outerBtn = document.querySelector(
      '.TVCartStickyButton',
    ) as HTMLElement;

    if (innerBtn) {
      innerBtn.click();
      console.log('Clicked inner button');
    } else if (outerBtn) {
      outerBtn.click();
      console.log('Clicked outer button');
    } else {
      console.warn('Кнопка Турвизора не найдена');
    }
  });
</script>
