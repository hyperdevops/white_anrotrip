---
// src/components/Contacts.astro
---

<section
  id="contacts"
  class="relative pt-20 sm:pt-28 pb-10 md:pb-16 bg-white overflow-hidden"
>
  <!-- Декоративный фон -->
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-64 bg-linear-to-b from-gray-950 to-transparent pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-0 right-0 w-96 h-96 bg-primary/4 rounded-full blur-0 md:blur-3xl pointer-events-none translate-x-1/3 translate-y-1/3"
  >
  </div>

  <div class="container mx-auto px-4 sm:px-6 max-w-7xl relative z-10">
    <!-- Заголовок -->
    <div class="text-center mb-14 md:mb-18 reveal-hidden">
      <div
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/8 border border-primary/15 mb-5"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-primary md:animate-pulse"></span>
        <span
          class="text-xs font-semibold text-primary uppercase tracking-widest font-montserrat"
          >Контакты</span
        >
      </div>
      <h2
        class="font-montserrat font-extrabold text-gray-900 uppercase tracking-tight leading-none"
        style="font-size: clamp(2rem, 1.5rem + 3vw, 4rem);"
      >
        Свяжитесь<br />с нами
      </h2>
    </div>

    <!-- Три карточки контактов -->
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5 mb-10 reveal-hidden"
      data-reveal-stagger
    >
      <!-- 1. Связь 24/7 -->
      <div
        class="contacts-card group relative overflow-hidden rounded-3xl bg-gray-900 p-7 sm:p-8 flex flex-col reveal-hidden"
      >
        <div
          class="absolute top-0 right-0 w-48 h-48 bg-primary/8 rounded-full blur-2xl pointer-events-none translate-x-1/3 -translate-y-1/3"
        >
        </div>
        <div class="relative z-10">
          <div
            class="w-12 h-12 rounded-2xl bg-primary/15 flex items-center justify-center mb-6 group-hover:bg-primary/25 transition-colors"
          >
            <svg
              class="w-6 h-6 text-primary"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              viewBox="0 0 24 24"
            >
              <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect>
              <line
                x1="12"
                y1="18"
                x2="12.01"
                y2="18"
                stroke-width="2.5"
                stroke-linecap="round"></line>
            </svg>
          </div>
          <h3 class="font-montserrat font-extrabold text-white text-xl mb-5">
            Для связи 24/7
          </h3>
          <div class="space-y-3">
            <a
              href="tel:88002224473"
              class="block text-2xl font-black text-white hover:text-primary transition-colors font-montserrat tracking-tight cursor-pointer"
            >
              8 (800) 222-44-73
            </a>
            <div>
<a
              href="tel:+79220267059"
              class="block text-lg font-semibold text-white/70 hover:text-primary-light transition-colors"
            >
                +7 (922) 026-70-59
              </a>
              <div class="flex items-center gap-1.5 mt-1">
                <span
                  class="text-[10px] text-white/45 uppercase tracking-widest"
                  >WhatsApp · Telegram · Viber</span
                >
              </div>
            </div>
            <a
              href="mailto:anro@anrotrip.ru"
              class="block text-primary font-semibold text-sm hover:text-primary-light transition-colors cursor-pointer"
            >
              anro@anrotrip.ru
            </a>
            <div class="pt-1">
              <span class="text-white/40 text-xs uppercase tracking-widest"
                >Соцсети:
              </span>
              <a
                href="https://vk.com/anrotrip"
                target="_blank"
                rel="noopener noreferrer"
                class="text-white/60 hover:text-primary-light text-sm font-semibold transition-colors cursor-pointer"
                >@anrotrip</a
              >
              <span class="text-white/40 text-xs ml-1">(VK, Telegram)</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 2. Офис в Челябинске -->
      <div
        class="contacts-card group relative overflow-hidden rounded-3xl bg-linear-to-br from-primary to-secondary p-7 sm:p-8 flex flex-col reveal-hidden"
      >
        <div
          class="absolute -right-8 -bottom-8 w-48 h-48 bg-white/10 rounded-full pointer-events-none"
        >
        </div>
        <div
          class="absolute -right-4 -top-4 w-24 h-24 bg-white/5 rounded-full pointer-events-none"
        >
        </div>
        <div class="relative z-10">
          <div
            class="w-12 h-12 rounded-2xl bg-white/20 flex items-center justify-center mb-6"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="font-montserrat font-extrabold text-white text-xl mb-5">
            Офис в Челябинске
          </h3>
          <div class="space-y-3">
            <p class="text-white font-semibold leading-snug">
              г. Челябинск,<br />
              ул. 250-летия Челябинска, д. 29
            </p>
            <div class="pt-1 space-y-1">
              <p class="text-white/90 font-bold text-sm">ПН–ПТ: 9:00–18:00</p>
              <p class="text-white/60 text-xs">
                СБ–ВС по предварительной договорённости
              </p>
            </div>
            <a
              href="tel:83512252991"
              class="block text-white/80 hover:text-white font-semibold transition-colors text-sm"
            >
              8 (351) 225-29-91 <span class="text-white/40 text-xs">(офис)</span
              >
            </a>
          </div>
        </div>
      </div>

      <!-- 3. Представительства -->
      <div
        class="contacts-card group relative overflow-hidden rounded-3xl bg-gray-50 border border-gray-100 p-7 sm:p-8 flex flex-col reveal-hidden"
      >
        <div
          class="w-12 h-12 rounded-2xl bg-secondary/10 flex items-center justify-center mb-6 group-hover:bg-secondary/20 transition-colors"
        >
          <svg
            class="w-6 h-6 text-secondary"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            viewBox="0 0 24 24"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="2" y1="12" x2="22" y2="12"></line>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"
            ></path>
          </svg>
        </div>
        <h3 class="font-montserrat font-extrabold text-gray-900 text-xl mb-5">
          Представительства
        </h3>
        <div class="space-y-4">
          {
            [
              { city: 'Москва', note: 'по договорённости' },
              { city: 'Екатеринбург', note: 'по договорённости' },
            ].map((loc) => (
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-secondary shrink-0" />
                <div>
                  <span class="font-bold text-gray-900 text-sm">
                    г. {loc.city}
                  </span>
                  <span class="text-secondary/80 text-xs ml-2">{loc.note}</span>
                </div>
              </div>
            ))
          }
          <div class="pt-2">
            <p class="text-gray-600 text-xs leading-relaxed">
              Работаем без выходных. Свяжитесь по телефону или через мессенджер.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA кнопка -->
    <div class="text-center reveal-hidden">
      <button
        onclick="openCallbackModal()"
        class="contacts-cta-btn inline-flex items-center gap-3 px-8 py-4 mt-3 rounded-full bg-gray-900 text-white font-bold text-sm uppercase tracking-wider hover:bg-gray-800 active:scale-[0.98] active:translate-y-0.5 btn-magnetic btn-ripple cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
      >
        <svg
          class="w-4 h-4 text-primary"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
          ></path>
        </svg>
        Заказать обратный звонок
      </button>
    </div>
  </div>
</section>
