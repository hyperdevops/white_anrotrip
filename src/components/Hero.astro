---
// src/components/Hero.astro
import { Image } from 'astro:assets';
import heroBg from '../assets/hero/plane.avif';
---

<section
  class="sticky top-0 z-0 min-h-dvh w-full flex items-center justify-center overflow-hidden"
>
  <div class="absolute inset-0">
    <Image
      src={heroBg}
      alt="Вид из самолета"
      class="h-full w-full object-cover scale-105 animate-[kenburns_30s_infinite_alternate]"
      quality="high"
      loading="eager"
    />
    <!-- Градиент затемнения -->
    <div
      class="absolute inset-0 bg-linear-to-b from-blue-900/40 via-black/10 to-black/60"
    >
    </div>
  </div>

  <div
    class="relative z-10 container mx-auto px-4 text-center text-white mt-16"
  >
    <h1
      class="mx-auto max-w-5xl font-montserrat text-4xl font-extrabold uppercase leading-tight tracking-tight drop-shadow-xl sm:text-6xl md:text-7xl lg:text-8xl"
    >
      Будь на высоте <br />
      <span
        class="text-transparent bg-clip-text bg-linear-to-r from-white via-blue-100 to-blue-200"
      >
        с ANRO TRIP!
      </span>
    </h1>

    <p
      class="mx-auto mt-6 max-w-2xl text-base font-medium text-white/90 sm:text-xl md:text-2xl drop-shadow-md"
    >
      Путешествия вашей мечты начинаются здесь
    </p>

    <div class="mt-12 flex flex-col items-center justify-center">
      <a
        id="hero-search-btn"
        href="#search"
        class="group relative inline-flex items-center justify-center rounded-full bg-(--color-cta) px-12 py-6 text-xl font-black text-[#11111b] transition-all duration-300 hover:scale-110 active:scale-95"
        style="box-shadow: 0 0 20px 5px rgba(255, 212, 23, 0.6);"
      >
        <span
          class="absolute inset-0 rounded-full bg-white/20 group-hover:bg-white/0 transition-colors"
        ></span>
        <span class="relative z-10 flex items-center gap-3">
          ПОИСК ТУРОВ
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-7 w-7 transition-transform duration-300 group-hover:translate-x-2"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="3"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </span>
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce z-20">
    <button
      id="scroll-arrow"
      aria-label="Скролл вниз"
      class="text-white/80 hover:text-white transition-colors cursor-pointer"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-10 w-10 drop-shadow-md"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7"></path>
      </svg>
    </button>
  </div>
</section>

<style>
  @keyframes kenburns {
    0% {
      transform: scale(1);
    }
    100% {
      transform: scale(1.15);
    }
  }
</style>

<script>
  // Скрипт прокрутки
  const searchBtn = document.getElementById('hero-search-btn');
  const arrowBtn = document.getElementById('scroll-arrow');

  if (searchBtn) {
    searchBtn.addEventListener('click', (e) => {
      e.preventDefault();

      // Находим элемент, к которому нужно проскроллить
      const searchAnchor = document.getElementById('search');
      if (searchAnchor) {
        // Прокручиваем к элементу со смещением вверх на 100px
        const rect = searchAnchor.getBoundingClientRect();
        const scrollTop =
          window.pageYOffset || document.documentElement.scrollTop;
        const targetPosition = rect.top + scrollTop - 104; // поднимаем на 100px выше

        // Плавная прокрутка к позиции
        window.scrollTo({
          top: targetPosition,
          behavior: 'smooth',
        });
      }
    });
  }

  if (arrowBtn) {
    arrowBtn.addEventListener('click', (e) => {
      e.preventDefault();
      document
        .getElementById('popular-tours')
        ?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }
</script>
