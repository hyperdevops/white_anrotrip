---
// src/components/Hero.astro
import { Image } from 'astro:assets';
import heroBg from '../assets/hero/plane.avif';
---

<section
  id="hero"
  class="sticky top-0 z-0 min-h-dvh w-full flex items-center justify-center overflow-hidden"
>
  <!-- Фоновое изображение -->
  <div class="absolute inset-0">
    <Image
      src={heroBg}
      alt="Вид из самолёта над облаками"
      class="h-full w-full object-cover scale-105 hero-kenburns"
      quality={75}
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <!-- Динамический градиент (время суток) -->
    <div
      id="hero-gradient"
      class="absolute inset-0 bg-linear-to-b transition-colors duration-[3s] ease-in-out"
    >
    </div>
    <!-- Постоянный нижний затемняющий слой -->
    <div
      class="absolute inset-0 bg-linear-to-t from-black/60 via-black/10 to-transparent pointer-events-none"
    >
    </div>
  </div>

  <!-- Контент -->
  <div
    id="hero-content"
    class="relative z-10 container mx-auto px-6 text-white mt-8"
  >
    <!-- Верхний бейдж -->
    <div class="flex justify-center mb-8 reveal-hidden">
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/12 border border-white/20 text-white/90 text-xs font-semibold uppercase tracking-widest"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-cta animate-pulse"></span>
        Туры · Авиабилеты · Визы · Трансфер
      </div>
    </div>

    <!-- Заголовок -->
    <h1
      class="mx-auto max-w-5xl font-montserrat font-extrabold uppercase text-center leading-[0.9] tracking-tight drop-shadow-2xl"
      style="font-size: clamp(2.25rem, 1.75rem + 5vw, 8rem);"
    >
      Будь
      <br />
      на&nbsp;высоте
      <br />
      <span class="hero-gradient-text">с&nbsp;ANRO TRIP!</span>
    </h1>

    <!-- Подзаголовок: на узких экранах не тесно -->
    <p
      class="mx-auto mt-6 max-w-[95vw] sm:max-w-xl text-center text-white/80 leading-relaxed drop-shadow-md"
      style="font-size: clamp(1rem, 0.8rem + 1vw, 1.35rem);"
    >
      Путешествия вашей мечты — от&nbsp;авиабилетов до<br
        class="hidden sm:block"
      /> полного корпоративного обслуживания
    </p>

    <!-- CTA кнопка -->
    <div
      class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4"
    >
      <a
        id="hero-search-btn"
        href="#search"
        class="group relative inline-flex items-center justify-center gap-3 overflow-hidden rounded-full bg-linear-to-r from-cta to-cta-hover px-10 py-5 font-black text-[#11111b] shadow-[0_0_24px_6px_rgba(255,212,23,0.45)] hover:shadow-[0_0_36px_8px_rgba(255,212,23,0.65)] hover:-translate-y-1 active:translate-y-0 transition-all duration-300 btn-ripple focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
        style="font-size: clamp(0.9rem, 0.75rem + 0.8vw, 1.1rem);"
      >
        <!-- Shine sweep -->
        <span
          class="absolute inset-0 w-[200%] bg-linear-to-r from-transparent via-white/35 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-900 ease-out pointer-events-none"
        ></span>
        <svg
          class="w-5 h-5 shrink-0 relative z-10"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          viewBox="0 0 24 24"
        >
          <circle cx="11" cy="11" r="8"></circle><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21 21l-4.35-4.35"></path>
        </svg>
        <span class="relative z-10 uppercase tracking-wider">Поиск туров</span>
      </a>

      <a
        href="tel:88002224473"
        class="inline-flex items-center gap-2 px-7 py-5 rounded-full border border-white/25 text-white font-semibold hover:bg-white/10 hover:-translate-y-0.5 transition-all duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-transparent"
        style="font-size: clamp(0.85rem, 0.75rem + 0.5vw, 1rem);"
      >
        <svg
          class="w-4 h-4 text-cta"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
          ></path>
        </svg>
        8 (800) 222-44-73
      </a>
    </div>

    <!-- Быстрые стат-пилюли -->
    <!-- <div class="mt-12 flex flex-wrap items-center justify-center gap-3">
      {
        [
          ['18', 'лет опыта'],
          ['14 000+', 'клиентов'],
          ['ТОП-10', 'России'],
          ['24/7', 'поддержка'],
        ].map(([val, label]) => (
          <div class="flex items-center gap-2 px-4 py-2.5 rounded-full bg-white/10 border border-white/15">
            <span class="font-montserrat font-black text-cta text-sm">
              {val}
            </span>
            <span class="text-white/60 text-xs">{label}</span>
          </div>
        ))
      }
    </div>
  </div> -->

    <!-- Скролл-стрелка -->
    <!-- <div class="absolute mt-8 left-1/2 -translate-x-1/2 z-20">
      <button
        id="scroll-arrow"
        aria-label="Скролл вниз"
        class="flex flex-col items-center gap-1.5 group cursor-pointer text-white/60 hover:text-white transition-colors"
      >
        <span
          class="text-[10px] uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity font-medium"
          >Смотреть</span
        >
        <div
          class="w-8 h-12 rounded-full border border-white/30 flex items-start justify-center pt-2 group-hover:border-white/60 transition-colors"
        >
          <div class="w-1 h-2.5 bg-white/70 rounded-full animate-hero-scroll">
          </div>
        </div>
      </button>
    </div> -->
    <div class="absolute mt-12 left-1/2 -translate-x-1/2 animate-bounce z-20">
      <button
        id="scroll-arrow"
        aria-label="Скролл вниз"
        class="text-white/80 hover:text-white transition-colors cursor-pointer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-10 w-10 drop-shadow-md"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 14l-7 7m0 0l-7-7"></path>
        </svg>
      </button>
    </div>
  </div>

  <script>
    const searchBtn = document.getElementById('hero-search-btn');
    const arrowBtn = document.getElementById('scroll-arrow');
    const heroGradient = document.getElementById('hero-gradient');
    const heroContent = document.getElementById('hero-content');
    const hero = document.getElementById('hero');

    // Scroll to search
    searchBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      const anchor = document.getElementById('search');
      if (anchor) {
        const top =
          anchor.getBoundingClientRect().top + window.pageYOffset - 104;
        window.scrollTo({ top, behavior: 'smooth' });
      }
    });

    arrowBtn?.addEventListener('click', () => {
      document
        .getElementById('popular-tours')
        ?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    // Dynamic gradient
    const h = new Date().getHours();
    if (heroGradient) {
      if (h >= 6 && h < 12)
        heroGradient.classList.add(
          'from-orange-400/25',
          'via-yellow-200/8',
          'to-blue-900/40',
        );
      else if (h >= 12 && h < 18)
        heroGradient.classList.add(
          'from-blue-400/20',
          'via-sky-200/8',
          'to-blue-900/35',
        );
      else if (h >= 18 && h < 22)
        heroGradient.classList.add(
          'from-purple-700/40',
          'via-pink-400/12',
          'to-black/65',
        );
      else
        heroGradient.classList.add(
          'from-indigo-900/45',
          'via-black/15',
          'to-black/75',
        );
    }

    // Parallax — только на десктопе (matchMedia hover)
    const isDesktop = window.matchMedia(
      '(hover: hover) and (min-width: 768px)',
    ).matches;
    if (isDesktop && heroContent && hero) {
      let ticking = false;
      function updateParallax() {
        const scrollY = window.scrollY;
        const heroH = (hero as HTMLElement).offsetHeight;
        if (scrollY < heroH) {
          (heroContent as HTMLElement).style.transform =
            `translateY(${scrollY * -0.15}px)`;
          (heroContent as HTMLElement).style.opacity =
            `${Math.max(1 - (scrollY / heroH) * 1.3, 0)}`;
        }
        ticking = false;
      }
      window.addEventListener(
        'scroll',
        () => {
          if (!ticking) {
            requestAnimationFrame(updateParallax);
            ticking = true;
          }
        },
        { passive: true },
      );
      updateParallax();
    }
  </script>
</section>
