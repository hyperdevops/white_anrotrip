---
// src/components/Hero.astro
import { Image } from 'astro:assets';
import heroBg from '../assets/hero/plane.avif';
---

<section
  id="hero"
  class="sticky top-0 z-0 min-h-dvh w-full flex items-center justify-center overflow-hidden"
>
  <div class="absolute inset-0">
    <Image
      src={heroBg}
      alt="Вид из самолета"
      class="h-full w-full object-cover scale-105"
      style="animation: kenburns 30s cubic-bezier(0.4, 0, 0.6, 1) infinite alternate;"
      quality={80}
      loading="eager"
    />
    <!-- Градиент затемнения (динамический, зависит от времени суток) -->
    <div
      id="hero-gradient"
      class="absolute inset-0 bg-linear-to-b transition-colors duration-[3s] ease-in-out"
    >
    </div>
  </div>

  <div
    id="hero-content"
    class="relative z-10 container mx-auto px-4 text-center text-white mt-16"
    style="will-change: transform, opacity;"
  >
    <h1
      class="mx-auto max-w-5xl font-montserrat text-4xl font-extrabold uppercase leading-tight tracking-tight drop-shadow-xl sm:text-6xl md:text-7xl lg:text-8xl"
    >
      Будь на высоте <br />
      <span
        class="text-transparent bg-clip-text bg-linear-to-r from-white via-blue-100 to-blue-200"
      >
        с ANRO TRIP!
      </span>
    </h1>

    <p
      class="mx-auto mt-6 max-w-2xl text-base font-medium text-white/90 sm:text-xl md:text-2xl drop-shadow-md"
    >
      Путешествия вашей мечты начинаются здесь
    </p>

    <div class="mt-12 flex flex-col items-center justify-center">
      <a
        id="hero-search-btn"
        href="#search"
        class="group relative inline-flex items-center justify-center gap-3 overflow-hidden rounded-full bg-linear-to-r from-cta to-cta-hover px-12 py-6 text-xl font-black text-[#11111b] shadow-[0_0_20px_5px_rgba(255,212,23,0.5)] transition-all duration-300 ease-out hover:shadow-[0_0_30px_5px_rgba(255,212,23,0.7)] hover:-translate-y-1 active:translate-y-0"
      >
        <!-- Shine effect (движущийся блик) -->
        <span
          class="absolute inset-0 w-[200%] bg-linear-to-r from-transparent via-white/30 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000 ease-out"
        ></span>

        <!-- Контент кнопки -->
        <span class="font-extrabold">ПОИСК ТУРОВ</span>

        <!-- Современная стрелка с анимацией -->
        <span class="relative z-10 flex items-center justify-center w-7 h-7">
          <svg
            class="absolute transition-all duration-300 ease-out group-hover:translate-x-1 group-hover:opacity-0"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
          <svg
            class="absolute transition-all duration-300 ease-out -translate-x-1 opacity-0 group-hover:translate-x-0 group-hover:opacity-100"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </span>
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce z-20">
    <button
      id="scroll-arrow"
      aria-label="Скролл вниз"
      class="text-white/80 hover:text-white transition-colors cursor-pointer"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-10 w-10 drop-shadow-md"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7"></path>
      </svg>
    </button>
  </div>
</section>

<style>
  /* Ken Burns улучшение: добавлены translate для более живого эффекта */
  @keyframes kenburns {
    0% {
      transform: scale(1) translate(0, 0);
    }
    50% {
      transform: scale(1.08) translate(1%, -1%);
    }
    100% {
      transform: scale(1.15) translate(-1%, 1%);
    }
  }
</style>

<script>
  // Скрипт прокрутки
  const searchBtn = document.getElementById('hero-search-btn');
  const arrowBtn = document.getElementById('scroll-arrow');

  if (searchBtn) {
    searchBtn.addEventListener('click', (e) => {
      e.preventDefault();

      // Находим элемент, к которому нужно проскроллить
      const searchAnchor = document.getElementById('search');
      if (searchAnchor) {
        // Прокручиваем к элементу со смещением вверх на 100px
        const rect = searchAnchor.getBoundingClientRect();
        const scrollTop =
          window.pageYOffset || document.documentElement.scrollTop;
        const targetPosition = rect.top + scrollTop - 104; // поднимаем на 100px выше

        // Плавная прокрутка к позиции
        window.scrollTo({
          top: targetPosition,
          behavior: 'smooth',
        });
      }
    });
  }

  if (arrowBtn) {
    arrowBtn.addEventListener('click', (e) => {
      e.preventDefault();
      document
        .getElementById('popular-tours')
        ?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }

  // DYNAMIC GRADIENT на основе времени суток
  const heroGradient = document.getElementById('hero-gradient');
  const hour = new Date().getHours();

  if (heroGradient) {
    // Утро (6:00 - 11:59): теплый оранжевый восход
    if (hour >= 6 && hour < 12) {
      heroGradient.classList.add(
        'from-orange-400/30',
        'via-yellow-200/10',
        'to-blue-900/50',
      );
    }
    // День (12:00 - 17:59): светло-синий
    else if (hour >= 12 && hour < 18) {
      heroGradient.classList.add(
        'from-blue-400/30',
        'via-blue-200/10',
        'to-blue-900/40',
      );
    }
    // Вечер (18:00 - 21:59): фиолетово-розовый закат
    else if (hour >= 18 && hour < 22) {
      heroGradient.classList.add(
        'from-purple-600/40',
        'via-pink-400/15',
        'to-black/70',
      );
    }
    // Ночь (22:00 - 5:59): темно-синий (дефолт)
    else {
      heroGradient.classList.add(
        'from-indigo-900/50',
        'via-black/20',
        'to-black/80',
      );
    }
  }

  // PARALLAX ЭФФЕКТ
  const heroContent = document.getElementById('hero-content');
  const hero = document.getElementById('hero');

  let ticking = false;

  function updateParallax() {
    const scrollY = window.scrollY;
    const heroHeight = hero?.offsetHeight || 0;

    // Применяем parallax только к контенту (фон оставляем неподвижным)
    if (scrollY < heroHeight && heroContent) {
      // Контент движется вверх медленнее + fade out
      heroContent.style.transform = `translateY(${scrollY * -0.2}px)`;
      heroContent.style.opacity = `${Math.max(1 - (scrollY / heroHeight) * 1.5, 0)}`;
    }

    ticking = false;
  }

  window.addEventListener(
    'scroll',
    () => {
      if (!ticking) {
        requestAnimationFrame(updateParallax);
        ticking = true;
      }
    },
    { passive: true },
  );

  // Инициализация
  updateParallax();
</script>
