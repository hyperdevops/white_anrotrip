---
// src/components/Hero.astro
import { getImage, Image } from 'astro:assets';
import heroBg from '../assets/hero/plane.avif';

// Tiny placeholder (20px) — как Tilda: размытый превью до загрузки полного изображения
const tinyHero = await getImage({ src: heroBg, width: 20, quality: 20 });
---

<section
  id="hero"
  class="sticky top-0 z-0 min-h-dvh w-full flex items-center justify-center overflow-hidden"
>
  <!-- Фоновое изображение: tiny blur placeholder (как Tilda) + fade-in при загрузке -->
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style={`background-image: url('${tinyHero.src}'); background-color: #0c4a6e`}
  >
    <Image
      src={heroBg}
      alt="Вид из самолёта над облаками"
      class="hero-bg-image h-full w-full object-cover scale-100 md:scale-105 hero-kenburns opacity-0 transition-opacity duration-500 ease-out"
      quality={90}
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <!-- Динамический градиент (время суток) -->
    <div
      id="hero-gradient"
      class="absolute inset-0 bg-linear-to-b transition-colors duration-[3s] ease-in-out"
    >
    </div>
    <!-- Постоянный нижний затемняющий слой -->
    <div
      class="absolute inset-0 bg-linear-to-t from-black/60 via-black/10 to-transparent pointer-events-none"
    >
    </div>
  </div>

  <!-- Контент: 3 группы вместо 5 — меньше одновременных анимаций -->
  <div
    id="hero-content"
    class="relative z-10 container mx-auto px-6 text-white mt-8"
  >
    <!-- Группа 1: бейдж + заголовок -->
    <div class="">
      <div class="flex justify-center mb-8">
        <div
          class="reveal-hidden inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/12 border border-white/20 text-white/90 text-xs font-semibold uppercase tracking-widest"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-cta md:animate-pulse"></span>
          Туры · Авиабилеты · Визы · Трансфер
        </div>
      </div>
      <h1
        class="mx-auto max-w-5xl font-montserrat font-extrabold uppercase text-center leading-[0.9] tracking-tight drop-shadow-2xl"
        style="font-size: clamp(2.25rem, 1.75rem + 5vw, 8rem);"
      >
        Будь
        <br />
        на&nbsp;высоте
        <br />
        <span class="hero-gradient-text">с&nbsp;ANRO TRIP!</span>
      </h1>
    </div>

    <!-- Группа 2: подзаголовок + CTA -->
    <div class="reveal-hidden delay-150">
      <p
        class="mx-auto mt-6 max-w-[95vw] sm:max-w-xl text-center text-white/80 leading-relaxed drop-shadow-md"
        style="font-size: clamp(1rem, 0.8rem + 1vw, 1.35rem);"
      >
        Путешествия вашей мечты — от&nbsp;авиабилетов до<br
          class="hidden sm:block"
        /> полного корпоративного обслуживания
      </p>
      <div
        class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4"
      >
        <a
          id="hero-search-btn"
          href="#search"
          class="group relative inline-flex items-center justify-center gap-3 overflow-hidden rounded-full bg-linear-to-r from-cta to-cta-hover px-10 py-5 font-black text-[#11111b] shadow-[0_0_24px_6px_rgba(255,212,23,0.45)] hover:shadow-[0_0_36px_8px_rgba(255,212,23,0.65)] hover:-translate-y-1 active:scale-[0.98] active:translate-y-0.5 transition-[transform,box-shadow] duration-normal btn-ripple cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
          style="font-size: clamp(0.9rem, 0.75rem + 0.8vw, 1.1rem);"
        >
          <!-- Shine sweep -->
          <span
            class="absolute inset-0 w-[200%] bg-linear-to-r from-transparent via-white/35 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-slow ease-out pointer-events-none"
          ></span>
          <svg
            class="w-5 h-5 shrink-0 relative z-10"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            viewBox="0 0 24 24"
          >
            <circle cx="11" cy="11" r="8"></circle><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21 21l-4.35-4.35"></path>
          </svg>
          <span class="relative z-10 uppercase tracking-wider">Поиск туров</span
          >
        </a>

        <a
          href="tel:88002224473"
          class="inline-flex items-center gap-2 px-7 py-5 rounded-full border border-white/25 text-white font-semibold hover:bg-white/10 hover:-translate-y-0.5 active:scale-[0.98] active:translate-y-0.5 transition-[transform,background-color] duration-normal cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-transparent"
          style="font-size: clamp(0.85rem, 0.75rem + 0.5vw, 1rem);"
        >
          <svg
            class="w-4 h-4 text-cta"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
          </svg>
          8 (800) 222-44-73
        </a>
      </div>
    </div>

    <!-- Быстрые стат-пилюли -->
    <div
      class="reveal-hidden mt-12 flex flex-wrap items-center justify-center gap-3"
    >
      {
        [
          ['18', 'лет опыта'],
          ['14 000+', 'клиентов'],
          ['ТОП-10', 'России'],
          ['24/7', 'поддержка'],
        ].map(([val, label]) => (
          <div class="flex items-center gap-2 px-4 py-2.5 rounded-full bg-white/10 border border-white/15">
            <span class="font-montserrat font-black text-cta text-sm">
              {val}
            </span>
            <span class="text-white/60 text-xs">{label}</span>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Скролл-стрелка — внизу Hero -->
  <div
    class="reveal-hidden absolute bottom-6 left-1/2 -translate-x-1/2 z-20 delay-200 animate-hero-scroll"
  >
    <button
      id="scroll-arrow"
      aria-label="Скролл вниз"
      class="text-white/80 hover:text-white transition-colors cursor-pointer"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-10 w-10 drop-shadow-md"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7"></path>
      </svg>
    </button>
  </div>
</section>

<script>
  const searchBtn = document.getElementById('hero-search-btn');
  const arrowBtn = document.getElementById('scroll-arrow');
  const heroContent = document.getElementById('hero-content');
  const hero = document.getElementById('hero');

  // Hero content — плавно уплывает вверх и исчезает при прокрутке (только десктоп — на мобайле jank)
  const isDesktop = window.matchMedia(
    '(hover: hover) and (min-width: 768px)',
  ).matches;
  if (heroContent && hero && isDesktop) {
    const heroH = (hero as HTMLElement).offsetHeight;

    function update() {
      const scrollY = window.scrollY;
      const progress = Math.min(1, scrollY / (heroH * 0.96)); // исчезает за 35% высоты Hero
      const moveUp = progress * 120;
      (heroContent as HTMLElement).style.transform = `translateY(${-moveUp}px)`;
      (heroContent as HTMLElement).style.opacity = `${1 - progress}`;
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  }

  // Scroll to search: mobile — headerHeight - 6 (как в меню, SEARCH_GAP = -6); desktop — 104
  searchBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    const anchor = document.getElementById('search');
    if (!anchor) return;
    const headerEl = document.getElementById('site-header');
    const headerHeight = headerEl ? headerEl.offsetHeight : 64;
    const isMobile = window.matchMedia('(max-width: 767px)').matches;
    const offset = isMobile ? headerHeight - 16 : 78;
    const top = anchor.getBoundingClientRect().top + window.scrollY - offset;
    window.scrollTo({ top, behavior: 'smooth' });
  });

  arrowBtn?.addEventListener('click', () => {
    document
      .getElementById('popular-tours')
      ?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  // Blur-up: показать изображение при загрузке
  const heroImg = hero?.querySelector(
    '.hero-bg-image',
  ) as HTMLImageElement | null;
  if (heroImg) {
    const show = () => heroImg.classList.add('!opacity-100');
    if (heroImg.complete) show();
    else heroImg.addEventListener('load', show);
  }

  // Динамический градиент по времени суток
  const heroGradient = document.getElementById('hero-gradient');
  const h = new Date().getHours();
  if (heroGradient) {
    if (h >= 6 && h < 12)
      heroGradient.classList.add(
        'from-orange-400/25',
        'via-yellow-200/8',
        'to-blue-900/40',
      );
    else if (h >= 12 && h < 18)
      heroGradient.classList.add(
        'from-blue-400/20',
        'via-sky-200/8',
        'to-blue-900/35',
      );
    else if (h >= 18 && h < 22)
      heroGradient.classList.add(
        'from-purple-700/40',
        'via-pink-400/12',
        'to-black/65',
      );
    else
      heroGradient.classList.add(
        'from-indigo-900/45',
        'via-black/15',
        'to-black/75',
      );
  }
</script>
