---
import { Image } from 'astro:assets';
import chelbasketImg from '../assets/partners/chelbasket.webp';
import ferrosplavImg from '../assets/partners/ferrosplav.webp';
import inrostImg from '../assets/partners/inrost.webp';
import mercedesImg from '../assets/partners/mercedes.webp';
import napoleonImg from '../assets/partners/napoleon.webp';
import niagaraImg from '../assets/partners/niagara.webp';
import niksImg from '../assets/partners/niks.webp';
import r1projectImg from '../assets/partners/r1project.webp';
import redpepperImg from '../assets/partners/redpepper.webp';
import unisteamImg from '../assets/partners/unisteam.webp';

const partners = [
  { name: 'Napoleon IT', logo: napoleonImg },
  { name: 'R1 Проектное бюро', logo: r1projectImg },
  { name: 'Ниагара', logo: niagaraImg },
  { name: 'НИКС', logo: niksImg },
  { name: 'Mercedes Benz', logo: mercedesImg },
  { name: 'Ферросплав', logo: ferrosplavImg },
  { name: 'Unisteam', logo: unisteamImg },
  { name: 'Red Pepper Film', logo: redpepperImg },
  { name: 'Инрост', logo: inrostImg },
  { name: 'Челбаскет', logo: chelbasketImg },
];

// Дублируем для бесшовного marquee
const row1 = [...partners, ...partners];
const row2 = [...partners].reverse();
const row2doubled = [...row2, ...row2];

const stats = [
  { value: '700+', label: 'компаний-партнёров', icon: 'building' },
  { value: '18', label: 'лет на рынке', icon: 'calendar' },
  { value: '14 000+', label: 'довольных клиентов', icon: 'users' },
  { value: '10', label: 'отраслей бизнеса', icon: 'layers' },
];

interface Props {
  class?: string;
}
const { class: classes = '' }: Props = Astro.props;
---

<section id="partners" class={`relative py-16 md:py-24 overflow-hidden ${classes}`}>

  <!-- Фоновый градиент -->
  <div class="absolute inset-0 bg-linear-to-br from-slate-50 via-white to-blue-50/40 pointer-events-none"></div>
  <!-- Декоративные орбы -->
  <div class="absolute -top-32 -left-32 w-80 h-80 bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-32 -right-32 w-96 h-96 bg-secondary/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative container mx-auto px-4 sm:px-6 max-w-7xl">

    <!-- ===== ЗАГОЛОВОК ===== -->
    <div class="text-center mb-12 md:mb-16 reveal-hidden">
      <!-- Бейдж -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/8 border border-primary/15 mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
        <span class="text-xs font-semibold text-primary uppercase tracking-widest font-montserrat">Доверие бизнеса</span>
      </div>

      <!-- Заголовок с градиентом и анимацией (partners-title в global.css) -->
      <h2 class="partners-title font-montserrat font-extrabold uppercase tracking-wider text-gray-900 mb-4 relative inline-block">
        Нам доверяют
      </h2>

      <p class="text-gray-500 text-base md:text-lg max-w-xl mx-auto leading-relaxed">
        Крупнейшие компании Урала выбирают ANRO TRIP для корпоративных поездок и деловых путешествий
      </p>
    </div>

    <!-- ===== СТАТЫ ===== -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-14 md:mb-18" data-reveal-stagger>
      {stats.map((stat) => (
        <div class="reveal-hidden glass-panel-interactive rounded-2xl p-5 sm:p-6 flex flex-col items-center text-center group">
          <!-- Иконка -->
          <div class="w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center mb-3 group-hover:bg-primary/20 transition-colors duration-300">
            {stat.icon === 'building' && (
              <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z"/>
              </svg>
            )}
            {stat.icon === 'calendar' && (
              <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/>
              </svg>
            )}
            {stat.icon === 'users' && (
              <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
              </svg>
            )}
            {stat.icon === 'layers' && (
              <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M11.99 18.54l-7.37-5.73L3 14.07l9 7 9-7-1.63-1.27-7.38 5.74zM12 16l7.36-5.73L21 9l-9-7-9 7 1.63 1.27L12 16z"/>
              </svg>
            )}
          </div>
          <!-- Значение -->
          <div class="font-montserrat font-extrabold text-2xl sm:text-3xl text-gray-900 leading-none mb-1 partners-counter" data-target={stat.value}>
            {stat.value}
          </div>
          <div class="text-xs sm:text-sm text-gray-500 font-medium leading-tight">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- ===== ЛЕНТА ЛОГОТИПОВ ===== -->
    <!-- Мобилка: один ряд, прокрутка пальцем, fade-маски как в Отзывах -->
    <div class="reveal-hidden relative md:hidden">
      <div class="absolute left-0 top-0 bottom-0 w-16 bg-linear-to-r from-slate-50 to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-16 bg-linear-to-l from-blue-50/60 to-transparent z-10 pointer-events-none"></div>
      <div
        class="flex overflow-x-auto gap-4 pb-4 snap-x snap-mandatory scrollbar-hide -mx-4 px-4"
        style="-webkit-overflow-scrolling: touch;"
      >
        {partners.map((partner) => (
          <div class="snap-start shrink-0 w-40 min-h-[7.5rem] rounded-2xl bg-white border border-gray-100 flex items-center justify-center px-5 py-4 group hover:border-primary/25 hover:shadow-md transition-all duration-300">
            <Image
              src={partner.logo}
              alt={partner.name}
              class="max-h-full w-auto max-w-full object-contain opacity-100 group-hover:opacity-100 transition-opacity duration-300"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>

    <!-- Десктоп: marquee, без изменений -->
    <div class="reveal-hidden relative hidden md:block">
      <div class="absolute left-0 top-0 bottom-0 w-16 sm:w-24 md:w-32 bg-linear-to-r from-white to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-16 sm:w-24 md:w-32 bg-linear-to-l from-white to-transparent z-10 pointer-events-none"></div>
      <div class="overflow-hidden mb-4">
        <div class="partners-track partners-track--forward flex gap-4 w-max" aria-hidden="true">
          {row1.map((partner) => (
            <div class="partners-logo-card shrink-0 w-40 h-22 sm:w-44 sm:h-24 md:h-36 rounded-2xl bg-white border border-gray-100 flex items-center justify-center px-5 py-3 group hover:border-primary/25 hover:shadow-md transition-all duration-300">
              <Image
                src={partner.logo}
                alt={partner.name}
                class="max-h-full w-auto object-contain opacity-100 group-hover:opacity-100 transition-opacity duration-300 group-hover:grayscale-0"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
      <div class="overflow-hidden">
        <div class="partners-track partners-track--reverse flex gap-4 w-max" aria-hidden="true">
          {row2doubled.map((partner) => (
            <div class="partners-logo-card shrink-0 w-40 h-22 sm:w-44 sm:h-24 md:h-36 rounded-2xl bg-white border border-gray-100 flex items-center justify-center px-5 py-3 group hover:border-primary/25 hover:shadow-md transition-all duration-300">
              <Image
                src={partner.logo}
                alt={partner.name}
                class="max-h-full w-auto object-contain opacity-100 group-hover:opacity-100 transition-opacity duration-300 group-hover:grayscale-0"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ===== CTA ===== -->
    <div class="text-center mt-12 reveal-hidden">
      <p class="text-sm text-gray-400 mb-4 uppercase tracking-widest font-medium font-montserrat">Ваша компания могла быть здесь</p>
      <a
        href="#contacts"
        class="inline-flex items-center gap-2.5 px-7 py-3.5 rounded-full bg-primary text-white font-semibold font-montserrat text-sm hover:bg-primary-dark transition-all duration-300 btn-magnetic btn-ripple shadow-[0_4px_20px_rgba(0,171,179,0.35)] hover:shadow-[0_6px_28px_rgba(0,171,179,0.5)] focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
      >
        Стать партнёром
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<script>
  function initPartnersCyclicScroll() {
    const el = document.getElementById('partners-cyclic-scroll');
    if (!el || window.innerWidth >= 768) return;
    let ticking = false;
    const loop = () => {
      const maxScroll = el.scrollWidth - el.clientWidth;
      if (maxScroll <= 0) return;
      const left = el.scrollLeft;
      if (left <= 20) el.scrollLeft = maxScroll;
      else if (left >= maxScroll - 20) el.scrollLeft = 0;
      ticking = false;
    };
    el.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(loop);
    });
  }
  initPartnersCyclicScroll();
  document.addEventListener('astro:page-load', initPartnersCyclicScroll);
</script>

