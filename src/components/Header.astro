---
const navItems = [
  { name: 'О нас',    href: '#about' },
  { name: 'Туры',     href: '#search' },
  { name: 'Отзывы',  href: '#reviews' },
  { name: 'Команда', href: '#team' },
  { name: 'Контакты',href: '#contacts' },
];
---

<header id="site-header" class="fixed top-3 left-0 right-0 z-50 px-4 sm:px-6 md:top-4 transition-all duration-500">
  <div class="mx-auto max-w-7xl">
    <div id="header-inner" class="relative flex items-center justify-between rounded-2xl glass-panel px-4 py-3 transition-all duration-500">

      <!-- Логотип -->
      <a href="#" id="logo-btn" class="flex items-center gap-2.5 group z-50 cursor-pointer select-none shrink-0">
        <svg width="36" height="36" viewBox="0 0 1080 1080"
          class="h-9 w-auto text-primary transition-transform duration-300 group-hover:scale-105 drop-shadow-sm"
          fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="m515.63 1067.3-3.8724-0.3995 0.50515-4.4818c0.27784-2.4649 0.67043-4.6255 0.87243-4.8013 0.202-0.1757 11.392-0.041 24.867 0.2994l24.5 0.619 0.60958 9.5-21.805-0.1681c-11.993-0.092-23.547-0.3479-25.677-0.5677zm96.917-6.8126c-0.38228-2.5492-0.49006-4.8399-0.23951-5.0904 0.25054-0.2506 7.5968-1.541 16.325-2.8676 8.7282-1.3266 19.161-3.1054 23.185-3.9528 10.097-2.1267 9.1225-2.592 10.663 5.0907l0.62808 3.1315-11.303 2.0906c-11.9 2.2011-26.165 4.5583-33.933 5.6076l-4.63 0.6253zm-164.55-2.0309c-14.084-2.9146-33.101-7.4786-34.62-8.3086-0.81278-0.4442-0.74472-1.8848 0.24808-5.2517l1.3681-4.6396 13.094 3.3021c7.202 1.8161 17.514 4.0784 22.916 5.0272s10.368 2.0634 11.038 2.4769c1.5816 0.9775 0.34118 10.016-1.355 9.8733-0.6538-0.055-6.3637-1.1707-12.689-2.4796zm262.93-18.101c-2.3636-6.2168-2.433-6.1522 12.068-11.224 7.425-2.5967 17.534-6.3806 22.465-8.4087s9.2499-3.6875 9.5981-3.6875c1.2553 0 4.2742 8.0628 3.3536 8.9568-1.8802 1.8263-42.443 17.043-45.431 17.043-0.56951 0-1.494-1.206-2.0544-2.68zm-360.43-11.378c-10.107-4.2006-30.961-13.636-32.439-14.677-0.24123-0.1699 0.53696-2.317 1.7293-4.7712l2.1679-4.4623 7.7707 3.5938c8.7293 4.0371 27.78 12.276 33.593 14.529 2.1024 0.8147 3.7743 1.9007 3.7152 2.4133-0.36379 3.1582-2.526 8.4264-3.4461 8.3965-0.60044-0.02-6.4917-2.2797-13.092-5.0227z"></path>
        </svg>
        <div class="flex flex-col leading-none">
          <span class="text-base font-extrabold tracking-tight text-primary font-montserrat whitespace-nowrap">ANRO TRIP</span>
          <span class="text-[9px] text-gray-400 uppercase tracking-widest hidden sm:block">Travel &amp; Business</span>
        </div>
      </a>

      <!-- Навигация (desktop) -->
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="relative px-3 py-2 text-[11px] font-bold text-gray-600 hover:text-primary uppercase tracking-[0.12em] transition-colors duration-200 rounded-lg hover:bg-primary/5 group"
          >
            {item.name}
            <span class="absolute bottom-1 left-3 right-3 h-px bg-primary scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></span>
          </a>
        ))}
      </nav>

      <!-- Правая часть -->
      <div class="flex items-center gap-2 z-50">
        <!-- Телефон (desktop) -->
        <a href="tel:88002224473" class="hidden xl:flex items-center gap-1.5 px-3 py-2 rounded-xl text-xs font-bold text-gray-700 hover:text-primary hover:bg-primary/5 transition-all duration-200">
          <svg class="w-3.5 h-3.5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          8 (800) 222-44-73
        </a>

        <a href="#contacts" class="hidden lg:inline-flex items-center gap-2 rounded-full bg-primary px-5 py-2.5 text-xs font-bold text-white hover:bg-primary-dark hover:shadow-lg hover:shadow-primary/30 active:scale-95 transition-all duration-300 uppercase tracking-wider shadow-md btn-magnetic">
          Связаться
        </a>

        <!-- Бургер (mobile) -->
        <button id="menu-toggle" class="lg:hidden flex flex-col gap-[5px] p-2 group focus:outline-none" aria-label="Меню" aria-expanded="false">
          <span class="h-0.5 w-5 bg-gray-700 rounded-full transition-all duration-300 origin-center"></span>
          <span class="h-0.5 w-5 bg-gray-700 rounded-full transition-all duration-300"></span>
          <span class="h-0.5 w-3.5 bg-gray-700 rounded-full transition-all duration-300 origin-center self-end"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu"
    class="fixed top-20 right-4 w-56 bg-white/95 backdrop-blur-xl rounded-2xl border border-gray-100 shadow-2xl shadow-black/15 lg:hidden z-40 transition-all duration-400 ease-out opacity-0 -translate-y-3 pointer-events-none"
  >
    <nav class="flex flex-col p-2">
      {navItems.map((item) => (
        <a href={item.href}
          class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-semibold text-gray-700 hover:bg-primary/8 hover:text-primary transition-all duration-200"
        >
          {item.name}
        </a>
      ))}
      <div class="my-1.5 h-px bg-gray-100 mx-2"></div>
      <a href="tel:88002224473" class="flex items-center gap-2 rounded-xl px-4 py-3 text-sm font-semibold text-gray-700 hover:bg-primary/8 hover:text-primary transition-all duration-200">
        <svg class="w-4 h-4 text-primary shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        8 (800) 222-44-73
      </a>
      <a href="#contacts" class="mx-2 mb-1 mt-0.5 rounded-xl bg-primary px-4 py-3 text-center text-sm font-bold text-white hover:bg-primary-dark transition-colors">
        Связаться
      </a>
    </nav>
  </div>
</header>

<script>
  const toggleBtn = document.getElementById('menu-toggle') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLElement;
  const logoBtn = document.getElementById('logo-btn') as HTMLAnchorElement;
  const headerInner = document.getElementById('header-inner') as HTMLElement;
  let menuOpen = false;

  // Scroll shrink effect
  const onScroll = () => {
    if (window.scrollY > 60) {
      headerInner?.classList.add('py-2');
      headerInner?.classList.remove('py-3');
    } else {
      headerInner?.classList.remove('py-2');
      headerInner?.classList.add('py-3');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });

  // Логотип — скролл наверх
  logoBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    document.body.style.transition = 'opacity 0.5s ease';
    document.body.style.opacity = '0';
    setTimeout(() => {
      window.scrollTo({ top: 0, behavior: 'instant' });
      document.querySelectorAll('.reveal-visible').forEach(el => el.classList.remove('reveal-visible'));
      if ((window as any).initScrollReveal) (window as any).initScrollReveal();
      setTimeout(() => {
        document.body.style.opacity = '1';
        setTimeout(() => { document.body.style.transition = ''; document.body.style.opacity = ''; }, 500);
      }, 80);
    }, 500);
  });

  const openMenu = () => {
    menuOpen = true;
    menu.classList.remove('opacity-0', '-translate-y-3', 'pointer-events-none');
    menu.classList.add('opacity-100', 'translate-y-0');
    toggleBtn.setAttribute('aria-expanded', 'true');
    // Animate bars to X
    const bars = toggleBtn.querySelectorAll('span');
    bars[0]?.classList.add('rotate-45', 'translate-y-[7px]');
    bars[1]?.classList.add('opacity-0', 'scale-x-0');
    bars[2]?.classList.add('-rotate-45', '-translate-y-[7px]', 'w-5', 'self-auto');
  };

  const closeMenu = () => {
    menuOpen = false;
    menu.classList.add('opacity-0', '-translate-y-3', 'pointer-events-none');
    menu.classList.remove('opacity-100', 'translate-y-0');
    toggleBtn.setAttribute('aria-expanded', 'false');
    const bars = toggleBtn.querySelectorAll('span');
    bars[0]?.classList.remove('rotate-45', 'translate-y-[7px]');
    bars[1]?.classList.remove('opacity-0', 'scale-x-0');
    bars[2]?.classList.remove('-rotate-45', '-translate-y-[7px]', 'w-5', 'self-auto');
  };

  toggleBtn?.addEventListener('click', (e) => { e.stopPropagation(); menuOpen ? closeMenu() : openMenu(); });
  document.addEventListener('click', (e) => {
    if (menuOpen && menu && !menu.contains(e.target as Node) && !toggleBtn?.contains(e.target as Node)) closeMenu();
  });
  menu?.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));
</script>
