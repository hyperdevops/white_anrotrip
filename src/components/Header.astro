---
import { Image } from 'astro:assets';
import favicon from '../assets/favicon.png';

export interface Props {
  navItems?: { name: string; href: string }[];
  ctaText?: string;
  ctaHref?: string;
  /** default: нав по центру хедера (сетка 1fr auto 1fr). corp: нав по центру между логотипом и телефоном (равные отступы). */
  navVariant?: 'default' | 'corp';
}

const base = import.meta.env.BASE_URL;
const baseTrimmed = base.replace(/\/$/, '');
const isHome =
  Astro.url.pathname === '/' ||
  Astro.url.pathname === '' ||
  Astro.url.pathname === baseTrimmed ||
  Astro.url.pathname === baseTrimmed + '/';
const defaultNavItems = [
  { name: 'О нас', href: '#about' },
  { name: 'Туры', href: '#search' },
  { name: 'Отзывы', href: '#reviews' },
  { name: 'Вопросы', href: '#faq' },
  { name: 'Команда', href: '#team' },
  { name: 'Контакты', href: '#contacts' },
];

const {
  navItems = defaultNavItems,
  ctaText = 'Личный кабинет',
  ctaHref = `${base}cabinet`,
  navVariant = 'default',
} = Astro.props;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-[transform,opacity] duration-normal"
>
  <div class="mx-auto max-w-7xl px-3 sm:px-4 pt-3 md:pt-4">
    <div
      id="header-inner"
      class:list={[
        'relative grid items-center gap-4 lg:gap-6 rounded-2xl glass-panel max-md:backdrop-blur-none md:backdrop-blur-xl px-4 py-3 transition-[background-color,border-color,box-shadow] duration-normal',
        navVariant === 'corp'
          ? 'grid-cols-[auto_minmax(0,1fr)_auto]'
          : 'grid-cols-[1fr_auto_1fr]',
      ]}
    >
      <!-- Логотип: на главной — scroll to top; на corp/cabinet — href="/" data-astro-reload (полная перезагрузка для Tourvisor) -->
      <a
        href={isHome ? '#' : base}
        id="logo-btn"
        class="flex items-center gap-3 group z-50 cursor-pointer select-none"
        {...isHome ? {} : { 'data-astro-reload': true }}
      >
        <!-- Иконка: Image с densities для чёткости на Retina и при зуме -->
        <Image
          src={favicon}
          alt=""
          width={40}
          height={40}
          format="png"
          densities={[2, 3, 4]}
          quality="max"
          decoding="async"
          class="h-10 w-10 shrink-0 object-contain drop-shadow-sm"
        />

        <!-- Текст рядом -->
        <div
          class="header-logo-text flex flex-col leading-none group-hover:scale-105 origin-left"
        >
          <div class="flex items-baseline gap-0.5">
            <span
              class="text-[15px] font-black tracking-tight text-black font-montserrat"
              >ANRO</span
            >
            <span
              class="text-[15px] font-semibold italic font-montserrat text-primary"
              >trip</span
            >
          </div>
          <span
            class="text-[9px] sm:text-[8px] text-gray-400 uppercase tracking-widest hidden sm:block"
            >Travel &amp; Business</span
          >
        </div>
      </a>

      <!-- Навигация (desktop): default — по центру хедера (1fr auto 1fr); corp — по центру между логотипом и телефоном (равные отступы) -->
      <nav
        class="hidden lg:flex items-center justify-center min-w-0 gap-x-2 gap-y-1"
      >
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="relative px-3 py-2 text-[11px] font-bold text-gray-600 hover:text-primary uppercase tracking-[0.12em] transition-colors duration-fast rounded-lg hover:bg-primary/5 group cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
            >
              {item.name}
              <span class="absolute bottom-1 left-3 right-3 h-px bg-primary scale-x-0 group-hover:scale-x-100 transition-transform duration-normal origin-left" />
            </a>
          ))
        }
      </nav>

      <!-- Правая часть: всегда в 3-й колонке (col-start-3), чтобы на mobile при скрытой нав бургер оставался справа -->
      <div
        class="col-start-3 flex items-center justify-end gap-2 z-50 justify-self-end shrink-0"
      >
        <!-- Телефон (desktop): whitespace-nowrap — номер в одну строку -->
        <a
          href="tel:88002224473"
          class="hidden xl:flex items-center gap-1.5 px-3 py-2 rounded-xl text-xs font-bold text-gray-700 hover:text-primary hover:bg-primary/5 transition-[color,background-color] duration-fast whitespace-nowrap cursor-pointer"
        >
          <svg
            class="w-3.5 h-3.5 text-primary"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
          </svg>
          8 (800) 222-44-73
        </a>

        <a
          href={ctaHref}
          class="header-cta-btn btn-ripple hidden lg:inline-flex items-center gap-2 rounded-full bg-primary px-5 py-2.5 text-xs font-bold text-white hover:bg-primary-dark hover:shadow-lg hover:shadow-primary/30 uppercase tracking-wider shadow-md cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 whitespace-nowrap"
          {...ctaHref.startsWith('/')
            ? { 'data-astro-transition-prefetch': '' }
            : {}}
        >
          {ctaText}
        </a>

        <!-- Бургер (mobile) -->
        <button
          id="menu-toggle"
          class="lg:hidden flex flex-col gap-1.25 p-2 group cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded-lg"
          aria-label="Меню"
          aria-expanded="false"
        >
          <span
            class="h-0.5 w-5 bg-gray-700 rounded-full transition-[transform,opacity] duration-fast origin-center"
          ></span>
          <span
            class="h-0.5 w-5 bg-gray-700 rounded-full transition-[transform,opacity] duration-fast"
          ></span>
          <span
            class="h-0.5 w-3.5 bg-gray-700 rounded-full transition-[transform,opacity] duration-fast origin-center self-end"
          ></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu: solid bg, transition 250ms (чуть дольше = плавнее) -->
  <div
    id="mobile-menu"
    class="fixed top-20 right-4 w-56 bg-white/95 rounded-2xl border border-white/40 shadow-2xl shadow-black/15 lg:hidden z-40 transition-[opacity,transform] duration-250 ease-out opacity-0 -translate-y-3 pointer-events-none"
  >
    <nav class="flex flex-col p-2" aria-label="Меню">
      <ul class="flex flex-col gap-0.5">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-semibold text-gray-700 hover:bg-primary/8 hover:text-primary transition-[background-color,color] duration-fast cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
              >
                {item.name === 'О нас' ? (
                  <svg
                    class="w-4 h-4 fill-current text-primary shrink-0"
                    viewBox="0 0 512 512"
                  >
                    <path
                      d="M256 512c141.4 0 256-114.6 256-256S397.4 0 256 0S0 114.6 0 256S114.6 512 256 512zM216 336h24V272H216c-13.3 0-24-10.7-24-24s10.7-24 24-24h48c13.3 0 24 10.7 24 24v88h8c13.3 0 24 10.7 24 24s-10.7 24-24 24H216c-13.3 0-24-10.7-24-24s10.7-24 24-24zm40-144c-17.7 0-32-14.3-32-32s14.3-32 32-32s32 14.3 32 32s-14.3 32-32 32z"
                    />
                  </svg>
                ) : item.name === 'Туры' ? (
                  <svg
                    class="w-4 h-4 fill-current text-primary shrink-0"
                    viewBox="0 0 512 512"
                  >
                    <path
                      d="M416 208c0 45.9-14.9 88.3-40 122.7L502.6 457.4c12.5 12.5 12.5 32.8 0 45.3s-32.8 12.5-45.3 0L330.7 376c-34.4 25.2-76.8 40-122.7 40C93.1 416 0 322.9 0 208S93.1 0 208 0S416 93.1 416 208zM208 352c79.5 0 144-64.5 144-144s-64.5-144-144-144S64 128.5 64 208s64.5 144 144 144z"
                    />
                  </svg>
                ) : item.name === 'Отзывы' ? (
                  <svg
                    class="w-4 h-4 fill-current text-primary shrink-0"
                    viewBox="0 0 512 512"
                  >
                    <path
                      d="M512 240c0 114.9-114.6 208-256 208c-37.1 0-72.3-6.4-104.1-17.9c-11.9 8.7-31.3 20.6-54.3 30.6C73.6 471.1 44.7 480 16 480c-6.5 0-12.3-3.9-14.8-9.9c-2.5-6-1.1-12.8 3.4-17.4l0 0 0 0 0 0 0 0 .3-.3c.3-.3 .7-.7 1.3-1.4c1.1-1.2 2.8-3.1 4.9-5.7c4.1-5 9.6-12.4 15.2-21.6c10-16.6 19.5-38.4 21.4-62.9C17.7 326.8 0 285.1 0 240C0 125.1 114.6 32 256 32s256 93.1 256 208z"
                    />
                  </svg>
                ) : item.name === 'Вопросы' ? (
                  <svg
                    class="w-4 h-4 fill-current text-primary shrink-0"
                    viewBox="0 0 512 512"
                  >
                    <path
                      d="M256 512c141.4 0 256-114.6 256-256S397.4 0 256 0S0 114.6 0 256S114.6 512 256 512zM169.8 165.3c7.9-22.3 29.1-37.3 52.8-37.3h58.3c34.9 0 63.1 28.3 63.1 63.1c0 22.6-12.1 43.5-31.7 54.8L280 264.4c-.2 13-10.9 23.6-24 23.6c-13.3 0-24-10.7-24-24V250.5c0-8.6 4.6-16.5 12.1-20.8l44.3-25.4c4.7-2.7 7.6-7.7 7.6-13.1c0-8.4-6.8-15.1-15.1-15.1H222.6c-3.4 0-6.4 2.1-7.5 5.3l-.4 1.2c-4.4 12.5-18.2 19-30.6 14.6s-19-18.2-14.6-30.6l.4-1.2zM288 352c0 17.7-14.3 32-32 32s-32-14.3-32-32s14.3-32 32-32s32 14.3 32 32z"
                    />
                  </svg>
                ) : item.name === 'Команда' ? (
                  <svg
                    class="w-4 h-4 fill-current text-primary shrink-0"
                    viewBox="0 0 640 512"
                  >
                    <path
                      d="M144 160c-44.2 0-80-35.8-80-80S99.8 0 144 0s80 35.8 80 80s-35.8 80-80 80zm368 0c-44.2 0-80-35.8-80-80s35.8-80 80-80s80 35.8 80 80s-35.8 80-80 80zM0 298.7C0 239.8 47.8 192 106.7 192h42.7c15.9 0 31 3.5 44.6 9.7c-1.3 7.2-1.9 14.7-1.9 22.3c0 38.2 16.8 72.5 43.3 96c-.2 0-.4 0-.7 0H21.3C9.6 320 0 310.4 0 298.7zM405.3 320c-.2 0-.4 0-.7 0c26.6-23.5 43.3-57.8 43.3-96c0-7.6-.7-15-1.9-22.3c13.6-6.3 28.7-9.7 44.6-9.7h42.7C592.2 192 640 239.8 640 298.7c0 11.8-9.6 21.3-21.3 21.3H405.3zM416 224c0 53-43 96-96 96s-96-43-96-96s43-96 96-96s96 43 96 96zM128 485.3C128 411.7 187.7 352 261.3 352H378.7C452.3 352 512 411.7 512 485.3c0 14.7-11.9 26.7-26.7 26.7H154.7c-14.7 0-26.7-11.9-26.7-26.7z"
                    />
                  </svg>
                ) : item.name === 'Контакты' ? (
                  <svg
                    class="w-4 h-4 fill-current text-primary shrink-0"
                    viewBox="0 0 512 512"
                  >
                    <path
                      d="M96 0C60.7 0 32 28.7 32 64V448c0 35.3 28.7 64 64 64H384c35.3 0 64-28.7 64-64V64c0-35.3-28.7-64-64-64H96zM208 288h64c44.2 0 80 35.8 80 80c0 8.8-7.2 16-16 16H144c-8.8 0-16-7.2-16-16c0-44.2 35.8-80 80-80zm96-96c0 35.3-28.7 64-64 64s-64-28.7-64-64s28.7-64 64-64s64 28.7 64 64zM512 80c0-8.8-7.2-16-16-16s-16 7.2-16 16v64c0 8.8 7.2 16 16 16s16-7.2 16-16V80zM496 192c-8.8 0-16 7.2-16 16v64c0 8.8 7.2 16 16 16s16-7.2 16-16V208c0-8.8-7.2-16-16-16zm16 144c0-8.8-7.2-16-16-16s-16 7.2-16 16v64c0 8.8 7.2 16 16 16s16-7.2 16-16V336z"
                    />
                  </svg>
                ) : (
                  <svg
                    class="w-4 h-4 fill-current text-primary shrink-0"
                    viewBox="0 0 512 512"
                    aria-hidden="true"
                  >
                    <path
                      d="M256 8C119 8 8 119 8 256s111 248 248 248s248-111 248-248S393 8 256 8zm0 448c-22.1 0-40-17.9-40-40s17.9-40 40-40s40 17.9 40 40s-17.9 40-40 40zm56-168c0 13.3-10.7 24-24 24h-64c-13.3 0-24-10.7-24-24s10.7-24 24-24h16v-64h-8c-13.3 0-24-10.7-24-24s10.7-24 24-24h32c13.3 0 24 10.7 24 24v88h8c13.3 0 24 10.7 24 24z"
                    />
                  </svg>
                )}
                {item.name}
              </a>
              {item.name === 'Контакты' ? (
                <button
                  id="open-favorites-menu"
                  type="button"
                  class="mt-0.5 w-full flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-semibold text-gray-700 hover:bg-primary/8 hover:text-primary transition-[background-color,color] duration-fast cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
                  aria-label="Открыть избранное (корзину туров)"
                >
                  <svg
                    class="w-4 h-4 fill-current text-primary shrink-0"
                    viewBox="0 0 512 512"
                  >
                    <path
                      d="M47.6 300.4L228.3 469.1c7.5 7 17.4 10.9 27.7 10.9s20.2-3.9 27.7-10.9L464.4 300.4c30.4-28.3 47.6-68 47.6-109.5v-5.8c0-69.9-50.5-129.5-119.4-141C347 36.5 300.6 51.4 268 84L256 96 244 84c-32.6-32.6-79-47.5-124.6-39.9C50.5 55.6 0 115.2 0 185.1v5.8c0 41.5 17.2 81.2 47.6 109.5z"
                    />
                  </svg>
                  Избранное
                </button>
              ) : null}
            </li>
          ))
        }
      </ul>
      <div class="my-1.5 h-px bg-gray-100 mx-2"></div>
      <a
        href="tel:88002224473"
        class="flex items-center gap-2 rounded-xl px-4 py-3 text-sm font-semibold text-gray-700 hover:bg-primary/8 hover:text-primary transition-[background-color,color] duration-fast cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
      >
        <svg class="w-4 h-4 fill-current text-primary shrink-0" viewBox="0 0 512 512">
          <path
            d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"
          />
        </svg>
        8 (800) 222-44-73
      </a>
      <a
        href={ctaHref}
        class="header-cta-btn btn-ripple mx-2 mb-1 mt-0.5 rounded-xl bg-primary px-4 py-3 text-center text-sm font-bold text-white hover:bg-primary-dark cursor-pointer whitespace-nowrap focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
        {...ctaHref.startsWith('/')
          ? { 'data-astro-transition-prefetch': '' }
          : {}}
      >
        {ctaText}
      </a>
    </nav>
  </div>
</header>

<script>
  let toggleBtn = document.getElementById(
    'menu-toggle',
  ) as HTMLButtonElement | null;
  let menu = document.getElementById('mobile-menu') as HTMLElement | null;
  const logoBtn = document.getElementById(
    'logo-btn',
  ) as HTMLAnchorElement | null;
  let headerInner = document.getElementById(
    'header-inner',
  ) as HTMLElement | null;
  let menuOpen = false;
  let toggleClickHandler: ((e: Event) => void) | null = null;

  // Прокрутка к якорям: Desktop — только #search и #content; Mobile — все пункты меню
  const initAnchorScroll = () => {
    const headerEl = document.getElementById('site-header');
    const headerHeight = headerEl ? headerEl.offsetHeight : 64;
    const isMobile = window.matchMedia('(max-width: 767px)').matches;

    // Desktop: как было — только #search и #content
    if (!isMobile) {
      document
        .querySelectorAll<HTMLAnchorElement>('header a[href="#search"]')
        .forEach((link) => {
          link.addEventListener('click', (e) => {
            e.preventDefault();
            const anchor = document.getElementById('search');
            if (anchor) {
              const top =
                anchor.getBoundingClientRect().top + window.scrollY - 78;
              window.scrollTo({ top, behavior: 'smooth' });
            }
          });
        });

      const GAP_PX = 22;
      document
        .querySelectorAll<HTMLAnchorElement>('header a[href="#content"]')
        .forEach((link) => {
          link.addEventListener('click', (e) => {
            e.preventDefault();
            const anchor = document.getElementById('content');
            if (anchor) {
              const offset = headerHeight + GAP_PX;
              const top =
                anchor.getBoundingClientRect().top + window.scrollY - offset;
              window.scrollTo({ top, behavior: 'smooth' });
            }
          });
        });
      return;
    }

    // Mobile: все пункты меню — прокрутка к якорям
    const GAP_PX = -28;
    const SEARCH_GAP = -16; // хедер + минимальный зазор до search widget
    const CORP_CONTENT_GAP = -28;

    const scrollToAnchor = (e: Event, href: string) => {
      const id = href.replace(/^#/, '');
      if (!id) return;
      const anchor = document.getElementById(id);
      if (!anchor) return;
      e.preventDefault();
      let offset: number;
      if (id === 'search') offset = headerHeight + SEARCH_GAP;
      else if (id === 'content') offset = headerHeight + CORP_CONTENT_GAP;
      else offset = headerHeight + GAP_PX;
      const top = anchor.getBoundingClientRect().top + window.scrollY - offset;
      window.scrollTo({ top, behavior: 'smooth' });
      if (menuOpen && menu) closeMenu();
    };

    document
      .querySelectorAll<HTMLAnchorElement>('header a[href^="#"]:not(#logo-btn)')
      .forEach((link) => {
        const href = link.getAttribute('href') || '';
        link.addEventListener('click', (e) => scrollToAnchor(e, href));
      });
  };
  initAnchorScroll();
  document.addEventListener('astro:page-load', initAnchorScroll);

  // При скролле — усиливаем тень, без изменения размеров
  const onScroll = () => {
    if (window.scrollY > 40) {
      headerInner?.classList.add('shadow-xl', 'shadow-black/10');
      headerInner?.classList.remove('shadow-none');
    } else {
      headerInner?.classList.remove('shadow-xl', 'shadow-black/10');
      headerInner?.classList.add('shadow-none');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Логотип — на главной scroll to top; на других страницах — data-astro-reload, нативный переход
  const initLogoClick = () => {
    const logo = document.getElementById('logo-btn');
    if (logo?.hasAttribute('data-astro-reload')) return;
    logo?.addEventListener('click', (e) => {
      e.preventDefault();
      const path = window.location.pathname.replace(/\/$/, '') || '/';
      const basePath = document.body.dataset.base?.replace(/\/$/, '') || '/';
      document.documentElement.style.transition = 'opacity 0.5s ease';
      document.body.style.transition = 'opacity 0.5s ease';
      document.documentElement.style.opacity = '0';
      document.body.style.opacity = '0';
      const isHomePath =
        path === '/' ||
        path === '/index.html' ||
        path === basePath ||
        path === basePath + '/';
      if (!isHomePath) {
        setTimeout(() => {
          window.location.href = document.body.dataset.base || '/';
        }, 500);
      } else {
        setTimeout(() => {
          window.scrollTo({ top: 0, behavior: 'instant' });
          document
            .querySelectorAll('.reveal-visible')
            .forEach((el) => el.classList.remove('reveal-visible'));
          if (window.initScrollReveal) window.initScrollReveal();
          setTimeout(() => {
            document.documentElement.style.opacity = '1';
            document.body.style.opacity = '1';
            setTimeout(() => {
              document.documentElement.style.transition = '';
              document.documentElement.style.opacity = '';
              document.body.style.transition = '';
              document.body.style.opacity = '';
            }, 500);
          }, 80);
        }, 500);
      }
    });
  };
  initLogoClick();
  document.addEventListener('astro:page-load', initLogoClick);

  const openMenu = () => {
    if (!menu || !toggleBtn) return;
    menuOpen = true;
    menu.classList.remove('opacity-0', '-translate-y-3', 'pointer-events-none');
    menu.classList.add('opacity-100', 'translate-y-0');
    toggleBtn.setAttribute('aria-expanded', 'true');
    const bars = toggleBtn.querySelectorAll('span');
    bars[0]?.classList.add('rotate-45', 'translate-y-[7px]');
    bars[1]?.classList.add('opacity-0', 'scale-x-0');
    bars[2]?.classList.add(
      '-rotate-45',
      '-translate-y-[7px]',
      'w-5',
      'self-auto',
    );
  };

  const closeMenu = () => {
    if (!menu || !toggleBtn) return;
    const menuEl = menu;
    menuOpen = false;
    toggleBtn.setAttribute('aria-expanded', 'false');
    menuEl.style.transition = 'none';
    menuEl.classList.add('opacity-0', '-translate-y-3', 'pointer-events-none');
    menuEl.classList.remove('opacity-100', 'translate-y-0');
    requestAnimationFrame(() => {
      menuEl.style.transition = '';
    });
    const bars = toggleBtn.querySelectorAll('span');
    bars.forEach((b) => ((b as HTMLElement).style.transition = 'none'));
    bars[0]?.classList.remove('rotate-45', 'translate-y-[7px]');
    bars[1]?.classList.remove('opacity-0', 'scale-x-0');
    bars[2]?.classList.remove(
      '-rotate-45',
      '-translate-y-[7px]',
      'w-5',
      'self-auto',
    );
    requestAnimationFrame(() => {
      bars.forEach((b) => ((b as HTMLElement).style.transition = ''));
    });
  };

  const initMobileMenu = () => {
    toggleBtn = document.getElementById(
      'menu-toggle',
    ) as HTMLButtonElement | null;
    menu = document.getElementById('mobile-menu') as HTMLElement | null;
    headerInner = document.getElementById('header-inner') as HTMLElement | null;
    onScroll();
    if (typeof window !== 'undefined' && window.innerWidth >= 1024) return;
    if (!toggleBtn || !menu) return;

    menuOpen = false;
    menu.classList.add('opacity-0', '-translate-y-3', 'pointer-events-none');
    menu.classList.remove('opacity-100', 'translate-y-0');
    toggleBtn.setAttribute('aria-expanded', 'false');
    const bars = toggleBtn.querySelectorAll('span');
    bars[0]?.classList.remove('rotate-45', 'translate-y-[7px]');
    bars[1]?.classList.remove('opacity-0', 'scale-x-0');
    bars[2]?.classList.remove(
      '-rotate-45',
      '-translate-y-[7px]',
      'w-5',
      'self-auto',
    );

    if (toggleClickHandler)
      toggleBtn.removeEventListener('click', toggleClickHandler);
    toggleClickHandler = (e: Event) => {
      e.stopPropagation();
      menuOpen ? closeMenu() : openMenu();
    };
    toggleBtn.addEventListener('click', toggleClickHandler);

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => closeMenu());
    });

    const favoritesBtn = document.getElementById(
      'open-favorites-menu',
    ) as HTMLButtonElement | null;
    favoritesBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const w = window as Window & { openFavoritesWidget?: () => void };
      w.openFavoritesWidget?.();
      closeMenu();
    });
  };
  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);

  document.addEventListener('click', (e) => {
    const target = e.target;
    if (menuOpen && menu && target instanceof Node) {
      if (!menu.contains(target) && !toggleBtn?.contains(target)) {
        closeMenu();
      }
    }
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuOpen) {
      closeMenu();
      toggleBtn?.focus();
    }
  });
</script>
