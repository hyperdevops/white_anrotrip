---
export interface Props {
  navItems?: { name: string; href: string }[];
  ctaText?: string;
  ctaHref?: string;
  /** default: нав по центру хедера (сетка 1fr auto 1fr). corp: нав по центру между логотипом и телефоном (равные отступы). */
  navVariant?: 'default' | 'corp';
}

const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
const defaultNavItems = [
  { name: 'О нас', href: '#about' },
  { name: 'Туры', href: '#search' },
  { name: 'Отзывы', href: '#reviews' },
  { name: 'Команда', href: '#team' },
  { name: 'Контакты', href: '#contacts' },
];

const {
  navItems = defaultNavItems,
  ctaText = 'Личный кабинет',
  ctaHref = '/cabinet',
  navVariant = 'default',
} = Astro.props;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="mx-auto max-w-7xl px-3 sm:px-4 pt-3 md:pt-4">
    <div
      id="header-inner"
      class:list={[
        'relative grid items-center gap-4 lg:gap-6 rounded-2xl glass-panel px-4 py-3 transition-all duration-300',
        navVariant === 'corp'
          ? 'grid-cols-[auto_minmax(0,1fr)_auto]'
          : 'grid-cols-[1fr_auto_1fr]',
      ]}
    >
      <!-- Логотип: на главной — scroll to top; на corp/cabinet — href="/" data-astro-reload (полная перезагрузка для Tourvisor) -->
      <a
        href={isHome ? '#' : '/'}
        id="logo-btn"
        class="flex items-center gap-3 group z-50 cursor-pointer select-none"
        {...(isHome ? {} : { 'data-astro-reload': true })}
      >
        <!-- SVG Логотип -->
