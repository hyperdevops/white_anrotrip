---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#9ca3af] text-white text-xs sm:text-sm">
  <!-- Основная часть (Реквизиты) -->
  <div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Левая колонка: Оплата -->
      <div class="space-y-4">
        <h4 class="font-bold text-gray-800 uppercase mb-2">Способы оплаты</h4>
        <ul class="space-y-1 text-white/90 leading-relaxed list-none">
          <li>Наличными в офисе Челябинска.</li>
          <li>Оплата банковской картой через терминал в офисе Челябинска.</li>
          <li>
            Оплата банковской картой онлайн через систему интернет-эквайринга.
          </li>
          <li>Оплата по QR-коду через мобильное приложение Вашего банка.</li>
          <li>Оплата с помощью Системы быстрых платежей (СБП).</li>
          <li>Оплата переводом денежных средств на наш расчетный счет.</li>
        </ul>

        <!-- Иконки (Заглушки текстом, можно заменить на SVG) -->
        <div
          class="flex items-center gap-4 mt-6 opacity-80 grayscale hover:grayscale-0 transition-all"
        >
          <!-- ТКП логотип (условно) -->
          <div class="font-black text-2xl text-blue-900 tracking-tighter">
            .:ТКП
          </div>
          <!-- IATA логотип (условно) -->
          <div class="font-black text-2xl text-blue-900 tracking-tighter">
            IATA
          </div>
        </div>
      </div>

      <!-- Правая колонка: Реквизиты -->
      <div class="space-y-2 text-white/90 leading-relaxed">
        <h4 class="font-bold text-gray-800 uppercase mb-2">
          Банковские реквизиты ООО "АНРО"
        </h4>
        <p>ИНН 6658540239 КПП 744701001</p>
        <p>ОГРН 1206600070764</p>
        <br />
        <p>Расчетный счет: 40702810802500008845</p>
        <p>Банк: ТОЧКА ПАО БАНКА "ФК ОТКРЫТИЕ"</p>
        <p>Кор. счет: 30101810845250000999</p>
        <p>БИК: 044525999</p>
        <br />
        <p>Адрес: 454003 г. Челябинск,</p>
        <p>ул. 250-летия Челябинска, д. 29, пом. 2</p>
        <p>Телефон: 8 (800) 222-44-73</p>
        <p>Электронный адрес: anro@anrotrip.ru</p>
      </div>
    </div>
  </div>

  <!-- Нижняя полоса (Copyright) -->
  <div class="bg-secondary py-6">
    <div
      class="container mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4"
    >
      <div class="text-center md:text-left opacity-80">
        <p class="font-bold">© ANRO TRIP</p>
        <p>Туристическая компания</p>
        <p class="text-[10px] mt-1">Все права защищены</p>
      </div>

      <!-- Соцсети -->
      <div class="flex items-center gap-6">
        <!-- VK Icon (New) -->
        <a href="#" class="hover:opacity-80 transition-opacity" aria-label="VK">
          <svg class="w-6 h-6 fill-white" viewBox="0 0 24 24"
            ><path
              d="M19.915 13.028c1.388 1.336 2.768 2.68 3.864 4.296.224.331.436.671.608 1.025.263.541-.121 1.258-.707 1.298-2.527.172-5.061.166-7.587.012-.472-.029-.86-.251-1.144-.608-.553-.695-1.107-1.391-1.637-2.106-.412-.556-.849-1.096-1.428-1.487-.63-.426-1.127-.291-1.408.388-.258.625-.325 1.306-.395 1.977-.076.716-.363 1.254-1.071 1.378-2.316.406-4.392-.191-6.195-1.635-2.071-1.658-3.535-3.806-4.735-6.136-.264-.512-.516-1.03-.758-1.552-.256-.552.059-1.037.662-1.045 2.508-.036 5.016-.027 7.525.006.577.008.974.303 1.182.812.551 1.352 1.149 2.683 1.892 3.939.267.451.564.887.962 1.23.472.406.883.336 1.116-.217.279-.661.341-1.373.359-2.085.029-1.226-.239-2.348-1.218-3.058-.426-.309-1.02-.375-.953-1.05.045-.444.382-.77.935-.907 1.634-.406 4.706-.306 5.672.406.409.301.464.985.505 1.65.056.916.036 1.834.453 2.67.142.285.409.467.728.432.317-.035.564-.264.783-.497 1.05-1.116 1.838-2.42 2.518-3.791.248-.5.474-1.01.701-1.52.194-.436.561-.699 1.04-.707 2.474-.038 4.949-.033 7.424 0 .58.008.969.344.829.932-.513 2.152-1.782 3.868-3.13 5.485-.297.357-.594.714-.888 1.074-.537.658-.518 1.02.046 1.583z"
            ></path></svg
          >
        </a>
        <!-- WhatsApp Icon -->
        <a
          href="#"
          class="hover:opacity-80 transition-opacity"
          aria-label="WhatsApp"
        >
          <svg class="w-6 h-6 fill-white" viewBox="0 0 24 24"
            ><path
              d="M12.04 0C5.4 0 .01 5.38.01 12.02c0 2.12.55 4.11 1.52 5.85L.05 23.4l5.65-1.48c1.67.91 3.56 1.39 5.5 1.39 6.64 0 12.03-5.38 12.03-12.02S18.68 0 12.04 0zm0 0"
            ></path></svg
          >
        </a>
        <!-- Telegram Icon -->
        <a
          href="#"
          class="hover:opacity-80 transition-opacity"
          aria-label="Telegram"
        >
          <svg class="w-6 h-6 fill-white" viewBox="0 0 24 24"
            ><path
              d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
            ></path></svg
          >
        </a>
      </div>

      <!-- Пустой блок справа, чтобы сохранить структуру -->
      <div class="hidden md:block"></div>
    </div>
  </div>
</footer>
