---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-950 text-white">

  <!-- Верхняя часть -->
  <div class="border-b border-white/8">
    <div class="container mx-auto px-4 sm:px-6 max-w-7xl py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12">

        <!-- Колонка 1: Логотип + описание -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <!-- Иконка логотипа -->
            <div class="relative w-12 h-12 flex items-center justify-center shrink-0">
              <svg class="absolute inset-0 w-full h-full header-logo-spin" viewBox="0 0 100 100" fill="none">
                <circle cx="50" cy="50" r="44" stroke="#00abb3" stroke-width="2"
                  stroke-dasharray="5 4" stroke-linecap="round" opacity="0.4"/>
              </svg>
              <svg class="absolute top-0.5 left-0.5 w-4 h-4" viewBox="0 0 32 32" fill="none">
                <g transform="rotate(-40,16,16)">
                  <path d="M4 14 L24 8 L26 14 L17 17 L17 23 L13 22 L13 17 Z" fill="#00abb3"/>
                  <path d="M17 17 L23 20 L22 23 Z" fill="#00abb3"/>
                </g>
              </svg>
              <div class="flex flex-col items-center leading-none">
                <span class="font-montserrat font-black text-white text-[7px] tracking-[0.1em]">ANRO</span>
                <span class="font-montserrat italic font-semibold text-[6px] mt-[-1px]" style="color:#00abb3">trip</span>
              </div>
            </div>
            <div>
              <div class="flex items-baseline gap-1">
                <span class="font-montserrat font-black text-white text-lg tracking-tight">ANRO</span>
                <span class="font-montserrat italic font-semibold text-lg" style="color:#00abb3">trip</span>
              </div>
              <div class="text-[9px] text-white/35 uppercase tracking-widest">Travel &amp; Business</div>
            </div>
          </div>
          <p class="text-white/45 text-sm leading-relaxed mb-6 max-w-xs">
            Консьерж-сервис по организации путешествий и командировок по всему миру. 18 лет безупречной репутации.
          </p>
          <!-- Соцсети -->
          <div class="flex items-center gap-3">
            <a href="#" aria-label="VK"
              class="w-9 h-9 rounded-xl bg-white/8 hover:bg-primary/20 flex items-center justify-center text-white/60 hover:text-primary transition-all duration-200">
              <svg class="w-4 h-4 fill-current" viewBox="0 0 640 640">
                <path d="M127.5 127.5C96 159 96 209.7 96 311L96 329C96 430.3 96 481 127.5 512.5C159 544 209.7 544 311 544L328.9 544C430.3 544 481 544 512.4 512.5C543.8 481 544 430.3 544 329L544 311.1C544 209.7 544 159 512.5 127.6C481 96.2 430.3 96 329 96L311 96C209.7 96 159 96 127.5 127.5zM171.6 232.3L222.7 232.3C224.4 317.8 262.1 354 292 361.5L292 232.3L340.2 232.3L340.2 306C369.7 302.8 400.7 269.2 411.1 232.3L459.3 232.3C455.4 251.5 447.5 269.6 436.2 285.6C424.9 301.6 410.5 315.1 393.7 325.2C412.4 334.5 428.9 347.6 442.1 363.7C455.3 379.8 465 398.6 470.4 418.7L417.4 418.7C412.5 401.2 402.6 385.6 388.8 373.7C375 361.8 358.1 354.3 340.1 352.1L340.1 418.7L334.3 418.7C232.2 418.7 174 348.7 171.5 232.2z"/>
              </svg>
            </a>
            <a href="https://wa.me/79220267059" aria-label="WhatsApp"
              class="w-9 h-9 rounded-xl bg-white/8 hover:bg-emerald-500/20 flex items-center justify-center text-white/60 hover:text-emerald-400 transition-all duration-200">
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </a>
            <a href="https://t.me/anrotrip" aria-label="Telegram"
              class="w-9 h-9 rounded-xl bg-white/8 hover:bg-sky-500/20 flex items-center justify-center text-white/60 hover:text-sky-400 transition-all duration-200">
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Колонка 2: Способы оплаты -->
        <div class="min-w-0 break-words">
          <h4 class="text-xs font-bold text-white/40 uppercase tracking-widest mb-5">Способы оплаты</h4>
          <ul class="space-y-2.5 text-white/55 text-sm leading-relaxed">
            {[
              'Наличными в офисе Челябинска',
              'Банковской картой через терминал',
              'Онлайн через интернет-эквайринг',
              'По QR-коду через мобильный банк',
              'Системой быстрых платежей (СБП)',
              'Переводом на расчётный счёт',
            ].map(item => (
              <li class="flex items-start gap-2.5">
                <span class="w-1 h-1 rounded-full bg-primary/60 mt-2 shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
          <!-- Сертификаты -->
          <div class="flex items-center gap-4 mt-6">
            <div class="px-3 py-1.5 rounded-lg bg-white/6 border border-white/10 font-black text-sm text-white/50 tracking-tight">.:ТКП</div>
            <div class="px-3 py-1.5 rounded-lg bg-white/6 border border-white/10 font-black text-sm text-white/50 tracking-tight">IATA</div>
          </div>
        </div>

        <!-- Колонка 3: Реквизиты -->
        <div class="min-w-0 break-words">
          <h4 class="text-xs font-bold text-white/40 uppercase tracking-widest mb-5">Реквизиты ООО «АНРО»</h4>
          <div class="space-y-2 text-white/45 text-xs leading-relaxed">
            <p><span class="text-white/25">ИНН</span> 6658540239 &nbsp;<span class="text-white/25">КПП</span> 744701001</p>
            <p><span class="text-white/25">ОГРН</span> 1206600070764</p>
            <div class="pt-1 pb-1 border-t border-white/8 space-y-1.5">
              <p>Р/с: 40702810802500008845</p>
              <p>Банк: ТОЧКА ПАО «ФК ОТКРЫТИЕ»</p>
              <p>К/с: 30101810845250000999</p>
              <p>БИК: 044525999</p>
            </div>
            <div class="pt-1 border-t border-white/8 space-y-1.5">
              <p>454003 г. Челябинск,</p>
              <p>ул. 250-летия Челябинска, д. 29, пом. 2</p>
              <a href="tel:88002224473" class="block text-white/60 hover:text-white transition-colors">8 (800) 222-44-73</a>
              <a href="mailto:anro@anrotrip.ru" class="block text-primary/70 hover:text-primary transition-colors">anro@anrotrip.ru</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Нижняя полоса -->
  <div class="container mx-auto px-4 sm:px-6 max-w-7xl py-5">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-white/25 text-xs">© {currentYear} ANRO TRIP · Туристическая компания · Все права защищены</p>
      <div class="flex items-center gap-4 text-white/25 text-xs">
        <a href="#" class="hover:text-white/60 transition-colors">Политика конфиденциальности</a>
        <span class="w-px h-3 bg-white/15"></span>
        <a href="#" class="hover:text-white/60 transition-colors">Пользовательское соглашение</a>
      </div>
    </div>
  </div>

</footer>
