---
// src/components/SearchWidget.astro
import NemoSearch from './widgets/NemoSearch.astro';
import TourvisorSearch from './widgets/TourvisorSearch.astro';
---

<!-- glass-panel + белый фон принудительно для виджетов -->
<section
  id="search-widget"
  class="glass-panel bg-white dark:bg-white rounded-3xl shadow-2xl border border-white/20 overflow-visible"
>
  <!-- Переключатель вкладок -->
  <div class="flex border-b border-gray-200">
    <button
      class="tab-btn flex-1 py-4 sm:py-5 text-center font-bold text-base sm:text-lg text-gray-500 hover:text-gray-800 flex items-center justify-center gap-2 active-tab relative min-h-12"
      data-target="nemo"
    >
      <span class="relative z-10">Авиабилеты</span>
      <!-- Индикатор (Полоска) -->
      <span
        class="absolute bottom-0 left-0 w-full h-1 bg-(--color-primary) scale-x-100 transition-transform duration-300 origin-left active-indicator"
      ></span>
    </button>

    <button
      class="tab-btn flex-1 py-4 sm:py-5 text-center font-bold text-base sm:text-lg text-gray-500 hover:text-gray-800 flex items-center justify-center gap-2 relative min-h-12"
      data-target="tourvisor"
    >
      <span class="relative z-10">Туры и Отели</span>
      <span
        class="absolute bottom-0 left-0 w-full h-1 bg-(--color-primary) scale-x-0 transition-transform duration-300 origin-left active-indicator"
      ></span>
    </button>
  </div>

  <!-- Контент -->
  <div class="p-4 sm:p-6 min-h-37.5 relative z-30">
    <div id="tab-nemo" class="tab-content block animate-fade-in">
      <NemoSearch />
    </div>
    <div
      id="tab-tourvisor"
      class="tab-content hidden animate-fade-in"
      style="min-height: 500px; width: 100%; display: none;"
    >
      <TourvisorSearch />
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.tab-btn');
  const contents = document.querySelectorAll('.tab-content');

  // Функция переключения
  const switchTab = (targetId: string) => {
    // 1. Скрываем все табы
    contents.forEach((c) => {
      c.classList.add('hidden');
      (c as HTMLElement).style.display = 'none'; // Явно скрываем
    });

    // 2. Сбрасываем стили кнопок
    tabs.forEach((t) => {
      t.classList.remove('text-[var(--color-primary)]');
      t.querySelector('.active-indicator')?.classList.add('scale-x-0');
      t.querySelector('.active-indicator')?.classList.remove('scale-x-100');
    });

    // 3. Активируем нужную кнопку
    const activeTabBtn = document.querySelector(
      `.tab-btn[data-target="${targetId}"]`,
    );
    if (activeTabBtn) {
      activeTabBtn.classList.add('text-[var(--color-primary)]');
      activeTabBtn
        .querySelector('.active-indicator')
        ?.classList.remove('scale-x-0');
      activeTabBtn
        .querySelector('.active-indicator')
        ?.classList.add('scale-x-100');
    }

    // 4. Показываем контент
    const targetContent = document.getElementById(`tab-${targetId}`);
    if (targetContent) {
      targetContent.classList.remove('hidden');
      (targetContent as HTMLElement).style.display = 'block'; // Явно показываем

      // --- ХАК ДЛЯ МОБИЛЬНЫХ (TOURVISOR) ---
      // Если открыли Турвизор, заставляем браузер пересчитать размеры
      if (targetId === 'tourvisor') {
        // Небольшой "пинок" контейнеру
        setTimeout(() => {
          window.dispatchEvent(new Event('resize')); // Эмулируем ресайз окна
        }, 100);
      }
    }
  };

  // Слушатели кликов
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-target');
      if (target) switchTab(target);
    });
  });
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.3s ease-out;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
