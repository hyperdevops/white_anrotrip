---
// src/components/SearchWidget.astro
import NemoSearch from './widgets/NemoSearch.astro';
// Tourvisor — lazy-load при переключении на вкладку (экономия ~890 KiB JS на первом рендере)
---

<section
  id="search-widget"
  class="search-widget-panel glass-panel max-md:backdrop-blur-none md:backdrop-blur-xl bg-white rounded-3xl border border-white/30 overflow-visible"
>
  <!-- Переключатель вкладок -->
  <div
    class="flex p-2 gap-1.5 border-b border-gray-100"
    role="tablist"
    aria-label="Поиск: Авиабилеты или Туры и Отели"
  >
    <!-- Tab: Авиабилеты -->
    <button
      id="search-tab-nemo"
      type="button"
      role="tab"
      aria-selected="true"
      aria-controls="tab-nemo"
      tabindex="0"
      class="tab-btn flex-1 flex items-center justify-center gap-2.5 py-3.5 px-4 rounded-2xl font-bold text-sm text-gray-500 hover:text-gray-800 active:scale-[0.98] active:translate-y-0.5 transition-all duration-fast relative active-tab cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
      data-target="nemo"
    >
      <svg
        class="w-4 h-4 shrink-0"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"
        ></path>
      </svg>
      <span class="relative z-10">Авиабилеты</span>
      <span
        class="active-indicator absolute inset-0 rounded-2xl bg-primary/8 scale-100 transition-transform duration-fast origin-center"
      ></span>
    </button>

    <!-- Tab: Туры и Отели -->
    <button
      id="search-tab-tourvisor"
      type="button"
      role="tab"
      aria-selected="false"
      aria-controls="tab-tourvisor"
      tabindex="-1"
      class="tab-btn flex-1 flex items-center justify-center gap-2.5 py-3.5 px-4 rounded-2xl font-bold text-sm text-gray-500 hover:text-gray-800 active:scale-[0.98] active:translate-y-0.5 transition-all duration-fast relative cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
      data-target="tourvisor"
    >
      <svg
        class="w-4 h-4 shrink-0"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
        ></path>
      </svg>
      <span class="relative z-10">Туры и Отели</span>
      <span
        class="active-indicator absolute inset-0 rounded-2xl bg-primary/8 scale-0 transition-transform duration-fast origin-center"
      ></span>
    </button>
  </div>

  <!-- Контент -->
  <div class="p-4 sm:p-6 min-h-37.5 relative z-30">
    <div
      id="tab-nemo"
      role="tabpanel"
      aria-labelledby="search-tab-nemo"
      class="tab-content block sw-fade-in"
    >
      <NemoSearch />
    </div>
    <div
      id="tab-tourvisor"
      role="tabpanel"
      aria-labelledby="search-tab-tourvisor"
      class="tab-content sw-fade-in hidden"
      style="min-height: 400px; width: 100%;"
    >
      <!-- Placeholder: Tourvisor загружается при первом переключении на вкладку -->
      <div class="tv-wrapper w-full bg-white rounded-xl min-h-112.5">
        <div id="tourvisor-container" class="tv-search-form tv-moduleid-192367">
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  function initSearchWidget() {
    const tabList = document.querySelector('#search-widget [role="tablist"]');
    if (!tabList) return;
    if (tabList.dataset.searchWidgetInit) return;

    const tabs = Array.from(tabList.querySelectorAll('.tab-btn[role="tab"]'));
    const contents = document.querySelectorAll('#search-widget .tab-content');
    if (!tabs.length || !contents.length) return;

    tabList.dataset.searchWidgetInit = '1';

    const switchTab = (targetId, focusActive = false) => {
      contents.forEach((c) => {
        c.classList.add('hidden');
        c.style.display = 'none';
      });

      tabs.forEach((t) => {
        t.classList.remove('text-primary', 'active-tab');
        t.setAttribute('aria-selected', 'false');
        t.setAttribute('tabindex', '-1');
        const ind = t.querySelector('.active-indicator');
        if (ind) ind.classList.replace('scale-100', 'scale-0');
      });

      const activeBtn = tabList.querySelector(
        '.tab-btn[data-target="' + targetId + '"]',
      );
      if (activeBtn) {
        activeBtn.classList.add('text-primary', 'active-tab');
        activeBtn.setAttribute('aria-selected', 'true');
        activeBtn.setAttribute('tabindex', '0');
        if (focusActive) activeBtn.focus();
        const ind = activeBtn.querySelector('.active-indicator');
        if (ind) ind.classList.replace('scale-0', 'scale-100');
      }

      const targetContent = document.getElementById('tab-' + targetId);
      if (targetContent) {
        targetContent.classList.remove('hidden');
        targetContent.style.display = 'block';
        if (targetId === 'tourvisor') {
          loadTourvisor();
        }
      }
    };

    function loadTourvisor() {
      if (window.__tourvisorLoaded) return;
      window.__tourvisorLoaded = true;
      var s = document.createElement('script');
      s.src = 'https://tourvisor.ru/module/init.js';
      s.async = false;
      document.body.appendChild(s);
      s.onload = function () {
        setTimeout(function () {
          window.dispatchEvent(new Event('resize'));
        }, 100);
      };
    }

    tabList.addEventListener('keydown', (e) => {
      const currentIndex = tabs.findIndex(
        (t) => t.getAttribute('tabindex') === '0',
      );
      if (currentIndex === -1) return;
      let nextIndex = currentIndex;
      if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault();
        nextIndex = currentIndex === 0 ? tabs.length - 1 : currentIndex - 1;
      } else if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault();
        nextIndex = currentIndex === tabs.length - 1 ? 0 : currentIndex + 1;
      } else if (e.key === 'Home') {
        e.preventDefault();
        nextIndex = 0;
      } else if (e.key === 'End') {
        e.preventDefault();
        nextIndex = tabs.length - 1;
      } else return;
      const target = tabs[nextIndex]?.getAttribute('data-target');
      if (target) switchTab(target, true);
    });

    const firstBtn = tabList.querySelector('.tab-btn.active-tab');
    if (firstBtn) {
      const ind = firstBtn.querySelector('.active-indicator');
      if (ind) ind.classList.replace('scale-0', 'scale-100');
      firstBtn.classList.add('text-primary');
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-target');
        if (target) switchTab(target);
      });
    });
  }

  window.initSearchWidget = initSearchWidget;

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearchWidget);
  } else {
    initSearchWidget();
  }
</script>
