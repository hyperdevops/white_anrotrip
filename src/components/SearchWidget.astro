---
// src/components/SearchWidget.astro
import NemoSearch from './widgets/NemoSearch.astro';
import TourvisorSearch from './widgets/TourvisorSearch.astro';
---

<section
  id="search-widget"
  class="glass-panel bg-white rounded-3xl shadow-2xl border border-white/30 overflow-visible"
>
  <!-- Переключатель вкладок -->
  <div
    class="flex p-2 gap-1.5 border-b border-gray-100"
    role="tablist"
    aria-label="Поиск: Авиабилеты или Туры и Отели"
  >
    <!-- Tab: Авиабилеты -->
    <button
      id="search-tab-nemo"
      type="button"
      role="tab"
      aria-selected="true"
      aria-controls="tab-nemo"
      tabindex="0"
      class="tab-btn flex-1 flex items-center justify-center gap-2.5 py-3.5 px-4 rounded-2xl font-bold text-sm text-gray-500 hover:text-gray-800 transition-all duration-250 relative active-tab focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
      data-target="nemo"
    >
      <svg
        class="w-4 h-4 shrink-0"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"
        ></path>
      </svg>
      <span class="relative z-10">Авиабилеты</span>
      <span
        class="active-indicator absolute inset-0 rounded-2xl bg-primary/8 scale-0 transition-transform duration-250 origin-center"
      ></span>
    </button>

    <!-- Tab: Туры и Отели -->
    <button
      id="search-tab-tourvisor"
      type="button"
      role="tab"
      aria-selected="false"
      aria-controls="tab-tourvisor"
      tabindex="-1"
      class="tab-btn flex-1 flex items-center justify-center gap-2.5 py-3.5 px-4 rounded-2xl font-bold text-sm text-gray-500 hover:text-gray-800 transition-all duration-250 relative focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
      data-target="tourvisor"
    >
      <svg
        class="w-4 h-4 shrink-0"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
        ></path>
      </svg>
      <span class="relative z-10">Туры и Отели</span>
      <span
        class="active-indicator absolute inset-0 rounded-2xl bg-primary/8 scale-0 transition-transform duration-250 origin-center"
      ></span>
    </button>
  </div>

  <!-- Контент -->
  <div class="p-4 sm:p-6 min-h-37.5 relative z-30">
    <div
      id="tab-nemo"
      role="tabpanel"
      aria-labelledby="search-tab-nemo"
      class="tab-content block sw-fade-in"
    >
      <NemoSearch />
    </div>
    <div
      id="tab-tourvisor"
      role="tabpanel"
      aria-labelledby="search-tab-tourvisor"
      class="tab-content sw-fade-in hidden"
      style="min-height: 400px; width: 100%;"
    >
      <TourvisorSearch />
    </div>
  </div>
</section>

<script>
  const tabList = document.querySelector('[role="tablist"]');
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.tab-btn[role="tab"]'));
  const contents = document.querySelectorAll<HTMLElement>('.tab-content');

  const switchTab = (targetId: string, focusActive = false) => {
    contents.forEach((c) => {
      c.classList.add('hidden');
      c.style.display = 'none';
    });

    tabs.forEach((t) => {
      t.classList.remove('text-primary', 'active-tab');
      t.setAttribute('aria-selected', 'false');
      t.setAttribute('tabindex', '-1');
      const ind = t.querySelector('.active-indicator') as HTMLElement | null;
      if (ind) ind.classList.replace('scale-100', 'scale-0');
    });

    const activeBtn = document.querySelector<HTMLButtonElement>(
      `.tab-btn[data-target="${targetId}"]`,
    );
    if (activeBtn) {
      activeBtn.classList.add('text-primary', 'active-tab');
      activeBtn.setAttribute('aria-selected', 'true');
      activeBtn.setAttribute('tabindex', '0');
      if (focusActive) activeBtn.focus();
      const ind = activeBtn.querySelector('.active-indicator');
      if (ind) {
        ind.classList.replace('scale-0', 'scale-100');
      }
    }

    const targetContent = document.getElementById(`tab-${targetId}`);
    if (targetContent) {
      targetContent.classList.remove('hidden');
      targetContent.style.display = 'block';
      if (targetId === 'tourvisor') {
        setTimeout(() => window.dispatchEvent(new Event('resize')), 100);
      }
    }
  };

  // Клавиатура: стрелки влево/вправо, Home, End
  tabList?.addEventListener('keydown', (e) => {
    const ev = e as KeyboardEvent;
    const currentIndex = tabs.findIndex((t) => t.getAttribute('tabindex') === '0');
    if (currentIndex === -1) return;
    let nextIndex = currentIndex;
    if (ev.key === 'ArrowLeft' || ev.key === 'ArrowUp') {
      ev.preventDefault();
      nextIndex = currentIndex === 0 ? tabs.length - 1 : currentIndex - 1;
    } else if (ev.key === 'ArrowRight' || ev.key === 'ArrowDown') {
      ev.preventDefault();
      nextIndex = currentIndex === tabs.length - 1 ? 0 : currentIndex + 1;
    } else if (ev.key === 'Home') {
      ev.preventDefault();
      nextIndex = 0;
    } else if (ev.key === 'End') {
      ev.preventDefault();
      nextIndex = tabs.length - 1;
    } else return;
    const target = tabs[nextIndex]?.getAttribute('data-target');
    if (target) switchTab(target, true);
  });

  // Init first tab (aria and tabindex already set in HTML; ensure panel state)
  const firstBtn = document.querySelector('.tab-btn.active-tab');
  if (firstBtn) {
    const ind = firstBtn.querySelector('.active-indicator');
    if (ind) ind.classList.replace('scale-0', 'scale-100');
    firstBtn.classList.add('text-primary');
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-target');
      if (target) switchTab(target);
    });
  });
</script>
