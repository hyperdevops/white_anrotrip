---
// src/components/CookieBanner.astro — простая карточка: белый фон, blur, зелёная кнопка
---

<div
  id="cookie-banner"
  class="fixed bottom-4 right-4 z-[2147483640] w-full max-w-[360px] rounded-2xl overflow-hidden bg-white/85 backdrop-blur-md border border-white/60 shadow-xl transition-all duration-500 translate-y-full opacity-0 pointer-events-none"
  role="dialog"
  aria-labelledby="cookie-banner-title"
  aria-describedby="cookie-banner-desc"
>
  <div class="relative px-5 pt-5 pb-5">
    <!-- КРЕСТИК ЗАКРЫТИЯ - ДОБАВЛЕН ID -->
    <button
      type="button"
      id="close-cookie-banner"
      aria-label="Закрыть"
      class="absolute top-3 right-3 w-8 h-8 rounded-full flex items-center justify-center text-gray-400 hover:text-gray-600 hover:bg-gray-100/80 transition-colors"
    >
      <svg
        class="w-4 h-4"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <h2
      id="cookie-banner-title"
      class="font-montserrat font-bold text-gray-900 text-sm pr-8 mb-2"
    >
      Мы используем cookie
    </h2>
    <p
      id="cookie-banner-desc"
      class="text-gray-600 text-xs leading-relaxed font-inter mb-4"
    >
      Чтобы сайт работал лучше. Продолжая, вы соглашаетесь с
      <a href="/privacy" class="text-primary hover:underline font-medium"
        >Политикой конфиденциальности</a
      >.
    </p>
    <button
      type="button"
      id="accept-cookies"
      class="w-full py-3 rounded-xl bg-primary text-white font-montserrat font-bold text-xs uppercase tracking-wider border-2 border-primary hover:bg-white hover:text-primary transition-colors"
    >
      Принять
    </button>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('accept-cookies');
  const closeBtn = document.getElementById('close-cookie-banner'); // <-- ПОЛУЧАЕМ КРЕСТИК
  const STORAGE_KEY = 'anro_cookies_accepted';

  // Функция для закрытия баннера (универсальная)
  const hideCookieBanner = () => {
    localStorage.setItem(STORAGE_KEY, 'true'); // Ставим метку

    if (banner) {
      // Прячем баннер с анимацией
      banner.classList.add(
        'translate-y-full',
        'opacity-0',
        'pointer-events-none',
      );
    }

    // Удаляем из DOM только ПОСЛЕ завершения анимации
    setTimeout(() => {
      banner?.remove();
    }, 300); // Длительность анимации
  };

  // Проверяем при загрузке
  if (!localStorage.getItem(STORAGE_KEY)) {
    setTimeout(() => {
      if (banner) {
        banner.classList.remove(
          'translate-y-full',
          'opacity-0',
          'pointer-events-none',
        );
        banner.classList.add('opacity-100'); // Делаем полностью видимым
      }
    }, 1000); // Задержка 1 секунда, чтобы баннер появился не сразу
  } else {
    // Если метка есть — удаляем баннер из DOM
    banner?.remove();
  }

  // ОБРАБОТЧИКИ СОБЫТИЙ
  acceptBtn?.addEventListener('click', hideCookieBanner); // Кнопка "Принять"
  closeBtn?.addEventListener('click', hideCookieBanner); // <-- КНОПКА "КРЕСТИК"
</script>
