---
// src/components/Reviews.astro
import { Image } from 'astro:assets';
import molodezhImg from '../assets/reviews/molodezh.webp';
import niagaraImg from '../assets/reviews/niagara.webp';
import mercedesImg from '../assets/reviews/mercedes.webp';
import niksImg from '../assets/reviews/niks.webp';
import usmanovaImg from '../assets/reviews/usmanova.webp';
import napoleonImg from '../assets/reviews/napoleon.webp';
import r1projectImg from '../assets/reviews/r1project.webp';
import uralniiImg from '../assets/reviews/uralnii.webp';

const reviews = [
  { id: 1, title: '"МОЛОДЕЖЬ ЮЖНОГО УРАЛА"', image: molodezhImg },
  { id: 2, title: '"Ниагара"', image: niagaraImg },
  { id: 3, title: '"ОМЕГА Mercedes Benz"', image: mercedesImg },
  { id: 4, title: '"НИКС"', image: niksImg },
  { id: 5, title: '"Аня Усманова"', image: usmanovaImg },
  { id: 6, title: '"Napoleon IT"', image: napoleonImg },
  { id: 7, title: '"Проектное бюро R1"', image: r1projectImg },
  { id: 8, title: '"Урал НИИ СТРОМ"', image: uralniiImg },
];

const reviewTitles = reviews.map((r) => r.title);
const reviewCount = reviews.length;
---

<section id="reviews" class="relative py-16 md:py-24 overflow-hidden bg-gray-950">
  <!-- Фоновые орбы -->
  <div class="absolute -top-40 -left-40 w-96 h-96 bg-primary/10 rounded-full blur-0 md:blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-40 -right-40 w-80 h-80 bg-secondary/8 rounded-full blur-0 md:blur-3xl pointer-events-none"></div>
  <!-- Тонкая сетка текстура -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-size-[60px_60px] pointer-events-none"></div>

  <div class="container mx-auto px-4 sm:px-6 max-w-7xl relative z-10">

    <!-- Заголовок -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12 md:mb-16 reveal-hidden">
      <div>
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/8 border border-white/12 mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-cta md:animate-pulse"></span>
          <span class="text-xs font-semibold text-white/70 uppercase tracking-widest font-montserrat">Отзывы</span>
        </div>
        <h2 class="font-montserrat font-extrabold text-white uppercase tracking-tight leading-none" style="font-size: clamp(2rem, 1.5rem + 3vw, 4rem);">
          Что говорят<br />
          <span class="text-primary">наши клиенты</span>
        </h2>
      </div>
      <p class="text-white/40 text-sm max-w-xs leading-relaxed md:pb-2">
        Благодарственные письма от компаний, которым мы организовали командировки и корпоративные поездки
      </p>
    </div>

    <!-- Карусель документов -->
    <div class="relative reveal-hidden">
      <!-- Fade-маски -->
      <div class="absolute left-0 top-0 bottom-0 w-16 bg-linear-to-r from-gray-950 to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-16 bg-linear-to-l from-gray-950 to-transparent z-10 pointer-events-none"></div>

      <div
        class="flex overflow-x-auto gap-4 pb-4 snap-x snap-mandatory scrollbar-hide -mx-4 sm:-mx-6 px-4 sm:px-6 md:mx-0 md:px-0 overscroll-x-contain max-sm:overscroll-y-auto scroll-smooth [touch-action:pan-x_pan-y]"
        id="reviews-scroller"
      >
        {reviews.map((item, index) => (
          <div
            class="snap-start shrink-0 w-32 sm:w-36 group cursor-pointer"
            onclick={`openLightbox(${index})`}
          >
            <!-- Карточка документа -->
            <div class="reviews-doc-card relative bg-white rounded-xl overflow-hidden shadow-lg border border-white/10">
              <Image
                src={item.image}
                alt={item.title}
                width={144}
                height={203}
                class="w-full h-auto object-cover aspect-[1/1.41] pointer-events-none"
                loading="lazy"
                sizes="(max-width: 640px) 128px, 144px"
                fetchpriority={index < 2 ? undefined : 'low'}
              />
              <!-- Hover overlay -->
              <div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/10 transition-colors duration-normal flex items-center justify-center">
                <div class="w-10 h-10 rounded-full bg-white/90 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-normal shadow-[0_4px_12px_rgba(0,0,0,0.15)]">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 8v6M8 11h6"/>
                  </svg>
                </div>
              </div>
            </div>
            <p class="text-center text-[11px] text-white/40 mt-2 truncate px-1" title={item.title}>{item.title}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-10 reveal-hidden">
      <button
        id="open-review-form"
        type="button"
        class="reviews-cta-btn inline-flex items-center gap-2.5 px-8 py-4 rounded-full bg-white/10 border border-white/15 text-white font-bold text-sm uppercase tracking-wider shadow-[0_4px_12px_rgba(0,171,179,0.25)] hover:bg-white/18 active:scale-[0.98] active:translate-y-0.5 btn-magnetic cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-gray-900"
      >
        <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Оставить отзыв
      </button>
    </div>
  </div>

  <!-- ══════ LIGHTBOX ══════ -->
  <style is:global>
    /* iOS: плавная прокрутка (веб-стандарт для touch) */
    #lightbox .slide-item,
    #reviews-scroller {
      -webkit-overflow-scrolling: touch;
    }
  </style>
  <div
    id="lightbox"
    class="fixed inset-0 z-2147483647 bg-black/95 hidden items-center justify-center opacity-0 transition-opacity duration-normal select-none backdrop-blur-sm cursor-zoom-in overflow-hidden"
    onclick="toggleZoom(event)"
  >
    <!-- Панель управления -->
    <div class="absolute top-0 right-0 p-5 flex gap-3 z-2147483649" onclick="event.stopPropagation()">
      <button
        type="button"
        aria-label="Увеличить или уменьшить"
        onclick="toggleZoom(event)"
        class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 active:scale-[0.98] active:translate-y-0.5 flex items-center justify-center text-white transition-[background-color,transform] cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-transparent"
        id="zoom-btn"
      >
        <svg id="icon-zoom-in" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 8v6M8 11h6"/>
        </svg>
        <svg id="icon-zoom-out" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M8 11h6"/>
        </svg>
      </button>
      <button
        id="lightbox-close-btn"
        type="button"
        aria-label="Закрыть просмотр"
        onclick="closeLightbox()"
        class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-transparent"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Название слайда -->
    <div class="absolute top-5 left-5 z-2147483649" id="lightbox-title">
      <span class="text-white/50 text-sm font-medium"></span>
    </div>

    <!-- Стрелки -->
      <button
        type="button"
        aria-label="Предыдущий отзыв"
        onclick="event.stopPropagation(); changeSlide(-1)"
        class="absolute left-4 top-1/2 -translate-y-1/2 z-2147483649 w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 active:scale-[0.98] active:translate-y-0.5 flex items-center justify-center text-white transition-[background-color,transform] md:flex cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-transparent"
      >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
    </button>
      <button
        type="button"
        aria-label="Следующий отзыв"
        onclick="event.stopPropagation(); changeSlide(1)"
        class="absolute right-4 top-1/2 -translate-y-1/2 z-2147483649 w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 active:scale-[0.98] active:translate-y-0.5 flex items-center justify-center text-white transition-[background-color,transform] md:flex cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-transparent"
      >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
      </svg>
    </button>

    <!-- Трек -->
    <div id="lightbox-track" class="flex h-full w-full transition-transform duration-normal ease-out will-change-transform">
      {reviews.map((item) => (
        <div class="w-full h-full shrink-0 slide-item overflow-x-hidden overflow-y-auto min-h-0 py-6 flex flex-col items-center overscroll-contain [touch-action:pan-x_pan-y]">
          <div class="lightbox-slide-inner flex items-center justify-center min-h-full w-full shrink-0 mx-auto">
            <Image
              src={item.image}
              alt={item.title}
              width={item.image.width}
              height={item.image.height}
              quality={92}
              class="lightbox-img max-w-[min(90vw,460px)] md:max-w-[min(90vw,560px)] w-auto h-auto object-contain object-center shadow-2xl shadow-black/30 rounded-lg block"
            />
          </div>
        </div>
      ))}
    </div>

    <!-- Счётчик -->
    <div class="absolute bottom-5 left-1/2 -translate-x-1/2 z-2147483649">
      <span id="lightbox-counter" class="text-white/40 text-sm font-medium"></span>
    </div>
  </div>

  <!-- ══════ ФОРМА ОТЗЫВА ══════ (по аналогии с CallbackModal / GiftModal: плавное открытие/закрытие, виджет офиса за блюром) -->
  <div id="review-modal-overlay"
    class="fixed inset-0 z-2147483647 bg-black/60 backdrop-blur-sm hidden items-center justify-center opacity-0 transition-opacity duration-slow">
    <div id="review-modal-content"
      class="bg-white rounded-3xl shadow-2xl shadow-black/20 w-full max-w-md mx-4 relative transform translate-y-20 transition-all duration-slow ease-out max-h-[90vh] overflow-y-auto">
      <button id="close-review-form"
        type="button"
        aria-label="Закрыть форму отзыва"
        class="absolute top-4 right-4 w-9 h-9 rounded-full bg-gray-100 hover:bg-gray-200 active:scale-[0.98] active:translate-y-0.5 flex items-center justify-center text-gray-500 hover:text-gray-800 transition-[color,background-color,transform] cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <div class="p-8 pt-7">
        <div class="text-center mb-6">
          <h3 class="font-montserrat text-xl font-extrabold text-gray-900 uppercase tracking-wide mb-1">Оставить отзыв</h3>
          <p class="text-sm text-gray-400">Будем благодарны за ваше мнение о работе ANRO TRIP</p>
        </div>

        <form class="space-y-3" onsubmit="event.preventDefault(); alert('Спасибо! Отзыв отправлен.'); closeReviewForm();">
          <div>
            <label class="text-xs text-gray-500 font-medium mb-1 block">Ваше имя</label>
            <input type="text" placeholder="Имя" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-[border-color,box-shadow]" />
          </div>
          <div>
            <label class="text-xs text-gray-500 font-medium mb-1 block">Телефон</label>
            <input type="tel" placeholder="+7 (___) ___-__-__" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-[border-color,box-shadow]" />
          </div>
          <div>
            <label class="text-xs text-gray-500 font-medium mb-1 block">E-mail</label>
            <input type="email" placeholder="email@example.ru" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-[border-color,box-shadow]" />
          </div>
          <div>
            <label class="text-xs text-gray-500 font-medium mb-1 block">Город</label>
            <input type="text" placeholder="Ваш город" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-[border-color,box-shadow]" />
          </div>
          <div>
            <label class="text-xs text-gray-500 font-medium mb-1 block">Услуга</label>
            <input type="text" placeholder="Билеты / тур / отель / виза / другое"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-[border-color,box-shadow]"
            />
          </div>
          <div>
            <label class="text-xs text-gray-500 font-medium mb-1 block">Отзыв</label>
            <textarea rows={3} placeholder="Расскажите о вашем опыте..." required
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm resize-none transition-[border-color,box-shadow]"
            ></textarea>
          </div>
          <div class="flex items-start gap-2.5 pt-1">
            <input type="checkbox" id="agree-review" class="mt-0.5 w-4 h-4 cursor-pointer" />
            <label for="agree-review" class="text-[11px] text-gray-400 leading-snug cursor-pointer">
              Даю согласие на обработку персональных данных в соответствии с
              <a href="/privacy" class="text-primary font-semibold hover:underline cursor-pointer">Политикой конфиденциальности</a>
            </label>
          </div>
          <button class="w-full bg-primary text-white font-bold py-3.5 rounded-xl mt-2 hover:bg-primary-dark transition-colors cursor-pointer tracking-wide uppercase text-sm">
            Отправить отзыв
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ reviewTitles, reviewCount }}>
  let currentIndex = 0;
  let isZoomed = false;

  const lightbox   = document.getElementById('lightbox');
  const track      = document.getElementById('lightbox-track');
  const slides     = document.querySelectorAll('.slide-item');
  const inners     = document.querySelectorAll('.lightbox-slide-inner');
  const images     = document.querySelectorAll('.lightbox-img');
  const counter    = document.getElementById('lightbox-counter');
  const titleEl    = document.getElementById('lightbox-title')?.querySelector('span');

  const zoomBtn    = document.getElementById('zoom-btn');
  const iconIn     = document.getElementById('icon-zoom-in');
  const iconOut    = document.getElementById('icon-zoom-out');

  const formOverlay  = document.getElementById('review-modal-overlay');
  const formContent  = document.getElementById('review-modal-content');
  const openFormBtn  = document.getElementById('open-review-form');
  const closeFormBtn = document.getElementById('close-review-form');

  let lightboxPreviousFocus = null;

  function getLightboxFocusables() {
    if (!lightbox) return [];
    const sel = 'button:not([disabled]), [href], [tabindex]:not([tabindex="-1"])';
    return Array.from(lightbox.querySelectorAll(sel)).filter(el => el.offsetParent !== null);
  }

  function trapLightboxFocus(ev) {
    const e = ev;
    if (e.key !== 'Tab') return;
    const focusables = getLightboxFocusables();
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) {
        e.preventDefault();
        last.focus();
      }
    } else {
      if (document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  }

  function togglePageElements(hide) {
    [document.querySelector('header'), document.getElementById('scroll-to-top'), document.getElementById('favorites-widget'), document.getElementById('office-widget-container')].forEach(el => {
      if (!el) return;
      el.style.transition = 'opacity 0.5s ease';
      el.style.opacity = hide ? '0' : '1';
      el.style.pointerEvents = hide ? 'none' : 'auto';
      if (!hide) setTimeout(() => { el.style.transition = ''; el.style.opacity = ''; el.style.pointerEvents = ''; }, 500);
    });
  }

  function updateCounter() {
    if (counter) counter.textContent = `${currentIndex + 1} / ${reviewCount}`;
    if (titleEl) titleEl.textContent = reviewTitles[currentIndex] || '';
  }

  window.openLightbox = (index) => {
    lightboxPreviousFocus = document.activeElement;
    currentIndex = index;
    updateTrackPosition(false);
    updateCounter();
    const curSlide = slides[currentIndex];
    if (curSlide) { curSlide.scrollTop = 0; curSlide.scrollLeft = 0; }
    lightbox.classList.remove('hidden');
    lightbox.style.display = 'flex';
    if (window.lockScroll) window.lockScroll();
    togglePageElements(true);
    lightbox.addEventListener('keydown', trapLightboxFocus);
    setTimeout(() => {
      lightbox.classList.remove('opacity-0');
      document.getElementById('lightbox-close-btn')?.focus();
    }, 10);
  };

  window.closeLightbox = () => {
    lightbox.removeEventListener('keydown', trapLightboxFocus);
    lightbox.classList.add('opacity-0');
    setTimeout(() => {
      lightbox.classList.add('hidden');
      lightbox.style.display = '';
      if (window.unlockScroll) window.unlockScroll();
      resetZoom();
      togglePageElements(false);
      lightboxPreviousFocus?.focus();
      lightboxPreviousFocus = null;
    }, 300);
  };

  window.changeSlide = (dir) => {
    resetZoom();
    currentIndex = (currentIndex + dir + reviewCount) % reviewCount;
    updateTrackPosition(true);
    updateCounter();
    const curSlide = slides[currentIndex];
    if (curSlide) { curSlide.scrollTop = 0; curSlide.scrollLeft = 0; }
  };

  function updateTrackPosition(animate) {
    track.style.transition = animate ? 'transform 0.3s ease-out' : 'none';
    track.style.transform = `translateX(-${currentIndex * 100}%)`;
  }

  // Зум как на anrotrip (Tilda): без transform, изображение в 2× размере + прокрутка, без прыжка
  window.toggleZoom = (e) => {
    const img = images[currentIndex];
    const slide = slides[currentIndex];
    const inner = inners[currentIndex];
    if (isZoomed) {
      img.style.width = '';
      img.style.height = '';
      img.style.maxWidth = '';
      img.style.maxHeight = '';
      if (inner) {
        inner.style.width = '';
        inner.style.height = '';
        inner.style.minWidth = '';
        inner.style.minHeight = '';
      }
      slide.style.overflowX = 'hidden';
      slide.style.overflowY = 'auto';
      lightbox.style.cursor = 'zoom-in';
      iconIn.classList.remove('hidden'); iconOut.classList.add('hidden');
      isZoomed = false;
    } else {
      const w = img.clientWidth;
      const h = img.clientHeight;
      const zoomFactor = 1.5;
      const zoomedW = Math.round(w * zoomFactor);
      const zoomedH = Math.round(h * zoomFactor);
      if (inner && w && h) {
        inner.style.width = zoomedW + 'px';
        inner.style.height = zoomedH + 'px';
        inner.style.minWidth = zoomedW + 'px';
        inner.style.minHeight = zoomedH + 'px';
      }
      img.style.maxWidth = 'none';
      img.style.maxHeight = 'none';
      img.style.width = zoomedW + 'px';
      img.style.height = zoomedH + 'px';
      slide.style.overflow = 'auto';
      slide.style.overflowX = 'auto';
      slide.style.overflowY = 'auto';
      // После перерасчёта layout — центрировать вид по центру документа (десктоп и мобильные)
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          const maxScrollL = Math.max(0, slide.scrollWidth - slide.clientWidth);
          const maxScrollT = Math.max(0, slide.scrollHeight - slide.clientHeight);
          slide.scrollLeft = maxScrollL * 0.5;
          slide.scrollTop = maxScrollT * 0.5;
        });
      });
      lightbox.style.cursor = 'zoom-out';
      iconIn.classList.add('hidden'); iconOut.classList.remove('hidden');
      isZoomed = true;
    }
  };

  function resetZoom() {
    images.forEach(img => {
      img.style.width = '';
      img.style.height = '';
      img.style.maxWidth = '';
      img.style.maxHeight = '';
    });
    inners.forEach(inner => {
      inner.style.width = '';
      inner.style.height = '';
      inner.style.minWidth = '';
      inner.style.minHeight = '';
    });
    slides.forEach(s => { s.style.overflowX = 'hidden'; s.style.overflowY = 'auto'; });
    lightbox.style.cursor = 'zoom-in';
    iconIn.classList.remove('hidden'); iconOut.classList.add('hidden');
    isZoomed = false;
  }

  // Swipe support
  let touchStartX = 0;
  lightbox?.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  lightbox?.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 50) window.changeSlide(dx < 0 ? 1 : -1);
  });

  // Form — плавное открытие/закрытие по аналогии с CallbackModal / GiftModal
  openFormBtn?.addEventListener('click', () => {
    if (!formOverlay || !formContent) return;
    formOverlay.classList.remove('hidden');
    formOverlay.style.display = 'flex';
    if (window.lockScroll) window.lockScroll();
    togglePageElements(true);
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        formOverlay.classList.remove('opacity-0');
        formContent.classList.remove('translate-y-20');
        formContent.classList.add('translate-y-0');
      });
    });
  });

  window.closeReviewForm = () => {
    if (!formOverlay || !formContent) return;
    formOverlay.classList.add('opacity-0');
    formContent.classList.remove('translate-y-0');
    formContent.classList.add('translate-y-20');
    setTimeout(() => {
      formOverlay.classList.add('hidden');
      formOverlay.style.display = 'none';
      if (window.unlockScroll) window.unlockScroll();
      togglePageElements(false);
    }, 500);
  };

  closeFormBtn?.addEventListener('click', closeReviewForm);
  formOverlay?.addEventListener('click', e => { if (e.target === formOverlay) closeReviewForm(); });

  window.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      if (!lightbox.classList.contains('hidden')) closeLightbox();
      if (!formOverlay.classList.contains('hidden')) closeReviewForm();
    }
    if (!lightbox.classList.contains('hidden')) {
      if (e.key === 'ArrowRight') window.changeSlide(1);
      if (e.key === 'ArrowLeft')  window.changeSlide(-1);
    }
  });

  function initReviewsScroller() {
    const el = document.getElementById('reviews-scroller');
    if (!el) return;
    el.scrollLeft = 0;
  }
  initReviewsScroller();
  document.addEventListener('astro:page-load', initReviewsScroller);
  window.addEventListener('load', () => {
    const el = document.getElementById('reviews-scroller');
    if (el) el.scrollLeft = 0;
  });
</script>
