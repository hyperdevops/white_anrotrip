---
// src/components/Reviews.astro

// Локальный placeholder до загрузки реальных фото отзывов
const reviewPlaceholder = '/images/review-placeholder.svg';

const reviews = [
  { id: 1, title: 'Молодежь Южного Урала', src: reviewPlaceholder },
  { id: 2, title: 'Ниагара',               src: reviewPlaceholder },
  { id: 3, title: 'Мерседес',              src: reviewPlaceholder },
  { id: 4, title: 'Никс',                  src: reviewPlaceholder },
  { id: 5, title: 'Письмо Аня Усманова',   src: reviewPlaceholder },
  { id: 6, title: 'Napoleon',              src: reviewPlaceholder },
  { id: 7, title: 'Проектное бюро',        src: reviewPlaceholder },
  { id: 8, title: 'Урал НИИ СТРОЙ',        src: reviewPlaceholder },
];
---

<section id="reviews" class="relative py-16 md:py-24 overflow-hidden bg-gray-950">
  <!-- Фоновые орбы -->
  <div class="absolute -top-40 -left-40 w-96 h-96 bg-primary/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-40 -right-40 w-80 h-80 bg-secondary/8 rounded-full blur-3xl pointer-events-none"></div>
  <!-- Тонкая сетка текстура -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:60px_60px] pointer-events-none"></div>

  <div class="container mx-auto px-4 sm:px-6 max-w-7xl relative z-10">

    <!-- Заголовок -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12 md:mb-16 reveal-hidden">
      <div>
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/8 border border-white/12 mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-cta animate-pulse"></span>
          <span class="text-xs font-semibold text-white/70 uppercase tracking-widest font-montserrat">Отзывы</span>
        </div>
        <h2 class="font-montserrat font-extrabold text-white uppercase tracking-tight leading-[1.0]" style="font-size: clamp(2rem, 1.5rem + 3vw, 4rem);">
          Что говорят<br />
          <span class="text-primary">наши клиенты</span>
        </h2>
      </div>
      <p class="text-white/40 text-sm max-w-xs leading-relaxed md:pb-2">
        Благодарственные письма от компаний, которым мы организовали командировки и корпоративные поездки
      </p>
    </div>

    <!-- Карусель документов -->
    <div class="relative reveal-hidden">
      <!-- Fade-маски -->
      <div class="absolute left-0 top-0 bottom-0 w-16 bg-linear-to-r from-gray-950 to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-16 bg-linear-to-l from-gray-950 to-transparent z-10 pointer-events-none"></div>

      <div
        class="flex overflow-x-auto gap-4 pb-4 snap-x snap-mandatory scrollbar-hide -mx-4 sm:-mx-6 px-4 sm:px-6 md:mx-0 md:px-0"
        id="reviews-scroller"
      >
        {reviews.map((item, index) => (
          <div
            class="snap-start shrink-0 w-32 sm:w-36 group cursor-pointer"
            onclick={`openLightbox(${index})`}
          >
            <!-- Карточка документа -->
            <div class="relative bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-2xl hover:shadow-primary/20 transition-all duration-300 hover:-translate-y-2 border border-white/10">
              <img
                src={item.src}
                alt={item.title}
                class="w-full h-auto object-cover aspect-[1/1.41] pointer-events-none"
                loading="lazy"
              />
              <!-- Hover overlay -->
              <div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/10 transition-colors duration-300 flex items-center justify-center">
                <div class="w-10 h-10 rounded-full bg-white/90 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 shadow-lg">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 8v6M8 11h6"/>
                  </svg>
                </div>
              </div>
            </div>
            <p class="text-center text-[11px] text-white/40 mt-2 truncate px-1" title={item.title}>{item.title}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-10 reveal-hidden">
      <button
        id="open-review-form"
        class="inline-flex items-center gap-2.5 px-8 py-4 rounded-full bg-white/10 border border-white/15 text-white font-bold text-sm uppercase tracking-wider hover:bg-white/18 hover:-translate-y-0.5 transition-all duration-300 btn-magnetic"
      >
        <svg class="w-4 h-4 text-cta" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Оставить отзыв
      </button>
    </div>
  </div>

  <!-- ══════ LIGHTBOX ══════ -->
  <div
    id="lightbox"
    class="fixed inset-0 z-2147483647 bg-black/95 hidden items-center justify-center opacity-0 transition-opacity duration-300 select-none backdrop-blur-sm cursor-zoom-in overflow-hidden"
    onclick="toggleZoom(event)"
  >
    <!-- Панель управления -->
    <div class="absolute top-0 right-0 p-5 flex gap-3 z-2147483649" onclick="event.stopPropagation()">
      <button onclick="toggleZoom(event)"
        class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors" id="zoom-btn">
        <svg id="icon-zoom-in" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 8v6M8 11h6"/>
        </svg>
        <svg id="icon-zoom-out" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M8 11h6"/>
        </svg>
      </button>
      <button onclick="closeLightbox()"
        class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Название слайда -->
    <div class="absolute top-5 left-5 z-2147483649" id="lightbox-title">
      <span class="text-white/50 text-sm font-medium"></span>
    </div>

    <!-- Стрелки -->
    <button onclick="event.stopPropagation(); changeSlide(-1)"
      class="absolute left-4 top-1/2 -translate-y-1/2 z-2147483649 w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors hidden md:flex focus:outline-none">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
    </button>
    <button onclick="event.stopPropagation(); changeSlide(1)"
      class="absolute right-4 top-1/2 -translate-y-1/2 z-2147483649 w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors hidden md:flex focus:outline-none">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
      </svg>
    </button>

    <!-- Трек -->
    <div id="lightbox-track" class="flex h-full w-full transition-transform duration-300 ease-out will-change-transform">
      {reviews.map((item) => (
        <div class="w-full h-full shrink-0 flex items-center justify-center slide-item overflow-hidden">
          <img src={item.src} alt={item.title}
            class="lightbox-img max-h-[88vh] max-w-[88vw] object-contain shadow-2xl transition-transform duration-300 origin-center rounded-lg"
            style="transform: scale(1);"
          />
        </div>
      ))}
    </div>

    <!-- Счётчик -->
    <div class="absolute bottom-5 left-1/2 -translate-x-1/2 z-2147483649">
      <span id="lightbox-counter" class="text-white/40 text-sm font-medium"></span>
    </div>
  </div>

  <!-- ══════ ФОРМА ОТЗЫВА ══════ -->
  <div id="review-modal-overlay"
    class="fixed inset-0 z-2147483647 bg-black/70 backdrop-blur-sm hidden items-center justify-center opacity-0 transition-opacity duration-400">
    <div id="review-modal-content"
      class="bg-white rounded-3xl shadow-2xl w-full max-w-md mx-4 relative transform translate-y-6 transition-all duration-400 ease-out max-h-[90vh] overflow-y-auto">
      <button id="close-review-form"
        class="absolute top-4 right-4 w-9 h-9 rounded-full bg-gray-100 hover:bg-gray-200 flex items-center justify-center text-gray-500 hover:text-gray-800 transition-colors cursor-pointer">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <div class="p-8 pt-7">
        <div class="text-center mb-6">
          <h3 class="font-montserrat text-xl font-extrabold text-gray-900 uppercase tracking-wide mb-1">Оставить отзыв</h3>
          <p class="text-sm text-gray-400">Будем благодарны за ваше мнение о работе ANRO TRIP</p>
        </div>

        <form class="space-y-3" onsubmit="event.preventDefault(); alert('Спасибо! Отзыв отправлен.'); closeReviewForm();">
          <div>
            <label class="text-xs text-gray-500 font-medium mb-1 block">Ваше имя</label>
            <input type="text" placeholder="Имя" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-all" />
          </div>
          <div>
            <label class="text-xs text-gray-500 font-medium mb-1 block">Телефон</label>
            <input type="tel" placeholder="+7 (___) ___-__-__" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-all" />
          </div>
          <div>
            <label class="text-xs text-gray-500 font-medium mb-1 block">E-mail</label>
            <input type="email" placeholder="email@example.ru" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-all" />
          </div>
          <div>
            <label class="text-xs text-gray-500 font-medium mb-1 block">Город</label>
            <input type="text" placeholder="Ваш город" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-all" />
          </div>
          <div>
            <label class="text-xs text-gray-500 font-medium mb-1 block">Услуга</label>
            <input type="text" placeholder="Билеты / тур / отель / виза / другое"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-all"
            />
          </div>
          <div>
            <label class="text-xs text-gray-500 font-medium mb-1 block">Отзыв</label>
            <textarea rows={3} placeholder="Расскажите о вашем опыте..." required
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm resize-none transition-all"
            ></textarea>
          </div>
          <div class="flex items-start gap-2.5 pt-1">
            <input type="checkbox" id="agree-review" class="mt-0.5 w-4 h-4 accent-primary" />
            <label for="agree-review" class="text-[11px] text-gray-400 leading-snug">
              Даю согласие на обработку персональных данных в соответствии с
              <a href="#" class="text-primary font-semibold hover:underline">Политикой конфиденциальности</a>
            </label>
          </div>
          <button class="w-full bg-primary text-white font-bold py-3.5 rounded-xl mt-2 hover:bg-primary-dark transition-colors cursor-pointer tracking-wide uppercase text-sm">
            Отправить отзыв
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ reviews }}>
  let currentIndex = 0;
  let isZoomed = false;

  const lightbox   = document.getElementById('lightbox');
  const track      = document.getElementById('lightbox-track');
  const slides     = document.querySelectorAll('.slide-item');
  const images     = document.querySelectorAll('.lightbox-img');
  const counter    = document.getElementById('lightbox-counter');
  const titleEl    = document.getElementById('lightbox-title')?.querySelector('span');

  const zoomBtn    = document.getElementById('zoom-btn');
  const iconIn     = document.getElementById('icon-zoom-in');
  const iconOut    = document.getElementById('icon-zoom-out');

  const formOverlay  = document.getElementById('review-modal-overlay');
  const formContent  = document.getElementById('review-modal-content');
  const openFormBtn  = document.getElementById('open-review-form');
  const closeFormBtn = document.getElementById('close-review-form');

  function togglePageElements(hide) {
    [document.querySelector('header'), document.getElementById('scroll-to-top'), document.getElementById('favorites-widget')].forEach(el => {
      if (!el) return;
      el.style.transition = 'opacity 0.4s ease';
      el.style.opacity = hide ? '0' : '1';
      el.style.pointerEvents = hide ? 'none' : 'auto';
      if (!hide) setTimeout(() => { el.style.transition = ''; el.style.opacity = ''; el.style.pointerEvents = ''; }, 400);
    });
  }

  function updateCounter() {
    if (counter) counter.textContent = `${currentIndex + 1} / ${reviews.length}`;
    if (titleEl) titleEl.textContent = reviews[currentIndex]?.title || '';
  }

  window.openLightbox = (index) => {
    currentIndex = index;
    updateTrackPosition(false);
    updateCounter();
    lightbox.classList.remove('hidden');
    lightbox.style.display = 'flex';
    if (window.lockScroll) window.lockScroll();
    togglePageElements(true);
    setTimeout(() => lightbox.classList.remove('opacity-0'), 10);
  };

  window.closeLightbox = () => {
    lightbox.classList.add('opacity-0');
    setTimeout(() => {
      lightbox.classList.add('hidden');
      lightbox.style.display = '';
      if (window.unlockScroll) window.unlockScroll();
      resetZoom();
      togglePageElements(false);
    }, 300);
  };

  window.changeSlide = (dir) => {
    resetZoom();
    currentIndex = (currentIndex + dir + reviews.length) % reviews.length;
    updateTrackPosition(true);
    updateCounter();
  };

  function updateTrackPosition(animate) {
    track.style.transition = animate ? 'transform 0.3s ease-out' : 'none';
    track.style.transform = `translateX(-${currentIndex * 100}%)`;
  }

  window.toggleZoom = (e) => {
    const img = images[currentIndex];
    const slide = slides[currentIndex];
    if (isZoomed) {
      img.style.transform = 'scale(1)'; slide.style.overflow = 'hidden';
      lightbox.style.cursor = 'zoom-in';
      iconIn.classList.remove('hidden'); iconOut.classList.add('hidden');
      isZoomed = false;
    } else {
      img.style.transform = 'scale(2.5)'; slide.style.overflow = 'auto';
      lightbox.style.cursor = 'zoom-out';
      iconIn.classList.add('hidden'); iconOut.classList.remove('hidden');
      isZoomed = true;
    }
  };

  function resetZoom() {
    images.forEach(img => { img.style.transform = 'scale(1)'; });
    slides.forEach(s => { s.style.overflow = 'hidden'; });
    lightbox.style.cursor = 'zoom-in';
    iconIn.classList.remove('hidden'); iconOut.classList.add('hidden');
    isZoomed = false;
  }

  // Swipe support
  let touchStartX = 0;
  lightbox?.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  lightbox?.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 50) window.changeSlide(dx < 0 ? 1 : -1);
  });

  // Form
  openFormBtn?.addEventListener('click', () => {
    formOverlay.classList.remove('hidden');
    formOverlay.style.display = 'flex';
    if (window.lockScroll) window.lockScroll();
    togglePageElements(true);
    setTimeout(() => {
      formOverlay.classList.remove('opacity-0');
      formContent.classList.remove('translate-y-6');
    }, 10);
  });

  window.closeReviewForm = () => {
    formOverlay.classList.add('opacity-0');
    formContent.classList.add('translate-y-6');
    setTimeout(() => {
      formOverlay.classList.add('hidden');
      formOverlay.style.display = 'none';
      if (window.unlockScroll) window.unlockScroll();
      togglePageElements(false);
    }, 400);
  };

  closeFormBtn?.addEventListener('click', closeReviewForm);
  formOverlay?.addEventListener('click', e => { if (e.target === formOverlay) closeReviewForm(); });

  window.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      if (!lightbox.classList.contains('hidden')) closeLightbox();
      if (!formOverlay.classList.contains('hidden')) closeReviewForm();
    }
    if (!lightbox.classList.contains('hidden')) {
      if (e.key === 'ArrowRight') window.changeSlide(1);
      if (e.key === 'ArrowLeft')  window.changeSlide(-1);
    }
  });

  function initReviewsCyclicScroll() {
    const el = document.getElementById('reviews-scroller');
    if (!el || window.innerWidth >= 768) return;
    let ticking = false;
    const loop = () => {
      const maxScroll = el.scrollWidth - el.clientWidth;
      if (maxScroll <= 0) return;
      const left = el.scrollLeft;
      if (left <= 20) el.scrollLeft = maxScroll;
      else if (left >= maxScroll - 20) el.scrollLeft = 0;
      ticking = false;
    };
    el.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(loop);
    });
  }
  initReviewsCyclicScroll();
  document.addEventListener('astro:page-load', initReviewsCyclicScroll);
</script>
