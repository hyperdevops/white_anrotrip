---
// src/components/About.astro

// 1. УСЛУГИ (Иконки верхний ряд)
const services = [
  {
    title: 'Авиа и ж/д билеты',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />`,
  },
  {
    title: 'Бронирование отелей',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`,
  },
  {
    title: 'Туры',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  },
  {
    title: 'Визовая поддержка',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" />`,
  },
  {
    title: 'Трансфер',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />`,
  },
  {
    title: 'Страховка',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />`,
  },
];

// 2. ПРЕИМУЩЕСТВА (3 карточки)
const features = [
  {
    title: 'Быстро развиваемся',
    desc: 'Входим в ТОП-10 компаний России по результатам 2024 года',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />`,
  },
  {
    title: 'Всегда на связи',
    desc: 'Наши клиенты получают круглосуточную поддержку',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  },
  {
    title: 'Собственная авиакасса',
    desc: 'Бронируем любые направления и быстро осуществляем обмен/возврат в собственных GDS пультах',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />`,
  },
];

// 3. ТЕКСТОВЫЕ БЛОКИ
const textBlocks = [
  `ANRO TRIP — это команда профессионалов, предоставляющих консьерж-сервис по организации командировок и путешествий по всему миру на протяжении 6 лет.`,
  `ANRO TRIP — это покупка авиа и ж/д билетов, заказ трансфера, оформление страховки, бронирование отеля или тура, помощь в оформлении визы, командировки под ключ и корпоративные мероприятия для Вашей компании.`,
  `ANRO TRIP — это российский туроператор РТО 022708.`,
  `ANRO TRIP — это 14 000 довольных клиентов по всему миру, 700 компаний на корпоративном обслуживании и более 18 лет работы в туризме.`,
];

// 4. НАПРАВЛЕНИЯ РАБОТЫ (Нижний блок)
const directions = [
  {
    title: 'Корпоративное обслуживание',
    desc: 'ANRO TRIP полностью возьмёт на себя организацию командировок вашей компании. Мы заключаем договор на индивидуальных условиях, подходящих именно Вам. Предоставляем отчётные документы через ЭДО.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />`,
  },
  {
    title: 'Авиабилеты',
    desc: 'ANRO TRIP имеет круглосуточный доступ к системам бронирования авиабилетов. Мы можем оформить/поменять/вернуть билет по Вашей просьбе в считанные минуты.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />`,
  },
  {
    title: 'Личный travel-ассистент',
    desc: 'При обращении в ANRO TRIP за любым туристическим продуктом за Вами закрепляется личный помощник, который учтёт все пожелания и поможет в форс-мажорных ситуациях.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />`,
  },
  {
    title: 'Визовая поддержка',
    desc: 'Сопровождаем подготовку полного пакета документов для подачи в визовый центр.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  },
];

export interface Props {
  class?: string;
}

const { class: classes = '' } = Astro.props;
---

<section id="about" class={`py-6 bg-white overflow-hidden ${classes}`}>
  <div class="container mx-auto px-4 max-w-7xl">
    <!-- ЗАГОЛОВОК -->
    <div class="text-center mb-14 reveal-hidden">
      <h2
        class="font-montserrat text-4xl font-extrabold text-gray-900 tracking-wide"
      >
        Почему выбирают <span class="text-primary">ANRO TRIP</span>
      </h2>
    </div>

    <!-- 1. ИКОНКИ УСЛУГ (Верхний ряд) -->
    <div
      class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 mb-24 reveal-hidden"
    >
      {
        services.map((item) => (
          <div class="flex flex-col items-center text-center group cursor-default">
            <div class="w-16 h-16 rounded-2xl bg-white border border-gray-100 shadow-sm flex items-center justify-center mb-4 group-hover:scale-110 group-hover:border-primary/30 group-hover:shadow-lg group-hover:shadow-primary/10 transition-all duration-300">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-8 w-8 text-gray-600 group-hover:text-primary transition-colors"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
                set:html={item.icon}
              />
            </div>
            <span class="text-sm font-semibold text-gray-700 group-hover:text-primary transition-colors">
              {item.title}
            </span>
          </div>
        ))
      }
    </div>

    <!-- 2. КАРТОЧКИ ПРЕИМУЩЕСТВ (3 штуки) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
      {
        features.map((item, index) => (
          <div
            class:list={[
              'group p-8 rounded-3xl bg-white transition-all duration-300',
              'border border-gray-100',
              'hover:border-primary/20',
              'deep-shadow hover:-translate-y-2',
              'reveal-hidden',
              'text-center h-full flex flex-col items-center',
              index === 1 ? 'delay-100' : index === 2 ? 'delay-200' : '',
            ]}
          >
            <div class="w-20 h-20 rounded-full bg-primary/5 flex items-center justify-center mb-6 group-hover:bg-primary group-hover:scale-110 transition-all duration-300 ring-1 ring-primary/20">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-10 w-10 text-primary group-hover:text-white transition-colors"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                set:html={item.icon}
              />
            </div>

            <h3 class="font-montserrat text-xl font-bold text-gray-900 mb-3 tracking-wide">
              {item.title}
            </h3>
            <p class="text-sm text-gray-600 leading-relaxed max-w-xs">
              {item.desc}
            </p>
          </div>
        ))
      }
    </div>

    <!-- 3. ТЕКСТ (На всю ширину с акцентами) -->
    <div class="w-full space-y-6 reveal-hidden mb-16 text-left">
      {
        textBlocks.map((text) => (
          <p class="text-lg text-gray-700 leading-relaxed font-inter">
            <span class="font-bold text-primary">ANRO TRIP</span>{' '}
            {text.replace('ANRO TRIP', '').replace(/^— /, '')}
          </p>
        ))
      }

      <p class="text-xl font-medium text-gray-800 mt-8">
        <a
          href="#contacts"
          class="text-primary font-bold hover:underline decoration-2 underline-offset-4 transition-all"
        >
          Свяжитесь с нами
        </a>
        любым удобным способом, и у вас появится личный
        <span class="text-primary font-bold">travel-ассистент</span>!
      </p>
    </div>

    <!-- 4. КНОПКИ (Коммерческое предложение) -->
    <div
      class="flex flex-col md:flex-row items-center justify-center gap-6 mb-24 reveal-hidden"
    >
      <a
        href="#contacts"
        class="w-full md:w-auto px-8 py-5 rounded-full bg-primary text-white font-bold text-sm tracking-widest uppercase shadow-lg shadow-primary/30 hover:bg-primary-dark hover:-translate-y-1 transition-all duration-300"
      >
        Персональный travel-ассистент
      </a>

      <a
        href="#"
        class="w-full md:w-auto px-8 py-5 rounded-full border-2 border-primary text-primary font-bold text-sm tracking-widest uppercase hover:bg-primary hover:text-white hover:-translate-y-1 transition-all duration-300"
      >
        Ознакомиться с коммерческим предложением
      </a>
    </div>

    <!-- 5. НАПРАВЛЕНИЯ РАБОТЫ (Сетка 2x2) -->
    <div class="mb-20">
      <h2
        class="font-montserrat text-4xl font-extrabold text-center text-gray-900 mb-16 reveal-hidden tracking-wide"
      >
        Направления работы <span class="text-primary">ANRO TRIP</span>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-16">
        {
          directions.map((item) => (
            <div class="flex gap-6 items-start group reveal-hidden">
              {/* Иконка */}
              <div class="shrink-0 w-20 h-20 rounded-full bg-primary flex items-center justify-center shadow-lg shadow-primary/30 group-hover:scale-110 transition-transform duration-300">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-10 w-10 text-white"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  set:html={item.icon}
                />
              </div>

              {/* Текст */}
              <div>
                <h3 class="font-montserrat text-xl font-bold text-gray-900 mb-3 tracking-wide">
                  {item.title.includes('travel-ассистент') ? (
                    <span>
                      Личный <span class="text-primary">travel-ассистент</span>
                    </span>
                  ) : (
                    item.title
                  )}
                </h3>
                <p class="text-gray-600 leading-relaxed text-sm">
                  {item.desc.split('ANRO TRIP').map((part, index, array) => (
                    <>
                      {part}
                      {index < array.length - 1 && (
                        <span class="font-bold text-primary">ANRO TRIP</span>
                      )}
                    </>
                  ))}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- 6. РЕЕСТРЫ -->
    <div class="flex flex-col items-center gap-4 reveal-hidden">
      <div
        class="px-10 py-4 rounded-full bg-[#0e7490] text-white font-bold text-sm uppercase tracking-wider shadow-md hover:bg-[#155e75] transition-colors cursor-default w-full md:w-auto text-center"
      >
        ANRO TRIP в реестре туроператоров РТО 022708
      </div>
      <div
        class="px-10 py-4 rounded-full bg-[#0e7490] text-white font-bold text-sm uppercase tracking-wider shadow-md hover:bg-[#155e75] transition-colors cursor-default w-full md:w-auto text-center"
      >
        ANRO TRIP в реестре турагентов РТА 0024615
      </div>
    </div>
  </div>
</section>
