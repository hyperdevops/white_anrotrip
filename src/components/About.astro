---
const features = [
  {
    title: 'Индивидуальный подход',
    desc: 'Мы не продаем туры, мы создаем путешествия. Подберем идеальный маршрут под ваши желания и бюджет.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />`,
  },
  {
    title: 'Поддержка 24/7',
    desc: 'Вы никогда не останетесь одни в чужой стране. Наш консьерж-сервис на связи в любое время дня и ночи.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  },
  {
    title: 'Гарантия лучшей цены',
    desc: 'Работаем напрямую с принимающими сторонами и отелями, исключая лишних посредников и наценки.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  },
  {
    title: 'Проверенные отели',
    desc: 'Лично инспектируем отели и курорты. Рекомендуем только то, где отдыхали бы сами.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  },
];
---

<section id="about" class="py-20 relative overflow-hidden">
  <div class="container mx-auto px-4">
    <!-- Заголовок -->
    <div class="text-center mb-16 reveal-hidden">
      <h2
        class="font-montserrat text-3xl font-extrabold text-gray-900 sm:text-4xl"
      >
        Почему выбирают <span class="text-primary"
          >ANRO TRIP</span
        >
      </h2>
      <p
        class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto"
      >
        Более 10 лет мы открываем мир для наших туристов, создавая незабываемые
        впечатления и комфорт в каждой детали.
      </p>
    </div>

    <!-- Сетка преимуществ -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        features.map((item, index) => (
          <div
            class:list={[
              'group p-8 rounded-3xl bg-white transition-all duration-300',
              'border border-gray-100',
              'hover:border-primary/20',
              'deep-shadow hover:-translate-y-2', // Наша тень и эффект подъема
              'reveal-hidden',
              index % 2 !== 0 ? 'delay-100' : '', // Шахматная задержка появления
            ]}
          >
            {/* Иконка */}
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-6 group-hover:bg-primary group-hover:scale-110 transition-all duration-300">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-7 w-7 text-primary group-hover:text-white transition-colors"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                set:html={item.icon}
              />
            </div>

            {/* Текст */}
            <h3 class="font-montserrat text-xl font-bold text-gray-900 mb-3">
              {item.title}
            </h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              {item.desc}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
