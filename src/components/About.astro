---
// src/components/About.astro
import TrustBadges from './TrustBadges.astro';

const services = [
  {
    title: 'Авиа и ж/д билеты',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />`,
  },
  {
    title: 'Бронирование отелей',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`,
  },
  {
    title: 'Туры',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  },
  {
    title: 'Визовая поддержка',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" />`,
  },
  {
    title: 'Трансфер',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />`,
  },
  {
    title: 'Страховка',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />`,
  },
];

const directions = [
  {
    num: '01',
    title: 'Корпоративное обслуживание',
    desc: 'ANRO TRIP полностью возьмёт на себя организацию командировок вашей компании. Заключаем договор на индивидуальных условиях. Предоставляем отчётные документы через ЭДО.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />`,
    accent: 'bg-primary',
  },
  {
    num: '02',
    title: 'Авиабилеты',
    desc: 'Круглосуточный доступ к системам бронирования. Оформим, поменяем или вернём билет по вашей просьбе в считанные минуты.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />`,
    accent: 'bg-secondary',
  },
  {
    num: '03',
    title: 'Личный travel-ассистент',
    desc: 'За вами закрепляется персональный помощник, который учтёт все пожелания и поможет в форс-мажорных ситуациях.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />`,
    accent: 'bg-cta',
  },
  {
    num: '04',
    title: 'Визовая поддержка',
    desc: 'Сопровождаем подготовку полного пакета документов для подачи в визовый центр. Работаем со всеми направлениями.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    accent: 'bg-primary',
  },
];

export interface Props {
  class?: string;
}
const { class: classes = '' } = Astro.props;
---

<section id="about" class={`relative overflow-hidden bg-white ${classes}`}>

  <!-- ══════════════════════════════════════════════
       БЛОК 1 — HERO-ЗАЯВЛЕНИЕ (асимметричный)
  ══════════════════════════════════════════════ -->
  <div class="relative pt-12 pb-20 md:pt-20 md:pb-24 bg-white overflow-hidden">
    <!-- Декор: большая буква фоном -->
    <div class="absolute right-0 top-1/2 -translate-y-1/2 text-[25rem] font-montserrat font-black text-gray-50 leading-none select-none pointer-events-none -mr-16 hidden lg:block">A</div>

    <div class="container mx-auto px-4 sm:px-6 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-12 lg:gap-20 items-center">

        <!-- Левая часть: текст -->
        <div class="reveal-hidden">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/8 border border-primary/15 mb-6">
            <span class="w-1.5 h-1.5 rounded-full bg-primary md:animate-pulse"></span>
            <span class="text-xs font-semibold text-primary uppercase tracking-widest font-montserrat">О компании</span>
          </div>

          <h2 class="font-montserrat font-extrabold text-gray-900 uppercase tracking-tight mb-6 leading-[0.95]" style="font-size: clamp(2.5rem, 2rem + 4vw, 5rem);">
            Почему<br />
            выбирают<br />
            <span class="text-primary">ANRO TRIP</span>
          </h2>

          <p class="text-gray-500 text-lg leading-relaxed max-w-lg mb-8">
            Консьерж-сервис по организации путешествий и командировок
            по всему миру. <strong class="text-gray-800 font-semibold">18 лет</strong> безупречной репутации
            и <br class="md:hidden" /><strong class="text-gray-800 font-semibold">14 000+</strong> довольных клиентов.
          </p>

          <!-- Быстрые теги -->
          <div class="flex flex-wrap gap-2">
            {['ТОП-10 России', 'РТО 022708', '24/7 поддержка', 'Личный ассистент'].map(tag => (
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-600 hover:bg-primary/10 hover:text-primary transition-colors cursor-default">
                {tag}
              </span>
            ))}
          </div>
        </div>

        <!-- Правая часть: Trust Badges -->
        <div class="lg:min-w-[420px] reveal-hidden">
          <TrustBadges />
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════
       БЛОК 2 — УСЛУГИ (пилюли)
  ══════════════════════════════════════════════ -->
  <div class="py-10 bg-gray-50 border-y border-gray-100 overflow-hidden reveal-hidden">
    <div class="container mx-auto px-4 sm:px-6 max-w-7xl">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest font-montserrat mb-5 text-center">Что мы делаем</p>
      <div class="flex flex-wrap justify-center gap-3">
        {services.map((item) => (
          <div class="about-services-pill flex items-center gap-2.5 px-5 py-3 rounded-full bg-white border border-gray-200 cursor-default group">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 text-primary shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.8"
              set:html={item.icon}
            />
            <span class="text-sm font-medium text-gray-700 group-hover:text-gray-900 whitespace-nowrap">{item.title}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════
       БЛОК 3 — BENTO ПРЕИМУЩЕСТВА
  ══════════════════════════════════════════════ -->
  <div class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 sm:px-6 max-w-7xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4" data-reveal-stagger>

        <!-- Карточка 1: большая — «Быстро развиваемся» -->
        <div class="reveal-hidden md:col-span-2 relative overflow-hidden rounded-3xl bg-linear-to-br from-primary to-secondary p-8 md:p-10 text-white min-h-[240px] flex flex-col justify-between group max-sm:[content-visibility:auto]">
          <div class="absolute -right-10 -top-10 w-48 h-48 rounded-full bg-white/10 pointer-events-none"></div>
          <div class="absolute -right-4 -bottom-8 w-32 h-32 rounded-full bg-white/5 pointer-events-none"></div>
          <div>
            <div class="w-12 h-12 rounded-2xl bg-white/20 flex items-center justify-center mb-6 group-hover:bg-white/30 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            <h3 class="font-montserrat font-bold text-2xl mb-3 leading-tight">Быстро развиваемся</h3>
            <p class="text-white/80 leading-relaxed">Входим в <strong class="text-white">ТОП-10 компаний России</strong> по результатам 2026 года. Ежегодно увеличиваем объём и расширяем географию.</p>
          </div>
          <div class="flex items-center gap-2 mt-6 text-white/60 text-sm font-medium">
            <span class="w-8 h-px bg-white/40"></span>
            Топ-10 России 2026
          </div>
        </div>

        <!-- Карточка 2: маленькая — «Всегда на связи» -->
        <div class="reveal-hidden relative overflow-hidden rounded-3xl bg-gray-900 p-8 text-white min-h-[240px] flex flex-col justify-between group max-sm:[content-visibility:auto]">
          <div class="absolute inset-0 bg-linear-to-br from-gray-900 to-gray-800 pointer-events-none"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 rounded-2xl bg-primary/20 flex items-center justify-center mb-6 group-hover:bg-primary/30 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-montserrat font-bold text-xl mb-3">Всегда на связи</h3>
            <p class="text-gray-400 text-sm leading-relaxed">Круглосуточная поддержка клиентов — 24/7, без выходных и праздников.</p>
          </div>
          <div class="relative z-10 mt-6">
            <span class="inline-block px-3 py-1 rounded-full bg-primary/15 text-primary text-xs font-bold">24 / 7</span>
          </div>
        </div>

        <!-- Карточка 3: широкая — «Собственная авиакасса» -->
        <div class="about-avia-card reveal-hidden md:col-span-3 relative overflow-hidden rounded-3xl bg-gray-50 border border-gray-100 p-8 md:p-10 min-h-[180px] flex flex-col md:flex-row md:items-center gap-8 group transition-all duration-normal max-sm:[content-visibility:auto] max-sm:transition-none">
          <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center shrink-0 group-hover:bg-primary transition-colors duration-normal">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-primary group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="font-montserrat font-bold text-xl text-gray-900 mb-2">Собственная авиакасса</h3>
            <p class="text-gray-500 leading-relaxed max-w-2xl">Бронируем любые направления и быстро осуществляем обмен и возврат в собственных <strong class="text-gray-700">GDS-пультах</strong>. Прямой доступ к тарифам без посредников.</p>
          </div>
          <div class="shrink-0 hidden md:flex items-center gap-3">
            <span class="text-5xl font-montserrat font-black text-gray-100">GDS</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════
       БЛОК 4 — НАПРАВЛЕНИЯ РАБОТЫ (нумерованный список)
  ══════════════════════════════════════════════ -->
  <div class="py-16 md:py-24 bg-gray-50 border-t border-gray-100">
    <div class="container mx-auto px-4 sm:px-6 max-w-7xl">

      <!-- Заголовок — асимметричный -->
      <div class="flex flex-col md:flex-row md:items-end gap-6 mb-14 md:mb-16 reveal-hidden">
        <div class="flex-1">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-secondary/8 border border-secondary/15 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-secondary md:animate-pulse"></span>
            <span class="text-xs font-semibold text-secondary uppercase tracking-widest font-montserrat">Направления</span>
          </div>
          <h2 class="font-montserrat font-extrabold text-gray-900 uppercase tracking-tight leading-none" style="font-size: clamp(2rem, 1.5rem + 3vw, 4rem);">
            Направления<br />работы<br />
            <span class="text-primary">ANRO TRIP</span>
          </h2>
        </div>
        <p class="text-gray-500 max-w-xs text-sm leading-relaxed md:pb-2">
          Полный цикл организации путешествий — от идеи до возвращения домой
        </p>
      </div>

      <!-- Список направлений -->
      <div class="space-y-0">
        {directions.map((item) => (
          <div class="reveal-hidden group flex items-start gap-6 md:gap-10 py-8 border-b border-gray-200 last:border-0 hover:bg-white hover:px-6 hover:-mx-6 hover:rounded-2xl transition-all duration-normal">

            <!-- Номер: фиксированная ширина + tabular-nums для выравнивания (web-standards) -->
            <div class="shrink-0 w-20 md:w-28 font-montserrat font-black text-5xl md:text-7xl text-gray-100 group-hover:text-primary/20 transition-colors leading-none select-none pt-1 tabular-nums self-start whitespace-nowrap">
              {item.num}
            </div>

            <!-- Контент -->
            <div class="flex-1 flex flex-col md:flex-row md:items-start gap-4 md:gap-8 min-w-0 self-start">
              <!-- Иконка -->
              <div class={`shrink-0 w-12 h-12 rounded-2xl ${item.accent} flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform duration-normal`}>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6 text-white"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.8"
                  set:html={item.icon}
                />
              </div>

              <!-- Текст -->
              <div class="flex-1">
                <h3 class="font-montserrat font-bold text-xl text-gray-900 mb-2 group-hover:text-primary transition-colors">
                  {item.title}
                </h3>
                <p class="text-gray-500 leading-relaxed text-sm max-w-2xl">{item.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════
       БЛОК 5 — CTA (тёмная полоса)
  ══════════════════════════════════════════════ -->
  <div class="relative overflow-hidden bg-gray-900 py-14 md:py-20 reveal-hidden">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-none md:blur-3xl pointer-events-none -translate-y-1/2"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-secondary/10 rounded-full blur-none md:blur-3xl pointer-events-none translate-y-1/2"></div>

    <div class="container mx-auto px-4 sm:px-6 max-w-7xl relative z-10">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-8">

        <div class="text-center lg:text-left">
          <p class="text-gray-400 text-sm uppercase tracking-widest font-montserrat mb-3">Начните прямо сейчас</p>
          <h3 class="font-montserrat font-extrabold text-white text-2xl md:text-3xl leading-tight">
            Свяжитесь с нами —<br />
            <span class="text-primary">получите личного travel-ассистента</span>
          </h3>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 shrink-0">
          <a
            href="https://wa.me/79220267059"
            class="about-cta-btn inline-flex items-center justify-center gap-2.5 px-7 py-4 rounded-full bg-primary text-white font-bold font-montserrat text-sm uppercase tracking-wider shadow-[0_4px_24px_rgba(0,171,179,0.4)] hover:bg-primary-dark active:scale-[0.98] active:translate-y-0.5 btn-magnetic btn-ripple focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 cursor-pointer"
          >
            Персональный ассистент
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a
            href={`${import.meta.env.BASE_URL}corp`}
            class="about-cta-btn inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full border border-white/20 text-white font-semibold font-montserrat text-sm uppercase tracking-wider shadow-[0_4px_24px_rgba(0,171,179,0.4)] hover:bg-white/10 active:scale-[0.98] active:translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-gray-900 cursor-pointer"
          >
            Коммерческое Предложение
          </a>
        </div>
      </div>
    </div>
  </div>

</section>
