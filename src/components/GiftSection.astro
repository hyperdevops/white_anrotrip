---
// src/components/GiftSection.astro
---

<section class="py-20 bg-[#262626] text-white relative overflow-hidden group">
  <!-- Декоративный фон (пятно света) -->
  <div
    class="absolute top-0 right-0 w-125 h-125 bg-secondary/20 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/2 pointer-events-none"
  >
  </div>

  <div class="container mx-auto px-4 max-w-7xl relative z-10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-12">
      <!-- ЛЕВАЯ ЧАСТЬ: Текст и Кнопка -->
      <div class="text-center md:text-left max-w-xl">
        <h2
          class="font-montserrat text-3xl md:text-4xl font-extrabold uppercase tracking-wider mb-4 leading-tight"
        >
          Подарочный <br /><span class="text-primary">сертификат</span>
        </h2>
        <p class="text-gray-300 text-lg mb-10 font-inter">
          Лучший подарок — это путешествие! <br />
          Подарите близким эмоции, которые останутся с ними навсегда.
        </p>

        <button
          onclick="openGiftModal()"
          class="inline-block px-12 py-4 rounded-full bg-secondary text-white border-2 border-secondary font-bold uppercase tracking-wider shadow-lg shadow-cyan-900/20 hover:bg-white hover:text-secondary hover:-translate-y-1 transition-all duration-300 cursor-pointer"
        >
          Купить сертификат
        </button>
      </div>

      <!-- ПРАВАЯ ЧАСТЬ: Изображение карты -->
      <!-- При клике на картинку тоже открывается форма -->
      <div
        class="relative w-full max-w-md cursor-pointer perspective-1000"
        onclick="openGiftModal()"
      >
        <!-- Эффект парения при наведении -->
        <div
          class="transition-transform duration-500 transform group-hover:rotate-2 group-hover:scale-105 group-hover:-translate-y-2"
        >
          <!-- ЗАГЛУШКА КАРТЫ -->
          <!-- Заменить этот DIV на тег <img src="..." /> -->
          <!-- <img
					src="/images/my-gift-card.png"
					alt="Подарочная карта"
					class="w-full h-auto rounded-2xl shadow-2xl"
				/> -->
          <div
            class="w-full aspect-[1.58/1] bg-linear-to-br from-gray-100 to-gray-300 rounded-2xl shadow-2xl border border-white/10 flex items-center justify-center relative overflow-hidden"
          >
            <!-- Логотип-заглушка -->
            <div class="text-center opacity-50">
              <span
                class="font-montserrat font-bold text-2xl text-gray-800 tracking-widest"
                >ANRO TRIP</span
              >
              <div class="w-full h-px bg-gray-400 my-2"></div>
              <span class="text-xs text-gray-600 uppercase">Gift Card</span>
            </div>

            <!-- Блик -->
            <div
              class="absolute inset-0 bg-linear-to-tr from-transparent via-white/40 to-transparent translate-x-[-150%] group-hover:translate-x-[150%] transition-transform duration-1000 ease-in-out"
            >
            </div>
          </div>

          <!-- Тень под картой -->
          <div
            class="absolute -bottom-6 left-10 right-10 h-4 bg-black/50 blur-xl rounded-full opacity-60"
          >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .perspective-1000 {
    perspective: 1000px;
  }
</style>
