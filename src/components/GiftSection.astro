---
// src/components/GiftSection.astro
import { Image } from 'astro:assets';
import certifImg from '../assets/certif/certif.webp';
---

<section class="relative py-16 md:py-24 bg-gray-950 text-white overflow-hidden">
  <!-- Декоративные орбы -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-cta/6 rounded-full blur-3xl pointer-events-none translate-x-1/3 -translate-y-1/3"></div>
  <div class="absolute bottom-0 left-0 w-80 h-80 bg-primary/8 rounded-full blur-3xl pointer-events-none -translate-x-1/3 translate-y-1/3"></div>
  <!-- Сеточный фон -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.025)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.025)_1px,transparent_1px)] bg-[size:60px_60px] pointer-events-none"></div>

  <div class="container mx-auto px-4 sm:px-6 max-w-7xl relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Левая часть: текст -->
      <div class="reveal-hidden">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-cta/10 border border-cta/20 mb-6">
          <svg class="w-3.5 h-3.5 text-cta" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20 12V22H4V12M22 7H2V12H22V7ZM12 22V7M12 7H7.5C6.12 7 5 5.88 5 4.5S6.12 2 7.5 2C9.47 2 12 4 12 4M12 7H16.5C17.88 7 19 5.88 19 4.5S17.88 2 16.5 2C14.53 2 12 4 12 4"/>
          </svg>
          <span class="text-xs font-semibold text-cta uppercase tracking-widest font-montserrat">Подарочный сертификат</span>
        </div>

        <h2 class="font-montserrat font-extrabold uppercase tracking-tight leading-[0.95] mb-6" style="font-size: clamp(2.2rem, 1.8rem + 3vw, 4.5rem);">
          Лучший<br />подарок —<br />
          <span class="text-cta">путешествие</span>
        </h2>

        <p class="text-white/60 text-lg leading-relaxed mb-8 max-w-md">
          Подарите близким эмоции, которые останутся с ними навсегда. Сертификат на любую сумму — для туров, авиабилетов или отелей.
        </p>

        <!-- Фичи -->
        <div class="space-y-3 mb-10">
          {[
            'На любую сумму от 5 000 ₽',
            'Действителен 12 месяцев',
            'Оформление за 15 минут',
            'Доставка на email или в офис',
          ].map(f => (
            <div class="flex items-center gap-3">
              <div class="w-5 h-5 rounded-full bg-cta/15 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-cta" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span class="text-white/70 text-sm">{f}</span>
            </div>
          ))}
        </div>

        <button
          onclick="openGiftModal()"
          class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-cta text-gray-900 font-extrabold text-sm uppercase tracking-wider shadow-[0_4px_24px_rgba(255,212,23,0.35)] hover:shadow-[0_6px_36px_rgba(255,212,23,0.55)] hover:-translate-y-0.5 active:translate-y-0 transition-all duration-300 btn-magnetic btn-ripple cursor-pointer"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20 12V22H4V12M22 7H2V12H22V7ZM12 22V7M12 7H7.5C6.12 7 5 5.88 5 4.5S6.12 2 7.5 2C9.47 2 12 4 12 4M12 7H16.5C17.88 7 19 5.88 19 4.5S17.88 2 16.5 2C14.53 2 12 4 12 4"/>
          </svg>
          Приобрести сертификат
        </button>
      </div>

      <!-- Правая часть: карта сертификата -->
      <div class="reveal-hidden flex items-center justify-center" onclick="openGiftModal()">
        <div class="relative w-full max-w-[480px] cursor-pointer group">
          <!-- Тень/свечение -->
          <div class="absolute -inset-4 bg-cta/10 rounded-3xl blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

          <!-- Карта -->
          <div class="relative rounded-2xl overflow-hidden shadow-2xl group-hover:scale-[1.02] group-hover:-translate-y-2 transition-transform duration-500">
            <Image
              src={certifImg}
              alt="Подарочный сертификат ANRO TRIP"
              class="w-full h-auto object-cover"
              loading="lazy"
            />
            <!-- Shine sweep -->
            <div class="absolute inset-0 bg-linear-to-tr from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-900 ease-in-out pointer-events-none"></div>
          </div>

          <!-- Тень под картой -->
          <div class="absolute -bottom-4 left-8 right-8 h-6 bg-cta/20 blur-xl rounded-full pointer-events-none"></div>
        </div>
      </div>
    </div>
  </div>
</section>
