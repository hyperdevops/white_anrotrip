---
// src/components/Awards.astro
import { Image } from 'astro:assets';
import leftAward   from '../assets/awards/left_awards.webp';
import centerAward from '../assets/awards/center_awards.webp';
import rightAward  from '../assets/awards/right_awards.webp';

const awards = [
  {
    title: '«Маэстро путешествий»',
    image: leftAward,
    rank: '9 место по России',
    accent: 'bg-amber-400',
    description: `По итогам 2026 года на четвёртой премии «Маэстро путешествий» от холдинга «Русский Экспресс» ANRO TRIP заняли:`,
    results: [
      { place: '1 место', geo: 'по УрФО' },
      { place: '2 место', geo: 'среди регионов России' },
      { place: '9 место', geo: 'по всей России' },
    ],
  },
  {
    title: 'MAXX ROYAL',
    image: centerAward,
    rank: '2 место по УрФО',
    accent: 'bg-violet-500',
    description: `По итогам 2026 года на церемонии MAXX ROYAL ANRO TRIP заняли 2 место по УрФО. Первое участие в церемонии — и сразу такая высокая награда!`,
    results: [
      { place: '2 место', geo: 'по УрФО' },
    ],
  },
  {
    title: 'NG PHASELIS BAY',
    image: rightAward,
    rank: 'Best Seller 3 года подряд',
    accent: 'bg-emerald-500',
    description: `По итогам 2026 года прошла четвёртая церемония в отеле NG PHASELIS BAY. ANRO TRIP третий год подряд получают звание «Best Seller».`,
    results: [
      { place: 'Best Seller', geo: '3 года подряд' },
    ],
  },
];
---

<section id="awards" class="relative py-16 md:py-24 bg-white overflow-hidden">
  <!-- Декор -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-cta/5 rounded-full blur-3xl pointer-events-none translate-x-1/2 -translate-y-1/2"></div>

  <div class="container mx-auto px-4 sm:px-6 max-w-7xl">

    <!-- Заголовок -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14 md:mb-16 reveal-hidden">
      <div>
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-cta/10 border border-cta/20 mb-5">
          <svg class="w-3.5 h-3.5 text-cta" fill="currentColor" viewBox="0 0 24 24">
            <path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
          </svg>
          <span class="text-xs font-semibold text-yellow-600 uppercase tracking-widest font-montserrat">Награды</span>
        </div>
        <h2 class="font-montserrat font-extrabold text-gray-900 uppercase tracking-tight leading-[1.0]" style="font-size: clamp(2rem, 1.5rem + 3vw, 4rem);">
          Награды<br />
          <span class="text-primary">ANRO TRIP 2026</span>
        </h2>
      </div>
      <p class="text-gray-400 text-sm max-w-xs leading-relaxed md:pb-2">
        Признание профессионального сообщества и крупнейших туристических холдингов России
      </p>
    </div>

    <!-- Карточки наград -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6" data-reveal-stagger>
      {awards.map((award, index) => (
        <div class:list={[
          'reveal-hidden group relative bg-white rounded-3xl overflow-hidden border border-gray-100 hover:border-primary/20 hover:shadow-2xl hover:-translate-y-2 transition-all duration-400',
          index === 1 ? 'md:mt-8' : '',
        ]}>
          <!-- Фото -->
          <div class="relative overflow-hidden aspect-[4/3] bg-gray-50">
            <Image
              src={award.image}
              alt={award.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <!-- Тонкий оверлей -->
            <div class="absolute inset-0 bg-linear-to-t from-black/30 to-transparent pointer-events-none"></div>
            <!-- Бейдж места -->
            <div class="absolute bottom-3 left-3">
              <span class:list={['inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-black uppercase tracking-wide text-white shadow-lg', award.accent]}>
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                </svg>
                {award.rank}
              </span>
            </div>
          </div>

          <!-- Контент -->
          <div class="p-6">
            <h3 class="font-montserrat font-extrabold text-gray-900 text-lg mb-3 uppercase tracking-wide">{award.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-4">{award.description}</p>

            <!-- Результаты -->
            <div class="space-y-2">
              {award.results.map(r => (
                <div class="flex items-center gap-3">
                  <span class:list={['shrink-0 w-2 h-2 rounded-full', award.accent]}></span>
                  <span class="font-bold text-gray-900 text-sm">{r.place}</span>
                  <span class="text-gray-400 text-xs">{r.geo}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
