---
// src/components/Awards.astro

// ДАННЫЕ НАГРАД
// Замени 'src' на пути к своим картинкам в папке /public/
const awards = [
  {
    title: '«Маэстро путешествий»',
    src: 'https://placehold.co/600x600/EEE/31343C?text=Maestro+Award', // <-- СЮДА КАРТИНКУ 1
    description: `
      По итогам 2024 года на четвертой премии <span class="font-bold">«Маэстро путешествий»</span> от холдинга «Русский Экспресс» ANRO TRIP заняли:
      <ul class="list-disc list-inside mt-4 space-y-1 ml-1">
        <li><span class="font-bold text-primary">1 место</span> по УрФО</li>
        <li><span class="font-bold text-primary">2 место</span> среди регионов (учитываются все регионы кроме Москвы)</li>
        <li><span class="font-bold text-primary">9 место</span> по всей России (в 2023 году мы стали впервые участниками премии и заняли 20 место по России)</li>
      </ul>
    `
  },
  {
    title: 'MAXX ROYAL',
    src: 'https://placehold.co/600x600/EEE/31343C?text=Maxx+Royal', // <-- СЮДА КАРТИНКУ 2
    description: `
      По итогам 2024 года на церемонии <span class="font-bold">MAXX ROYAL</span><br/>
      ANRO TRIP заняли <span class="font-bold text-primary">2 место по УрФО</span>.
      <br/><br/>
      Первое участие в церемонии и такая высокая награда!
    `
  },
  {
    title: 'NG PHASELIS BAY',
    src: 'https://placehold.co/600x600/EEE/31343C?text=NG+Phaselis', // <-- СЮДА КАРТИНКУ 3
    description: `
      По итогам 2024 года прошла четвертая церемония награждения в прекрасном отеле <span class="font-bold">NG PHASELIS BAY</span>.
      <br/><br/>
      ANRO TRIP третий год подряд стали участниками церемонии и в третий раз получили звание <span class="font-bold text-primary">"Best Seller"</span>.
    `
  }
];
---

<section id="awards" class="py-20 bg-white relative overflow-hidden border-t border-gray-100">
  <div class="container mx-auto px-4 max-w-7xl">

    <!-- Заголовок -->
    <h2 class="font-montserrat text-3xl font-extrabold text-center text-gray-900 mb-16 reveal-hidden uppercase tracking-wider">
      Награды <span class="text-primary">ANRO TRIP 2024</span>
    </h2>

    <!-- Сетка наград -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
      {awards.map((item, index) => (
        <div
          class:list={[
            'group bg-white rounded-3xl p-6 border border-gray-100 transition-all duration-300',
            'hover:shadow-2xl hover:border-primary/20 hover:-translate-y-2', // Эффект карточки
            'reveal-hidden',
            index === 1 ? 'delay-100' : index === 2 ? 'delay-200' : ''
          ]}
        >
          <!-- Картинка -->
          <div class="relative overflow-hidden rounded-2xl mb-6 aspect-square bg-gray-50">
            <img
              src={item.src}
              alt={item.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <!-- Легкий блик при наведении -->
            <div class="absolute inset-0 bg-white/0 group-hover:bg-white/10 transition-colors duration-300 pointer-events-none"></div>
          </div>

          <!-- Контент -->
          <div class="space-y-4">
            <div class="text-sm text-gray-600 leading-relaxed font-inter" set:html={item.description} />
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
