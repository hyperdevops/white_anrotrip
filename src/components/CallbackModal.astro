---
// src/components/CallbackModal.astro
import Modal from './ui/Modal.astro'; // Убедитесь, что создали Modal.astro в папке src/components/ui/
---

<Modal id="callback-modal" title="Заказать обратный звонок">
  <form
    class="space-y-4"
    onsubmit="event.preventDefault(); alert('Спасибо! Мы скоро свяжемся с вами.'); this.reset(); document.getElementById('callback-modal').close();"
  >
    <div>
      <label
        class="block text-sm font-medium text-gray-700 mb-1"
        >Как к вам обращаться?</label
      >
      <input
        type="text"
        required
        placeholder="Иван"
        class="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-gray-900 focus:ring-2 focus:ring-[#04a5e5] focus:border-transparent outline-none transition-all placeholder:text-gray-400"
      />
    </div>

    <div>
      <label
        class="block text-sm font-medium text-gray-700 mb-1"
        >Номер телефона</label
      >
      <input
        type="tel"
        required
        placeholder="+7 (999) 000-00-00"
        class="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-gray-900 focus:ring-2 focus:ring-[#04a5e5] focus:border-transparent outline-none transition-all placeholder:text-gray-400"
      />
    </div>

    <div class="pt-2">
      <button
        type="submit"
        class="w-full bg-[#04a5e5] hover:bg-[#0391ca] text-white font-bold py-4 rounded-xl shadow-lg shadow-[#04a5e5]/30 transition-all duration-300 transform active:scale-95"
      >
        Перезвоните мне
      </button>
      <p class="text-xs text-center text-gray-500 mt-3">
        Нажимая кнопку, вы соглашаетесь с политикой обработки персональных
        данных
      </p>
    </div>
  </form>
</Modal>
