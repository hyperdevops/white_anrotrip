---
// src/components/CallbackModal.astro
---

<!-- ФОН (Оверлей) -->
<div
  id="callback-modal-overlay"
  class="fixed inset-0 z-2147483647 bg-black/60 backdrop-blur-sm max-md:backdrop-blur-none hidden opacity-0 transition-opacity duration-slow max-md:duration-300 max-md:ease-[cubic-bezier(0.33,1,0.68,1)]"
>
  <div class="flex min-h-full min-w-full items-center justify-center">
    <!-- КОНТЕНТ: desktop — slide up, mobile — лёгкое всплытие (translate-y-8, ease-out) -->
    <div
    class="bg-white rounded-3xl shadow-2xl shadow-black/20 max-md:shadow-lg w-full max-w-md mx-4 relative transform max-h-[90dvh] overflow-y-auto contain-[layout_paint]
      translate-y-20 max-md:translate-y-8
      transition-transform duration-slow ease-out max-md:duration-300 max-md:ease-[cubic-bezier(0.33,1,0.68,1)]
      [&.modal-open]:translate-y-0"
    id="callback-modal-content"
  >
    <!-- Крестик закрытия -->
    <button
      id="close-callback-modal"
      type="button"
      aria-label="Закрыть окно заказа звонка"
      class="absolute top-4 right-4 w-9 h-9 rounded-full bg-gray-100 hover:bg-gray-200 active:scale-[0.98] active:translate-y-0.5 flex items-center justify-center text-gray-500 hover:text-gray-800 transition-[color,background-color,transform] cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 z-10"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5 stroke-2"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path></svg
      >
    </button>

    <div class="p-8 pt-7">
      <h3
        class="font-montserrat text-xl font-extrabold text-gray-900 uppercase tracking-wide mb-1 text-center"
      >
        Заказ обратного звонка
      </h3>
      <p class="text-center text-sm text-gray-400 mb-6 wrap-break-word">
        Оставьте свои контакты,<br class="hidden sm:block" />и мы свяжемся с
        вами в ближайшее время!
      </p>

      <form
        id="callback-form"
        class="space-y-3"
        onsubmit="event.preventDefault();"
      >
        <div>
          <label class="text-xs text-gray-500 font-medium mb-1 block"
            >Ваше имя</label
          >
          <input
            name="name"
            type="text"
            placeholder="Имя"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-[border-color,box-shadow]"
          />
        </div>

        <div>
          <label class="text-xs text-gray-500 font-medium mb-1 block"
            >Ваш телефон</label
          >
          <input
            name="phone"
            type="tel"
            placeholder="+7 (999) 000-00-00"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-[border-color,box-shadow]"
          />
        </div>

        <div class="flex items-start gap-2.5 pt-1">
          <input
            name="agree"
            type="checkbox"
            id="agree-callback"
            class="mt-0.5 w-4 h-4 cursor-pointer"
          />
          <label
            for="agree-callback"
            class="text-[11px] text-gray-400 leading-snug cursor-pointer"
          >
            Даю свое согласие на обработку персональных данных в соответствии с <a
              href={`${import.meta.env.BASE_URL}privacy`}
              class="text-primary font-semibold hover:underline cursor-pointer"
              >Политикой конфиденциальности</a
            >
          </label>
        </div>

        <button
          class="w-full bg-primary text-white font-bold py-3.5 rounded-xl mt-2 hover:bg-primary-dark transition-colors cursor-pointer tracking-wide uppercase text-sm active:scale-[0.98] active:translate-y-0.5"
        >
          Заказать звонок
        </button>
      </form>
    </div>
  </div>
  </div>
</div>

<script>
  const overlay = document.getElementById('callback-modal-overlay');
  const content = document.getElementById('callback-modal-content');
  const closeBtn = document.getElementById('close-callback-modal');

  let previousActiveElement: HTMLElement | null = null;

  function getFocusables(container: HTMLElement): HTMLElement[] {
    const sel =
      'button:not([disabled]), [href], input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';
    return Array.from(container.querySelectorAll<HTMLElement>(sel)).filter(
      (el) => el.offsetParent !== null && !el.hasAttribute('aria-hidden'),
    );
  }

  function trapFocus(e: KeyboardEvent) {
    if (e.key !== 'Tab' || !content) return;
    const focusables = getFocusables(content);
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) {
        e.preventDefault();
        last.focus();
      }
    } else {
      if (document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  }

  // Глобальная функция открытия
  window.openCallbackModal = () => {
    if (overlay && content) {
      previousActiveElement = document.activeElement as HTMLElement | null;
      overlay.classList.remove('hidden');
      overlay.style.display = 'block';
      window.lockScroll();

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          content.style.willChange = 'transform';
          overlay.classList.remove('opacity-0');
          content.classList.add('modal-open');
          closeBtn?.focus();
          content.addEventListener('keydown', trapFocus);

          const onOpenEnd = () => {
            content.style.willChange = '';
          };
          content.addEventListener('transitionend', onOpenEnd, { once: true });
        });
      });
    }
  };

  // Глобальная функция закрытия
  window.closeCallbackModal = () => {
    if (overlay && content) {
      content.removeEventListener('keydown', trapFocus);
      content.style.willChange = 'transform';
      overlay.classList.add('opacity-0');
      content.classList.remove('modal-open');

      const onCloseEnd = () => {
        if (!overlay.classList.contains('opacity-0')) return;
        content.style.willChange = '';
        overlay.classList.add('hidden');
        overlay.style.display = '';
        requestAnimationFrame(() => {
          window.unlockScroll();
          previousActiveElement?.focus();
          previousActiveElement = null;
        });
      };
      content.addEventListener('transitionend', onCloseEnd, { once: true });
    }
  };

  closeBtn?.addEventListener('click', window.closeCallbackModal);
  overlay?.addEventListener('click', (e) => {
    if (content && !content.contains(e.target as Node)) window.closeCallbackModal();
  });

  // Обработка отправки формы (временно — console.log, готово к интеграции Netlify Forms/Formspree)
  const callbackForm = document.getElementById('callback-form');
  callbackForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const data = Object.fromEntries(new FormData(form).entries());
    console.log('Form submitted', data);
    window.closeCallbackModal();
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay?.classList.contains('hidden')) {
      window.closeCallbackModal();
    }
  });
</script>
