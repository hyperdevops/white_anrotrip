---
// src/components/CallbackModal.astro
---

<!-- ФОН (Оверлей) -->
<div
  id="callback-modal-overlay"
  class="fixed inset-0 z-2147483647 bg-black/60 backdrop-blur-sm hidden items-center justify-center opacity-0 transition-opacity duration-500"
>
  <!-- КОНТЕНТ (Выплывает снизу) -->
  <div
    class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 relative transform translate-y-20 transition-all duration-500 ease-out max-h-[90vh] overflow-y-auto border border-gray-100"
    id="callback-modal-content"
  >
    <!-- Крестик закрытия -->
    <button
      id="close-callback-modal"
      class="cursor-pointer absolute top-4 right-4 text-gray-400 hover:text-gray-800 p-2 focus:outline-none bg-gray-50 rounded-full hover:bg-gray-100 transition-colors z-10"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5 stroke-2"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path></svg
      >
    </button>

    <div class="p-8">
      <h3
        class="font-montserrat text-xl font-bold text-center text-secondary mb-2 uppercase"
      >
        Заказ обратного звонка
      </h3>
      <p class="text-center text-xs text-gray-500 mb-6 italic break-words">
        Оставьте свои контакты,<br class="hidden sm:block" />и мы свяжемся с вами в ближайшее время!
      </p>

      <form
        class="space-y-4"
        onsubmit="event.preventDefault(); alert('Спасибо! Мы перезвоним.'); window.closeCallbackModal();"
      >
        <div class="space-y-1">
          <label class="text-xs text-gray-500 ml-1">Ваше имя</label>
          <input
            type="text"
            placeholder="Имя"
            required
            class="w-full px-4 py-3 rounded-md border border-gray-300 focus:border-secondary focus:ring-1 focus:ring-secondary outline-none text-sm"
          />
        </div>

        <div class="space-y-1">
          <label class="text-xs text-gray-500 ml-1">Ваш телефон</label>
          <input
            type="tel"
            placeholder="+7 (999) 000-00-00"
            required
            class="w-full px-4 py-3 rounded-md border border-gray-300 focus:border-secondary focus:ring-1 focus:ring-secondary outline-none text-sm"
          />
        </div>

        <div class="flex items-start gap-2 pt-2">
          <input type="checkbox" id="agree-callback" class="mt-1" />
          <label
            for="agree-callback"
            class="text-[10px] text-gray-500 leading-tight"
          >
            Даю свое согласие на обработку персональных данных в соответствии с <a
              href="#"
              class="text-secondary font-bold hover:underline"
              >Политикой конфиденциальности</a
            >
          </label>
        </div>

        <button
          class="cursor-pointer w-full bg-secondary text-white border-2 border-secondary font-bold py-3 rounded-md mt-4 hover:bg-white hover:text-secondary transition-all uppercase tracking-wider shadow-lg shadow-cyan-900/20"
        >
          Заказать звонок
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  const overlay = document.getElementById('callback-modal-overlay');
  const content = document.getElementById('callback-modal-content');
  const closeBtn = document.getElementById('close-callback-modal');

  // Утилита скрытия хедера (чтобы не перекрывал)
  function toggleHeader(hide: boolean) {
    const header = document.querySelector('header');
    if (header) {
      header.style.transition = 'opacity 0.5s';
      header.style.opacity = hide ? '0' : '1';
      header.style.pointerEvents = hide ? 'none' : 'auto';
    }
  }

  // Глобальная функция открытия
  window.openCallbackModal = () => {
    if (overlay && content) {
      overlay.classList.remove('hidden');
      overlay.style.display = 'flex';

      toggleHeader(true);

      setTimeout(() => {
        overlay.classList.remove('opacity-0');
        content.classList.remove('translate-y-20');
        content.classList.add('translate-y-0');
      }, 10);
      window.lockScroll();
    }
  };

  // Глобальная функция закрытия
  window.closeCallbackModal = (event) => {
    if (overlay && content) {
      overlay.classList.add('opacity-0');
      content.classList.remove('translate-y-0');
      content.classList.add('translate-y-20');

      setTimeout(() => {
        overlay.classList.add('hidden');
        overlay.style.display = 'none';
        window.unlockScroll();
        toggleHeader(false);
      }, 500);
    }
  };

  closeBtn?.addEventListener('click', window.closeCallbackModal);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) window.closeCallbackModal();
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay?.classList.contains('hidden')) {
      window.closeCallbackModal();
    }
  });
</script>
