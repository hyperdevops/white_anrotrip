---
// src/components/GiftModal.astro
import { Image } from 'astro:assets';
import certifImg from '../assets/certif/certif.webp';
---

<!-- ФОН (Оверлей) --><!-- z-index максимальный, чтобы перекрывать всё -->
<div
  id="gift-modal-overlay"
  class="fixed inset-0 z-2147483647 bg-black/60 backdrop-blur-sm hidden items-center justify-center opacity-0 transition-opacity duration-500"
>
  <!-- КОНТЕНТ (Выплывает снизу) -->
  <div
    class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 relative transform translate-y-20 transition-all duration-500 ease-out max-h-[90dvh] overflow-y-auto border border-gray-100"
    id="gift-modal-content"
  >
    <!-- Крестик закрытия -->
    <button
      id="close-gift-modal"
      class="cursor-pointer absolute top-4 right-4 text-gray-400 hover:text-gray-800 p-2 focus:outline-none bg-gray-50 rounded-full hover:bg-gray-100 transition-colors z-10"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5 stroke-2"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path></svg
      >
    </button>

    <div class="p-8">
      <h3
        class="font-montserrat text-xl font-bold text-center text-secondary mb-2 uppercase"
      >
        Подарочный сертификат
      </h3>
      <p class="text-center text-xs text-gray-500 mb-6 italic">
        Лучший подарок — это путешествие!
      </p>

      <!-- Картинка сертификата (Astro Image — оптимизация, lazy) -->
      <!-- <div class="w-full aspect-[1.58/1] rounded-xl overflow-hidden mb-8 shadow-md">
        <Image
          src={certifImg}
          alt="Подарочный сертификат ANRO TRIP"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div> -->

      <form
        class="space-y-4"
        onsubmit="event.preventDefault(); closeGiftModal();"
      >
        <p class="text-xs text-center text-gray-500 mb-5 font-inter">
          <i
            >Вы можете приобрести <strong>Подарочный сертификат</strong> на любые
            услуги туристической компании ANRO TRIP для этого заполните форму и мы
            свяжемся с Вами!</i
          >
        </p>
        <div class="space-y-1">
          <label class="text-xs text-gray-500 ml-1">Фамилия Имя Отчество</label>
          <input
            type="text"
            placeholder="ФИО"
            required
            class="w-full px-4 py-3 rounded-md border border-gray-300 focus:border-secondary focus:ring-1 focus:ring-secondary outline-none text-sm"
          />
        </div>

        <div class="space-y-1">
          <label class="text-xs text-gray-500 ml-1">Ваш телефон</label>
          <input
            type="tel"
            placeholder="+7 (999) 000-00-00"
            required
            class="w-full px-4 py-3 rounded-md border border-gray-300 focus:border-secondary focus:ring-1 focus:ring-secondary outline-none text-sm"
          />
        </div>

        <div class="space-y-1">
          <label class="text-xs text-gray-500 ml-1">Ваш e-mail</label>
          <input
            type="email"
            placeholder="example@mail.ru"
            required
            class="w-full px-4 py-3 rounded-md border border-gray-300 focus:border-secondary focus:ring-1 focus:ring-secondary outline-none text-sm"
          />
        </div>

        <div class="flex items-start gap-2 pt-2">
          <input type="checkbox" id="agree-gift" class="mt-1" />
          <label
            for="agree-gift"
            class="text-[10px] text-gray-500 leading-tight"
          >
            Даю свое согласие на обработку персональных данных в соответствии с <a
              href="#"
              class="text-secondary font-bold hover:underline"
              >Политикой конфиденциальности</a
            >
          </label>
        </div>

        <button
          class="cursor-pointer w-full bg-secondary text-white border-2 border-secondary font-bold py-3 rounded-md mt-4 hover:bg-white hover:text-secondary transition-all uppercase tracking-wider shadow-lg shadow-cyan-900/20"
        >
          Отправить
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  /**
   * Утилита скрытия хедера (такая же, как в Reviews, чтобы не было наложения)
   * @param {boolean} hide - Показать или скрыть хедер
   */
  function toggleHeader(hide: boolean) {
    const header = document.querySelector('header');
    if (header) {
      header.style.transition = 'opacity 0.5s';
      header.style.opacity = hide ? '0' : '1';
      header.style.pointerEvents = hide ? 'none' : 'auto';
    }
  }

  function openGiftModal() {
    const overlay = document.getElementById('gift-modal-overlay');
    const content = document.getElementById('gift-modal-content');

    if (overlay && content) {
      overlay.classList.remove('hidden');
      overlay.style.display = 'flex';

      toggleHeader(true); // Скрываем хедер

      setTimeout(() => {
        overlay.classList.remove('opacity-0');
        content.classList.remove('translate-y-20');
        content.classList.add('translate-y-0');
      }, 10);
      window.lockScroll();
    }
  }

  function closeGiftModal() {
    const overlay = document.getElementById('gift-modal-overlay');
    const content = document.getElementById('gift-modal-content');

    if (overlay && content) {
      overlay.classList.add('opacity-0');
      content.classList.remove('translate-y-0');
      content.classList.add('translate-y-20');

      setTimeout(() => {
        overlay.classList.add('hidden');
        overlay.style.display = 'none';
        window.unlockScroll();
        toggleHeader(false); // Возвращаем хедер
      }, 500);
    }
  }

  // Добавляем функции в глобальный объект window
  window.openGiftModal = openGiftModal;
  window.closeGiftModal = closeGiftModal;

  const closeBtn = document.getElementById('close-gift-modal');
  const overlay = document.getElementById('gift-modal-overlay');

  closeBtn?.addEventListener('click', closeGiftModal);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeGiftModal();
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay?.classList.contains('hidden')) {
      closeGiftModal();
    }
  });
</script>
