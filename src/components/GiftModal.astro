---
// src/components/GiftModal.astro
import { Image } from 'astro:assets';
import certifImg from '../assets/certif/certif.webp';
---

<!-- ФОН (Оверлей) --><!-- z-index максимальный, чтобы перекрывать всё -->
<div
  id="gift-modal-overlay"
  class="fixed inset-0 z-2147483647 bg-black/60 backdrop-blur-sm max-md:backdrop-blur-none hidden items-center justify-center opacity-0 transition-opacity duration-slow max-md:duration-300 max-md:ease-[cubic-bezier(0.33,1,0.68,1)]"
>
  <!-- КОНТЕНТ: desktop — slide up, mobile — лёгкое всплытие (translate-y-8, ease-out-expo) -->
  <div
    class="bg-white rounded-3xl shadow-2xl shadow-black/20 max-md:shadow-lg w-full max-w-md mx-4 relative transform max-h-[90dvh] overflow-y-auto contain-[layout_paint]
      translate-y-20 max-md:translate-y-8
      transition-transform duration-slow ease-out max-md:duration-300 max-md:ease-[cubic-bezier(0.33,1,0.68,1)]
      [&.modal-open]:translate-y-0"
    id="gift-modal-content"
  >
    <!-- Крестик закрытия -->
    <button
      id="close-gift-modal"
      type="button"
      aria-label="Закрыть окно подарочного сертификата"
      class="absolute top-4 right-4 w-9 h-9 rounded-full bg-gray-100 hover:bg-gray-200 flex items-center justify-center text-gray-500 hover:text-gray-800 transition-[color,background-color] cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 z-10 btn-ripple"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5 stroke-2"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path></svg
      >
    </button>

    <div class="p-8 pt-7">
      <h3
        class="font-montserrat text-xl font-extrabold text-gray-900 uppercase tracking-wide mb-1 text-center"
      >
        Подарочный сертификат
      </h3>
      <p class="text-center text-sm text-gray-400 mb-6">
        Лучший подарок — это путешествие!
      </p>

      <!-- Картинка сертификата (Astro Image — оптимизация, lazy, только desktop) -->
      <!-- <div
        class="hidden md:block w-full aspect-[1.58/1] rounded-xl overflow-hidden mb-8 shadow-md"
      >
        <Image
          src={certifImg}
          alt="Подарочный сертификат ANRO TRIP"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div> -->

      <form id="gift-form" class="space-y-3" onsubmit="event.preventDefault();">
        <p class="text-xs text-center text-gray-500 mb-5 font-inter">
          <i
            >Вы можете приобрести <strong>Подарочный сертификат</strong> на любые
            услуги туристической компании ANRO TRIP для этого заполните форму и мы
            свяжемся с Вами!</i
          >
        </p>
        <div>
          <label class="text-xs text-gray-500 font-medium mb-1 block"
            >Фамилия Имя Отчество</label
          >
          <input
            name="fio"
            type="text"
            placeholder="ФИО"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-[border-color,box-shadow]"
          />
        </div>

        <div>
          <label class="text-xs text-gray-500 font-medium mb-1 block"
            >Ваш телефон</label
          >
          <input
            name="phone"
            type="tel"
            placeholder="+7 (999) 000-00-00"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-[border-color,box-shadow]"
          />
        </div>

        <div>
          <label class="text-xs text-gray-500 font-medium mb-1 block"
            >Ваш e-mail</label
          >
          <input
            name="email"
            type="email"
            placeholder="example@mail.ru"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-[border-color,box-shadow]"
          />
        </div>

        <div class="flex items-start gap-2.5 pt-1">
          <input
            name="agree"
            type="checkbox"
            id="agree-gift"
            class="mt-0.5 w-4 h-4 cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-1"
          />
          <label
            for="agree-gift"
            class="text-[11px] text-gray-400 leading-snug cursor-pointer"
          >
            Даю свое согласие на обработку персональных данных в соответствии с <a
              href={`${import.meta.env.BASE_URL}privacy`}
              class="text-primary font-semibold hover:underline cursor-pointer"
              >Политикой конфиденциальности</a
            >
          </label>
        </div>

        <button
          class="w-full bg-primary text-white font-bold py-3.5 rounded-xl mt-2 hover:bg-primary-dark hover:shadow-lg hover:shadow-primary/30 transition-[color,box-shadow] duration-normal cursor-pointer tracking-wide uppercase text-sm btn-ripple"
        >
          Отправить
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  let previousActiveElement = null as HTMLElement | null;

  function getFocusables(container: HTMLElement) {
    const sel =
      'button:not([disabled]), [href], input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';
    return Array.from(container.querySelectorAll<HTMLElement>(sel)).filter(
      (el) => el.offsetParent !== null && !el.hasAttribute('aria-hidden'),
    );
  }

  function trapFocus(e: KeyboardEvent) {
    if (e.key !== 'Tab') return;
    const content = document.getElementById('gift-modal-content');
    if (!content) return;
    const focusables = getFocusables(content);
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) {
        e.preventDefault();
        last.focus();
      }
    } else {
      if (document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  }

  function openGiftModal() {
    const overlay = document.getElementById('gift-modal-overlay');
    const content = document.getElementById('gift-modal-content');
    const closeBtn = document.getElementById('close-gift-modal');

    if (overlay && content) {
      previousActiveElement = document.activeElement as HTMLElement | null;
      overlay.classList.remove('hidden');
      overlay.style.display = 'flex';
      window.lockScroll();

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          content.style.willChange = 'transform';
          overlay.classList.remove('opacity-0');
          content.classList.add('modal-open');
          closeBtn?.focus();
          content.addEventListener('keydown', trapFocus);

          const onOpenEnd = () => {
            content.style.willChange = '';
          };
          content.addEventListener('transitionend', onOpenEnd, { once: true });
        });
      });
    }
  }

  function closeGiftModal() {
    const overlay = document.getElementById('gift-modal-overlay');
    const content = document.getElementById('gift-modal-content');

    if (overlay && content) {
      content.removeEventListener('keydown', trapFocus);
      content.style.willChange = 'transform';
      overlay.classList.add('opacity-0');
      content.classList.remove('modal-open');

      const onCloseEnd = () => {
        if (!overlay.classList.contains('opacity-0')) return;
        content.style.willChange = '';
        overlay.classList.add('hidden');
        overlay.style.display = 'none';
        requestAnimationFrame(() => {
          window.unlockScroll();
          previousActiveElement?.focus();
          previousActiveElement = null;
        });
      };
      content.addEventListener('transitionend', onCloseEnd, { once: true });
    }
  }

  window.openGiftModal = openGiftModal;
  window.closeGiftModal = closeGiftModal;

  const closeBtn = document.getElementById('close-gift-modal');
  const overlay = document.getElementById('gift-modal-overlay');

  closeBtn?.addEventListener('click', closeGiftModal);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeGiftModal();
  });

  // Обработка отправки формы (временно — console.log, готово к интеграции Netlify Forms/Formspree)
  const giftForm = document.getElementById('gift-form');
  giftForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const data = Object.fromEntries(new FormData(form).entries());
    console.log('Form submitted', data);
    closeGiftModal();
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay?.classList.contains('hidden')) {
      closeGiftModal();
    }
  });
</script>
