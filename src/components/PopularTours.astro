---
import { Image } from 'astro:assets';
import antalyaImg  from '../assets/tours/antalya.webp';
import seychellesImg from '../assets/tours/seychelles.webp';
import thailandImg from '../assets/tours/thailand.webp';
import maldivesImg from '../assets/tours/maldives.webp';
import egyptImg    from '../assets/tours/egypt.webp';
import vietnamImg  from '../assets/tours/vietnam.webp';

export interface Props { class?: string; }
const { class: classes = '' } = Astro.props;

const tours = [
  { title: 'Мальдивы',        price: 'от 150 000 ₽', image: maldivesImg, size: 'large',  badge: 'Luxury',        badgeColor: 'bg-amber-400/90 text-amber-950' },
  { title: 'Сейшелы, Маэ',    price: 'от 180 000 ₽', image: seychellesImg, size: 'tall',   badge: 'Острова',       badgeColor: 'bg-[#0d9488]/85 text-white' },
  { title: 'Турция, Анталья', price: 'от 85 000 ₽',  image: antalyaImg,  size: 'normal', badge: 'Хит продаж',    badgeColor: 'bg-rose-500/90 text-white' },
  { title: 'Таиланд, Пхукет', price: 'от 115 000 ₽', image: thailandImg, size: 'normal', badge: 'Relax',         badgeColor: 'bg-emerald-500/80 text-white' },
  { title: 'Египет, Шарм',    price: 'от 105 000 ₽',  image: egyptImg,    size: 'wide',   badge: 'Всё включено',  badgeColor: 'bg-orange-500/90 text-white' },
  { title: 'Вьетнам, Нячанг', price: 'от 125 000 ₽',  image: vietnamImg,  size: 'wide',   badge: 'Пляжный отдых', badgeColor: 'bg-sky-500/80 text-white' },
];
---

<section id="tours" class={`pt-14 pb-10 md:pb-16 bg-[linear-gradient(to_bottom,transparent_0,rgb(240_249_255)_120px,rgb(255_255_255)_40%,rgb(249_250_251)_100%)] overflow-hidden ${classes}`}>
  <div class="@container container mx-auto px-4 sm:px-6 max-w-7xl">

    <!-- Асимметричный заголовок -->
    <div class="flex flex-col @md:flex-row @md:items-end justify-between gap-4 mb-10 md:mb-12 reveal-hidden">
      <div>
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/8 border border-primary/15 mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-primary md:animate-pulse"></span>
          <span class="text-xs font-semibold text-primary uppercase tracking-widest font-montserrat">Горящие туры</span>
        </div>
        <h2 class="font-montserrat font-extrabold text-gray-900 uppercase tracking-tight leading-none" style="font-size: clamp(2rem, 1.5rem + 3vw, 4rem);">
          Популярные<br /><span class="text-primary">направления</span>
        </h2>
      </div>
      <p class="text-gray-400 text-sm max-w-xs leading-relaxed @md:pb-2 @md:text-right">
        Лучшие предложения этого сезона.<br />Нажмите на карточку, чтобы подобрать тур.
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 @md:grid-cols-4 gap-3 md:gap-4 auto-rows-[240px] @lg:auto-rows-[270px]" data-reveal-stagger>
      {tours.map((tour) => (
        <button
          type="button"
          data-tour-title={tour.title}
          aria-label={`Подобрать тур: ${tour.title} — переход к форме поиска`}
          class:list={[
            'group relative overflow-hidden rounded-3xl cursor-pointer transition-[opacity,transform,box-shadow] duration-slow deep-shadow border border-white/10 reveal-hidden active:scale-[0.98] active:translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 [content-visibility:auto]',
            tour.size === 'large'  ? '@md:col-span-2 @md:row-span-2' : '',
            tour.size === 'tall'   ? '@md:col-span-1 @md:row-span-2' : '',
            tour.size === 'wide'   ? '@md:col-span-2 @md:row-span-1' : '',
            tour.size === 'normal' ? '@md:col-span-1 @md:row-span-1' : '',
          ]}
        >
          <!-- Фото -->
          <div class="absolute inset-0">
            <div class="absolute inset-0 tour-card-breathe">
              <Image src={tour.image} alt={tour.title}
                class="h-full w-full object-cover md:transition-transform md:duration-slow group-hover:scale-[1.04] image-sharp"
                loading="lazy"
              />
            </div>
            <!-- Градиент снизу -->
            <div class="absolute inset-0 bg-[linear-gradient(to_top,rgb(0_0_0/85%)_0%,rgb(0_0_0/25%)_50%,transparent_100%)] opacity-90 md:group-hover:opacity-70 md:transition-opacity md:duration-normal"></div>
            <!-- Легкий оверлей сверху -->
            <div class="absolute inset-0 bg-[linear-gradient(to_bottom,rgb(0_0_0/20%)_0%,transparent_40%)]"></div>
          </div>

          <!-- Контент -->
          <div class="absolute inset-0 p-5 sm:p-6 flex flex-col justify-between">
            <!-- Бейдж -->
            <div class="flex justify-between items-start">
              <span class:list={['inline-block rounded-full px-3 py-1 text-[10px] font-black uppercase tracking-wider', tour.badgeColor]}>
                {tour.badge}
              </span>
              <!-- Иконка-стрелка появляется при hover (только десктоп) -->
              <span class="hidden sm:flex w-8 h-8 rounded-full bg-white/15 items-center justify-center opacity-0 md:group-hover:opacity-100 md:transition-opacity md:duration-normal -translate-y-1 md:group-hover:translate-y-0">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </span>
            </div>

            <!-- Название и цена -->
            <div class="transform translate-y-1.5 md:group-hover:translate-y-0 md:transition-transform md:duration-normal">
              <h3 class="font-montserrat font-extrabold text-white leading-tight mb-1 md:group-hover:text-cta md:transition-colors md:duration-normal" style="font-size: clamp(1.15rem, 1rem + 1vw, 1.6rem);">
                {tour.title}
              </h3>
              <div class="flex items-center gap-2">
                <p class="text-white/75 font-semibold text-sm">{tour.price}</p>
                <span class="text-white/70 text-xs">· под ключ</span>
              </div>
            </div>
          </div>
        </button>
      ))}
    </div>

    <!-- CTA под сеткой -->
    <div class="text-center mt-8 reveal-hidden">
      <a
        id="popular-tours-all-btn"
        href="#search"
        class="inline-flex items-center gap-2 text-sm font-semibold text-gray-400 hover:text-primary active:scale-[0.98] active:translate-y-0.5 transition-[color,transform] duration-fast group cursor-pointer"
      >
        Смотреть все направления
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  const scrollToSearch = () => {
    const anchor = document.getElementById('search');
    if (anchor) {
      const top = anchor.getBoundingClientRect().top + window.pageYOffset - 104;
      window.scrollTo({ top, behavior: 'smooth' });
    }
  };

  document.querySelectorAll('button[data-tour-title]').forEach((btn) => {
    btn.addEventListener('click', () => scrollToSearch());
  });

  document.getElementById('popular-tours-all-btn')?.addEventListener('click', (e) => {
    e.preventDefault();
    scrollToSearch();
  });

  function initToursBreathePause() {
    const toursSection = document.getElementById('tours');
    if (!toursSection || toursSection.dataset.breatheObserved) return;
    toursSection.dataset.breatheObserved = '1';
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          e.target.classList.toggle('tours-out-of-view', !e.isIntersecting);
        });
      },
      { threshold: 0 }
    );
    observer.observe(toursSection);
  }
  initToursBreathePause();
  document.addEventListener('astro:page-load', initToursBreathePause);
</script>
