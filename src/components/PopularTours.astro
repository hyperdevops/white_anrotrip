---
const tours = [
  {
    title: 'Турция, Анталья',
    price: 'от 45 000 ₽',
    image:
      'https://images.unsplash.com/photo-1542051841857-5f90071e7989?q=80&w=2070&auto=format&fit=crop',
    size: 'large',
    badge: '🔥 Хит продаж',
  },
  {
    title: 'ОАЭ, Дубай',
    price: 'от 80 000 ₽',
    image:
      'https://images.unsplash.com/photo-1512453979798-5ea932a23518?q=80&w=2074&auto=format&fit=crop',
    size: 'tall',
    badge: 'Shopping',
  },
  {
    title: 'Таиланд, Пхукет',
    price: 'от 95 000 ₽',
    image:
      'https://images.unsplash.com/photo-1552465011-b4e21bf6e79a?q=80&w=2039&auto=format&fit=crop',
    size: 'normal',
    badge: 'Relax',
  },
  {
    title: 'Мальдивы',
    price: 'от 150 000 ₽',
    image:
      'https://images.unsplash.com/photo-1514282401047-d79a71a590e8?q=80&w=2065&auto=format&fit=crop',
    size: 'normal',
    badge: 'Luxury',
  },
  {
    title: 'Египет, Шарм',
    price: 'от 55 000 ₽',
    image:
      'https://images.unsplash.com/photo-1566321743167-7b8c26922579?q=80&w=2070&auto=format&fit=crop',
    size: 'wide',
    badge: 'Все включено',
  },
];
---

<!--
  ИСПРАВЛЕНИЕ:
  Убрал bg-white dark:bg-darkbg.
  Теперь фон прозрачный, и виден цвет родительской шторки (.content-sheet).
-->
<section id="tours" class="py-10 transition-colors">
  <div class="container mx-auto px-4">
    <!-- Заголовок -->
    <div class="mb-12 text-center reveal-hidden">
      <h2
        class="font-montserrat text-3xl font-extrabold text-gray-900 dark:text-white sm:text-4xl md:text-5xl"
      >
        Популярные <span class="text-primary dark:text-primary-light"
          >Направления</span
        >
      </h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-300">
        Лучшие предложения этого сезона
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 auto-rows-[250px]">
      {
        tours.map((tour, index) => (
          <button
            type="button"
            data-tour-title={tour.title}
            class:list={[
              'group relative overflow-hidden rounded-3xl cursor-pointer transition-all duration-500',

              // ИСПОЛЬЗУЕМ НАШ КЛАСС
              'deep-shadow border border-white/20 dark:border-white/5',

              // Анимация
              'reveal-hidden',
              index % 2 === 0 ? '' : 'delay-100',
              tour.size === 'large' ? 'md:col-span-2 md:row-span-2' : '',
              tour.size === 'tall' ? 'md:col-span-1 md:row-span-2' : '',
              tour.size === 'wide' ? 'md:col-span-2 md:row-span-1' : '',
              tour.size === 'normal' ? 'md:col-span-1 md:row-span-1' : '',
            ]}
          >
            <div class="absolute inset-0">
              <img
                src={tour.image}
                alt={tour.title}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-[linear-gradient(to_top,rgb(0_0_0/80%),rgb(0_0_0/20%),transparent)] opacity-80 group-hover:opacity-60 transition-opacity" />
            </div>
            {/* Контент */}
            <div class="absolute inset-0 p-6 flex flex-col justify-between">
              <div class="flex justify-between items-start">
                <span class="inline-block rounded-full bg-white/20 backdrop-blur-md px-3 py-1 text-xs font-bold text-white uppercase tracking-wider border border-white/30">
                  {tour.badge}
                </span>
              </div>

              <div class="transform translate-y-2 group-hover:translate-y-0 transition-transform duration-300 text-left">
                <h3 class="font-montserrat text-2xl font-bold text-white mb-1 group-hover:text-cta transition-colors">
                  {tour.title}
                </h3>
                <p class="text-white/90 font-medium text-lg">{tour.price}</p>
              </div>
            </div>
          </button>
        ))
      }
    </div>
  </div>
</section>

<!-- Скрипт клика -->
<script>
  document.querySelectorAll('button[data-tour-title]').forEach((button) => {
    button.addEventListener('click', (event) => {
      // @ts-ignore
      const tourTitle = event.currentTarget.getAttribute('data-tour-title');
      alert(`Детали тура: ${tourTitle}`);
    });
  });
</script>
