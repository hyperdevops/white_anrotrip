  <!-- ГЛАВНАЯ КНОПКА -->
  <button
    id="office-toggle-btn"
    class="w-14 h-14 rounded-full bg-primary text-white shadow-[0_4px_20px_rgba(14,116,144,0.4)] flex items-center justify-center hover:bg-primary hover:scale-105 transition-all duration-300 cursor-pointer animate-pulse-slow relative z-10"
  >
    <svg
      id="icon-msg"
      xmlns="http://www.w3.org/2000/svg"
      class="h-7 w-7 transition-transform duration-300"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
      ></path>
    </svg>
    <svg
      id="icon-close"
      xmlns="http://www.w3.org/2000/svg"
      class="h-7 w-7 absolute opacity-0 rotate-90 transition-all duration-300"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
</div>

<script>
  const btn = document.getElementById('office-toggle-btn');
  const list = document.getElementById('social-list');
  const iconMsg = document.getElementById('icon-msg');
  const iconClose = document.getElementById('icon-close');
  const container = document.getElementById('office-widget-container');
  let isOpen = false;

  // 1. Открытие/Закрытие меню
  btn?.addEventListener('click', () => {
    isOpen = !isOpen;
    if (isOpen) {
      // Открываем
      list?.classList.remove(
        'opacity-0',
        'translate-y-4',
        'pointer-events-none',
        'scale-90',
      );

      // Иконки
      iconMsg?.classList.add('opacity-0', '-rotate-90');
      iconClose?.classList.remove('opacity-0', 'rotate-90');
    } else {
      // Закрываем
      list?.classList.add(
        'opacity-0',
        'translate-y-4',
        'pointer-events-none',
        'scale-90',
      );

      // Иконки
      iconMsg?.classList.remove('opacity-0', '-rotate-90');
      iconClose?.classList.add('opacity-0', 'rotate-90');
    }
  });

  // 2. ЛОГИКА "ПИЛЮЛИ" (Парковка над футером)
  window.addEventListener('scroll', () => {
    const footer = document.querySelector('footer');
    if (!footer || !container) return;

    const footerRect = footer.getBoundingClientRect();
    const windowHeight = window.innerHeight;

    // Если футер появился в зоне видимости
    if (footerRect.top < windowHeight) {
      // Исходное положение кнопки (расстояние от низа экрана до центра кнопки)
      // bottom-8 (32px) + половина высоты (28px) = 60px
      const originalCenterFromBottom = 60;

      // Где сейчас верх футера относительно низа экрана?
      // (windowHeight - footerRect.top) - это расстояние от низа экрана до верха футера
      const footerDistFromBottom = windowHeight - footerRect.top;

      // Нам нужно, чтобы центр кнопки был ровно на линии футера.
      // Значит, нам нужно сдвинуть кнопку вверх на разницу.
      // Разница = footerDistFromBottom - originalCenterFromBottom
      const lift = footerDistFromBottom - originalCenterFromBottom;

      // Если lift > 0, значит футер выше нашей кнопки, надо двигать
      if (lift > 0) {
        container.style.transform = `translateY(-${lift}px)`;
      } else {
        container.style.transform = `translateY(0)`;
      }
    } else {
      container.style.transform = `translateY(0)`;
    }
  });
</script>

<style>
  @keyframes pulse-slow {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(63, 160, 240, 0.7);
    }
    70% {
      box-shadow: 0 0 0 15px rgba(14, 116, 144, 0);
    }
  }
  .animate-pulse-slow {
    animation: pulse-slow 2.5s infinite;
  }
</style>
