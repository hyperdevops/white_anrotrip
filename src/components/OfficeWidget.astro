  <!-- ГЛАВНАЯ КНОПКА -->
  <button
    id="office-toggle-btn"
    class="office-toggle-btn w-14 h-14 rounded-full bg-primary text-white flex items-center justify-center hover:bg-primary hover:scale-105 active:scale-[0.98] active:translate-y-0.5 transition-[transform] duration-normal cursor-pointer animate-pulse-slow relative z-10 pointer-events-auto focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-primary"
  >
    <svg
      id="icon-msg"
      xmlns="http://www.w3.org/2000/svg"
      class="h-7 w-7 transition-transform duration-normal"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
      ></path>
    </svg>
    <svg
      id="icon-close"
      xmlns="http://www.w3.org/2000/svg"
      class="h-7 w-7 absolute opacity-0 rotate-90 transition-all duration-normal"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
</div>

<script>
  let scrollHandler: (() => void) | null = null;

  function initOfficeWidget() {
    const btn = document.getElementById('office-toggle-btn');
    const list = document.getElementById('social-list');
    const iconMsg = document.getElementById('icon-msg');
    const iconClose = document.getElementById('icon-close');
    const container = document.getElementById('office-widget-container');

    if (!btn) return;

    let isOpen = false;

    // Удаляем старый scroll listener (важно при View Transitions)
    if (scrollHandler) {
      window.removeEventListener('scroll', scrollHandler);
      scrollHandler = null;
    }

    btn.onclick = () => {
      isOpen = !isOpen;
      if (isOpen) {
        list?.classList.remove(
          'opacity-0',
          'translate-y-4',
          'pointer-events-none',
          'scale-90',
        );
        list?.classList.add('pointer-events-auto');
        iconMsg?.classList.add('opacity-0', '-rotate-90');
        iconClose?.classList.remove('opacity-0', 'rotate-90');
        // Убираем пульсацию при открытии виджета
        btn.classList.remove('animate-pulse-slow');
        btn.classList.add('pulse-disabled');
      } else {
        list?.classList.add(
          'opacity-0',
          'translate-y-4',
          'pointer-events-none',
          'scale-90',
        );
        list?.classList.remove('pointer-events-auto');
        iconMsg?.classList.remove('opacity-0', '-rotate-90');
        iconClose?.classList.add('opacity-0', 'rotate-90');
        // Возвращаем пульсацию при закрытии виджета
        btn.classList.remove('pulse-disabled');
        btn.classList.add('animate-pulse-slow');
      }
    };

    let ticking = false;
    function updateWidgetPosition() {
      if (!container) return;
      const scrollY = window.scrollY || window.pageYOffset;
      const bottomOfScreen = scrollY + window.innerHeight;
      const distanceFromBottom =
        document.documentElement.scrollHeight - bottomOfScreen;
      const stopDistance = 130;
      if (distanceFromBottom < stopDistance) {
        container.style.transform = `translateY(-${stopDistance - distanceFromBottom}px)`;
      } else {
        container.style.transform = 'translateY(0)';
      }
      ticking = false;
    }

    scrollHandler = () => {
      if (!ticking) {
        window.requestAnimationFrame(updateWidgetPosition);
        ticking = true;
      }
    };
    window.addEventListener('scroll', scrollHandler);
    updateWidgetPosition();
  }

  // Инициализация виджета с добавлением класса пульсации при загрузке
  initOfficeWidget();
  // Убедимся, что класс пульсации установлен при инициализации
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('office-toggle-btn');
    if (btn && !btn.classList.contains('pulse-disabled') && !btn.classList.contains('animate-pulse-slow')) {
      btn.classList.add('animate-pulse-slow');
    }
  });
  document.addEventListener('astro:page-load', initOfficeWidget);

  (window as unknown as { initOfficeWidget?: () => void }).initOfficeWidget =
    initOfficeWidget;
</script>
