---
import '../styles/global.css';
import favicon from '../assets/favicon.png';
import { ClientRouter } from 'astro:transitions';
import ScrollProgress from '../components/ScrollProgress.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import CallbackModal from '../components/CallbackModal.astro';
import ReviewModal from '../components/ReviewModal.astro';
import FavoritesWidget from '../components/FavoritesWidget.astro';
import CookieBanner from '../components/CookieBanner.astro';
import OfficeWidget from '../components/OfficeWidget.astro';
import GiftModal from '../components/GiftModal.astro';

interface Props {
  title: string;
  description?: string;
  /** Полный URL страницы для canonical и og:url (если не задан — берётся из Astro.url) */
  canonicalURL?: string;
  /** Путь или URL картинки для превью в соцсетях (рекомендуется 1200×630). По умолчанию favicon из assets */
  ogImage?: string;
  showFavorites?: boolean;
  showScrollProgress?: boolean;
  showScrollToTop?: boolean;
  showOfficeWidget?: boolean;
}

const {
  title,
  description = 'ANRO TRIP — Путешествия, которые меняют жизнь.',
  canonicalURL,
  ogImage = '/favicon.src',
  showFavorites = true,
  showScrollProgress = true,
  showScrollToTop = true,
  showOfficeWidget = true,
} = Astro.props;

const baseUrl = Astro.url.origin;
const canonical = canonicalURL ?? Astro.url.href;
const ogImageUrl = ogImage.startsWith('http')
  ? ogImage
  : new URL(ogImage, baseUrl).href;
---

<!doctype html>
<html lang="ru" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#00abb3" />

    <!-- Favicon (из assets — оптимизируется при сборке) -->
    <link rel="icon" type="image/png" href={favicon.src} />
    <link rel="apple-touch-icon" href={favicon.src} />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="ru_RU" />

    <!-- Шрифты: preconnect + display=swap для быстрого рендера -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Montserrat:wght@600;700;800&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <!-- Noscript fallback -->
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Montserrat:wght@600;700;800&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- View Transitions API -->
    <ClientRouter />

    <title>{title}</title>
    <slot name="head" />
  </head>
  <body
    class="bg-white text-gray-900 font-inter antialiased overflow-x-hidden selection:bg-primary/20 selection:text-primary-dark"
  >
    <!-- Вспышка при загрузке — тот же эффект, что при клике по логотипу (fade-in 0.5s). Учитываем prefers-reduced-motion -->
    <script is:inline>
      (function () {
        var d = document;
        var prefersReduced = window.matchMedia(
          '(prefers-reduced-motion: reduce)',
        ).matches;
        if (!prefersReduced) {
          d.documentElement.style.opacity = '0';
          d.body.style.opacity = '0';
          d.documentElement.style.transition = 'opacity 0.5s ease';
          d.body.style.transition = 'opacity 0.5s ease';
        }
        function fadeIn() {
          if (prefersReduced) return;
          d.documentElement.style.opacity = '1';
          d.body.style.opacity = '1';
          setTimeout(function () {
            d.documentElement.style.transition = '';
            d.documentElement.style.opacity = '';
            d.body.style.transition = '';
            d.body.style.opacity = '';
          }, 500);
        }
        if (d.readyState === 'loading') {
          d.addEventListener('DOMContentLoaded', fadeIn);
        } else {
          fadeIn();
        }
      })();
    </script>
    <!-- Skip Link: виден при фокусе (Tab), для клавиатуры и скринридеров -->
    <a
      href="#content"
      class="fixed left-4 top-0 z-9999 -translate-y-full rounded-b-md bg-primary px-4 py-2.5 text-sm font-semibold text-white shadow-lg transition-transform duration-fast focus:translate-y-0 cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
    >
      Перейти к содержимому
    </a>
    {showScrollProgress && <ScrollProgress />}
    <slot />
    {showScrollToTop && <ScrollToTop />}
    {showFavorites && <FavoritesWidget />}
    {showOfficeWidget && <OfficeWidget />}
    <CookieBanner />
    <GiftModal />
    <CallbackModal />
    <ReviewModal />

    <!-- Tourvisor не поддерживает View Transition — при переходе на главную делаем полную загрузку (astro:before-swap) -->
    <script is:inline>
      document.addEventListener('astro:before-swap', function (e) {
        // Проверяем по наличию виджета Tourvisor (только на главной), а не по documentURI — он может быть пустым при fetch
        var isMainPage = e.newDocument.querySelector(
          '.tv-search-form.tv-moduleid-192367',
        );
        if (isMainPage) {
          e.swap = function () {
            window.location.href = window.location.origin + '/';
          };
        }
      });
    </script>
    <!-- ОБНОВЛЕННЫЙ СКРИПТ АНИМАЦИИ -->
    <script is:inline>
      // Создаем глобальную функцию для запуска/перезапуска анимаций
      window.initScrollReveal = () => {
        const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1,
        };

        const observer = new IntersectionObserver((entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('reveal-visible');
              observer.unobserve(entry.target); // Перестаем следить после появления
            }
          });
        }, observerOptions);

        // Находим все скрытые элементы и начинаем следить
        document.querySelectorAll('.reveal-hidden').forEach((el) => {
          // Если мы перезапускаем, убеждаемся, что класс видимости снят
          // Но делаем это аккуратно, чтобы не мигало то, что уже на экране (если не телепорт)
          // В данном случае Header сам снимет классы перед вызовом этой функции
          observer.observe(el);
        });
      };

      // Запускаем при первой загрузке
      window.initScrollReveal();

      // При переходах View Transitions (ClientRouter) перезапускаем reveal для новой страницы
      document.addEventListener('astro:page-load', () => {
        requestAnimationFrame(() => {
          window.initScrollReveal?.();
          window.initSearchWidget?.();
          window.initNemoWidget?.();
          window.initTourvisorWidget?.();
        });
      });
      // Функция вычисления ширины скроллбара
      function getScrollbarWidth() {
        return window.innerWidth - document.documentElement.clientWidth;
      }

      // БЛОКИРОВКА СКРОЛЛА С КОМПЕНСАЦИЕЙ
      window.lockScroll = () => {
        const scrollbarWidth = getScrollbarWidth();

        // Если скроллбара нет (мобилка), просто блокируем и выходим
        if (scrollbarWidth <= 0) {
          document.body.style.overflow = 'hidden';
          return;
        }

        // 1. Добавляем отступ body, чтобы контент не прыгал
        document.body.style.paddingRight = `${scrollbarWidth}px`;

        // 2. Добавляем отступ ХЕДЕРУ (если он fixed w-full), чтобы он не растягивался
        const header = document.querySelector('header');
        if (header) {
          header.style.paddingRight = `${scrollbarWidth}px`;
        }

        // 3. Блокируем скролл
        document.body.style.overflow = 'hidden';
      };

      // РАЗБЛОКИРОВКА
      window.unlockScroll = () => {
        document.body.style.overflow = '';
        document.body.style.paddingRight = '';

        const header = document.querySelector('header');
        if (header) {
          header.style.paddingRight = '';
        }
      };
    </script>
  </body>
</html>
