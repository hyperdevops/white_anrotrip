---
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import PopularTours from '../components/PopularTours.astro';
import SearchWidget from '../components/SearchWidget.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="ANRO TRIP — Будь на высоте!">
  <Header />

  <main>
    <Hero />

    <!--
      ШТОРКА С КОНТЕНТОМ
      Используем класс content-sheet (цвета и переходы настроены в CSS)
      Убрал лишние bg-white и dark:bg... из HTML, чтобы не было конфликтов.
    -->
    <div
      class="relative z-10 mt-[45vh] md:mt-[20vh] content-sheet pb-20 min-h-screen"
    >
      <!-- Виджет -->
      <div class="relative z-20 -translate-y-1/2 px-4">
        <SearchWidget />
      </div>

      <!-- Туры -->
      <div class="-mt-48 md:-mt-16 relative z-10">
        <PopularTours />
      </div>

      <div class="h-20"></div>
    </div>
  </main>
</Layout>
