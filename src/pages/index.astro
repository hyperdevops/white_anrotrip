---
// src/pages/index.astro
import heroBg from '../assets/hero/plane.avif';
import About from '../components/About.astro';
import Awards from '../components/Awards.astro';
import Contacts from '../components/Contacts.astro';
import Footer from '../components/Footer.astro';
import GiftSection from '../components/GiftSection.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Partners from '../components/Partners.astro';
import PopularTours from '../components/PopularTours.astro';
import Reviews from '../components/Reviews.astro';
import SearchWidget from '../components/SearchWidget.astro';
import Team from '../components/Team.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="ANRO TRIP — Будь на высоте!">
  <Fragment slot="head">
    <link
      rel="preload"
      as="image"
      href={heroBg.src}
      type="image/avif"
      fetchpriority="high"
    />
  </Fragment>
  <Header />

  <main>
    <!--
      Первый экран: Картинка, Заголовок, Кнопка, Стрелка.
      Занимает 100vh.
    -->
    <Hero />

    <!--
      Блок контента.
      mt-[20vh] сдвигает его вниз, открывая картинку Hero.
      bg-white — белый фон
      shadow — тень сверху
    -->
    <div
      id="content"
      class="relative z-10 mt-[20vh] bg-white rounded-t-3xl shadow-[0_-10px_40px_rgba(15,76,129,0.12)] transition-colors duration-700 ease-in-out pb-12 md:pb-20"
    >
      <!-- Якорь для кнопки "Поиск туров" (невидимый) -->
      <div id="search" class="absolute -top-32 w-full h-1"></div>

      <!--
         Виджет поиска.
         -translate-y-24 поднимает его ВВЕРХ, чтобы он наехал на границу Hero.
         glass-panel — класс из global.css.
      -->
      <div class="relative z-20 -translate-y-24 px-4 sm:px-6 max-w-7xl mx-auto">
        <SearchWidget />
      </div>

      <!-- Остальной контент: единый горизонтальный ритм px-4 sm:px-6 -->
      <div class="space-y-0">
        <!-- Якорь для стрелочки "Популярные туры" -->
        <div
          id="popular-tours"
          class="scroll-mt-[calc(4rem+40px)] pt-4 md:pt-6"
        >
          <PopularTours />
        </div>

        <About />
        <Partners />
        <Reviews />
        <Awards />
        <GiftSection />
        <Team />
        <Contacts />
      </div>
    </div>
  </main>
  <Footer />
</Layout>
