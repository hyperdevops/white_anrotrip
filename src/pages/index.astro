---
// src/pages/index.astro
import About from '../components/About.astro';
import Awards from '../components/Awards.astro';
import Contacts from '../components/Contacts.astro';
import Footer from '../components/Footer.astro';
import GiftSection from '../components/GiftSection.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Partners from '../components/Partners.astro';
import PopularTours from '../components/PopularTours.astro';
import Reviews from '../components/Reviews.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import SearchWidget from '../components/SearchWidget.astro';
import Team from '../components/Team.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="ANRO TRIP — Будь на высоте!">
  <Header />

  <main>
    <!--
      Первый экран: Картинка, Заголовок, Кнопка, Стрелка.
      Занимает 100vh.
    -->
    <Hero />

    <!--
      Блок контента.
      mt-[90vh] сдвигает его вниз, открывая картинку Hero.
      content-sheet — класс из global.css (белый/темный фон, скругление).
    -->
    <div id="content" class="relative z-10 mt-[90vh] content-sheet pb-20">
      <!-- Якорь для кнопки "Поиск туров" (невидимый) -->
      <div id="search-anchor" class="absolute -top-32 w-full h-1"></div>

      <!--
         Виджет поиска.
         -translate-y-24 поднимает его ВВЕРХ, чтобы он наехал на границу Hero.
         glass-panel — класс из global.css.
      -->
      <div class="relative z-20 -translate-y-24 px-4 max-w-7xl mx-auto">
        <SearchWidget />
      </div>

      <!-- Остальной контент -->
      <div class="-mt-12 space-y-24">
        <!-- Якорь для стрелочки "Популярные туры" -->
        <div id="popular-tours" class="scroll-mt-32">
          <PopularTours />
        </div>

        <About />
        <Partners />
        <Reviews />
        <Awards />
        <GiftSection />
        <Team />
        <Contacts />
      </div>
    </div>
  </main>
  <Footer />
  <ScrollToTop />
</Layout>
