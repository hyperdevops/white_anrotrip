---
import type { GetStaticPathsOptions } from 'astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import favicon from '../../assets/favicon.png';
import FooterMinimal from '../../components/FooterMinimal.astro';
import Layout from '../../layouts/Layout.astro';
import { getTourStyleBadge } from '../../lib/tourDestinationBadge';

export const prerender = true;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const allPosts = await getCollection('blog');
  const sortedPosts = allPosts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );
  const featuredPost =
    sortedPosts.find((p) => p.data.featured === true) ?? null;
  const postsForGrid = featuredPost
    ? sortedPosts.filter((p) => p.id !== featuredPost.id)
    : sortedPosts;

  return paginate(postsForGrid, {
    pageSize: 6,
    props: { featuredPost },
  });
}

const { page, featuredPost } = Astro.props;

// Все направления из коллекции — для тегов в шапке
const allBlogPosts = await getCollection('blog');
const allDestinations = [
  ...new Set(
    allBlogPosts
      .map((p) => p.data.destination)
      .filter((d): d is string => Boolean(d)),
  ),
].sort();

// Счётчик материалов с правильным склонением
const totalCount = page.total + (featuredPost ? 1 : 0);
const materialsWord =
  totalCount % 10 === 1 && totalCount % 100 !== 11
    ? 'материал'
    : totalCount % 10 >= 2 &&
        totalCount % 10 <= 4 &&
        (totalCount % 100 < 10 || totalCount % 100 >= 20)
      ? 'материала'
      : 'материалов';
---

<Layout
  title="Журнал о путешествиях | ANRO TRIP"
  description="Вдохновляющие идеи, советы экспертов и путеводители по лучшим направлениям от команды ANRO TRIP."
  showFavorites={false}
  showOfficeWidget={false}
  showScrollToTop={false}
>
  <!-- Одна сплошная страница: mesh-фон, без наезда блока списка на hero -->
  <main
    class="blog-mesh-text-bg relative overflow-hidden min-h-screen pb-16 md:pb-24"
    aria-label="Журнал о путешествиях"
  >
    <!-- Фоновые орбы страницы — паттерн как на главной -->
    <div
      class="absolute -top-28 -right-28 size-112 rounded-full bg-primary/8 blur-none md:blur-3xl pointer-events-none"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute top-[38%] -left-24 size-80 rounded-full bg-secondary/5 blur-none md:blur-3xl pointer-events-none"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute bottom-40 -right-16 size-72 rounded-full bg-cta/7 blur-none md:blur-3xl pointer-events-none"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute bottom-0 left-1/2 -translate-x-1/2 w-152 h-36 rounded-full bg-primary/4 blur-none md:blur-3xl pointer-events-none"
      aria-hidden="true"
    >
    </div>

    <div class="relative">
      <a
        href={`${base}/`}
        data-astro-reload
        class="reveal-hidden pointer-events-auto absolute top-4 right-4 left-auto z-20 flex h-12 w-12 items-center justify-center rounded-full bg-white/85 backdrop-blur-sm shadow-[0_0_24px_rgba(0,0,0,0.08)] transition-[box-shadow,transform] duration-normal hover:shadow-[0_0_32px_rgba(0,0,0,0.12)] focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 sm:left-6 sm:right-auto"
        aria-label="На главную"
      >
        <Image
          src={favicon}
          alt=""
          width={40}
          height={40}
          format="png"
          densities={[2, 3, 4]}
          quality="max"
          decoding="async"
          class="h-10 w-10 object-contain drop-shadow-sm"
        />
      </a>
      <div class="container mx-auto max-w-7xl px-4 pb-10 pt-6 sm:px-6 md:pb-12">
        <!-- Заголовок страницы — паттерн как в PopularTours -->
        <div>
          <div
            class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/15 bg-primary/8 px-4 py-1.5"
          >
            <span class="h-1.5 w-1.5 rounded-full bg-primary md:animate-pulse"
            ></span>
            <span
              class="font-montserrat text-xs font-semibold uppercase tracking-widest text-primary"
              >Журнал</span
            >
          </div>
          <h1
            class="mb-4 font-montserrat font-extrabold uppercase leading-none tracking-tight text-gray-900"
            style="font-size: clamp(2rem, 1.5rem + 3vw, 4rem);"
          >
            Журнал<br /><span class="text-primary">путешествий</span>
          </h1>
          <p class="max-w-md text-sm leading-relaxed text-gray-400">
            Вдохновляющие идеи, советы экспертов и путеводители по лучшим
            направлениям от команды ANRO TRIP.
          </p>

          <!-- Редакционная строка -->
          <div class="mt-5 pt-4 border-t border-primary/10 space-y-3">
            <div
              class="flex flex-wrap items-center gap-2.5 text-[11px] text-gray-400 font-inter"
            >
              <span class="font-medium text-gray-500 tabular-nums"
                >{totalCount} {materialsWord}</span
              >
              <span aria-hidden="true" class="text-gray-200">·</span>
              <span class="inline-flex items-center gap-1.5">
                <span
                  class="inline-block w-1.5 h-1.5 rounded-full bg-primary/50 md:animate-pulse"
                  aria-hidden="true"></span>
                Обновляется
              </span>
              <span aria-hidden="true" class="text-gray-200">·</span>
              <span>ANRO&nbsp;TRIP · 2026</span>
            </div>
            <!-- Теги направлений -->
            {
              allDestinations.length > 0 && (
                <div
                  class="flex flex-wrap gap-1.5"
                  role="list"
                  aria-label="Направления в журнале"
                >
                  {allDestinations.map((dest) => {
                    const badge = getTourStyleBadge(dest);
                    return (
                      <span
                        role="listitem"
                        class:list={[
                          'inline-block rounded-full px-2.5 py-0.5 text-[10px] font-black uppercase tracking-wider font-montserrat',
                          badge.className,
                        ]}
                      >
                        {badge.label}
                      </span>
                    );
                  })}
                </div>
              )
            }
          </div>
        </div>
      </div>
    </div>

    <div class="container mx-auto max-w-7xl px-4 pt-2 sm:px-6 md:pt-4">
      <!-- Крупная карточка «Направления» + сетка остальных материалов (стр. 1) -->
      <div
        class="mb-16 grid grid-cols-1 gap-4 md:grid-cols-3 md:gap-5"
        data-reveal-stagger
      >
        {
          page.currentPage === 1 && featuredPost && (
            <article class="group reveal-hidden md:col-span-3 flex flex-col lg:flex-row rounded-3xl overflow-hidden bg-white border border-primary/15 shadow-[0_8px_40px_rgba(0,171,179,0.18)] hover:shadow-[0_12px_48px_rgba(0,171,179,0.28)] transition-[opacity,transform,box-shadow] duration-slow [content-visibility:auto]">
              <a
                href={`${base}/blog/${featuredPost.id}`}
                class="relative block overflow-hidden aspect-16/10 lg:w-[58%] lg:shrink-0 lg:aspect-auto lg:min-h-[min(22rem,52vh)]"
                aria-label={`Читать статью: ${featuredPost.data.title}`}
              >
                {featuredPost.data.heroImages &&
                featuredPost.data.heroImages.length >= 2 ? (
                  <div
                    class="absolute inset-0 transition-transform duration-slow ease-out group-hover:scale-[1.02]"
                    data-slideshow={`card-featured-${featuredPost.id}`}
                  >
                    {featuredPost.data.heroImages.slice(0, 8).map((img, i) => (
                      <div
                        class="absolute inset-0 transition-opacity duration-1000 ease-in-out"
                        data-slide={i}
                        data-slideshow-group={`card-featured-${featuredPost.id}`}
                      >
                        <Image
                          src={img}
                          alt={`${featuredPost.data.title} — фото ${i + 1}`}
                          width={1200}
                          height={675}
                          loading={i === 0 ? 'eager' : 'lazy'}
                          class="w-full h-full object-cover"
                        />
                      </div>
                    ))}
                  </div>
                ) : featuredPost.data.heroImage ? (
                  <Image
                    src={featuredPost.data.heroImage}
                    alt={featuredPost.data.title}
                    width={1200}
                    height={675}
                    loading="eager"
                    class="object-cover w-full h-full transition-transform duration-slow ease-out group-hover:scale-[1.02]"
                  />
                ) : (
                  <div class="w-full h-full bg-linear-to-br from-primary/10 to-primary/20 flex items-center justify-center min-h-48">
                    <svg
                      class="w-16 h-16 text-primary/30"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                      />
                    </svg>
                  </div>
                )}
                <div class="absolute top-4 left-4 flex flex-wrap items-center gap-2">
                  <span class="bg-cta text-gray-900 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider font-montserrat shadow-sm">
                    Выбор редакции
                  </span>
                  {featuredPost.data.destination && (
                    <span
                      class:list={[
                        'inline-block rounded-full px-3 py-1 text-[10px] font-black uppercase tracking-wider font-montserrat',
                        getTourStyleBadge(featuredPost.data.destination)
                          .className,
                      ]}
                    >
                      {getTourStyleBadge(featuredPost.data.destination).label}
                    </span>
                  )}
                </div>
              </a>

              <div class="relative overflow-hidden p-6 md:p-8 lg:p-10 flex flex-col grow lg:max-w-[42%]">
                <div
                  class="absolute top-0 right-0 size-52 rounded-full bg-primary/7 blur-none md:blur-2xl pointer-events-none translate-x-1/3 -translate-y-1/3"
                  aria-hidden="true"
                />
                <div
                  class="absolute bottom-0 left-0 size-40 rounded-full bg-secondary/6 blur-none md:blur-2xl pointer-events-none -translate-x-1/3 translate-y-1/3"
                  aria-hidden="true"
                />
                <div
                  class="absolute bottom-1/3 right-4 size-24 rounded-full bg-cta/8 blur-none md:blur-xl pointer-events-none"
                  aria-hidden="true"
                />
                <time
                  datetime={featuredPost.data.pubDate.toISOString()}
                  class="text-xs text-gray-400 font-inter mb-3 block"
                >
                  {featuredPost.data.pubDate.toLocaleDateString('ru-RU', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
                <h2 class="text-xl md:text-2xl lg:text-[1.65rem] font-extrabold text-gray-900 mb-3 font-montserrat leading-tight tracking-tight line-clamp-3 group-hover:text-primary transition-colors duration-fast">
                  <a href={`${base}/blog/${featuredPost.id}`}>
                    {featuredPost.data.title}
                  </a>
                </h2>
                <p class="text-sm md:text-base text-gray-600 line-clamp-4 mb-6 grow font-inter leading-relaxed">
                  {featuredPost.data.description}
                </p>
                <div class="flex flex-wrap items-center justify-between gap-4 pt-4 border-t border-gray-100 mt-auto">
                  <span class="text-xs font-semibold text-gray-500 font-inter">
                    {featuredPost.data.author}
                  </span>
                  <a
                    href={`${base}/blog/${featuredPost.id}`}
                    class="group/link inline-flex items-center gap-2 text-sm font-bold text-primary hover:text-primary-dark transition-colors duration-fast font-montserrat uppercase tracking-wide"
                    aria-label={`Читать: ${featuredPost.data.title}`}
                  >
                    Читать материал
                    <svg
                      class="w-4 h-4 group-hover/link:translate-x-0.5 transition-transform duration-fast"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          )
        }
        {
          page.data.map((post, index) => (
            <article class="group reveal-hidden flex flex-col rounded-3xl overflow-hidden bg-white border border-white/10 shadow-[0_4px_24px_rgba(0,171,179,0.15)] hover:shadow-[0_8px_32px_rgba(0,171,179,0.25)] transition-[opacity,transform,box-shadow] duration-slow [content-visibility:auto]">
              <a
                href={`${base}/blog/${post.id}`}
                class="block relative overflow-hidden aspect-4/3"
                aria-label={`Читать статью: ${post.data.title}`}
              >
                {post.data.heroImages && post.data.heroImages.length >= 2 ? (
                  // Слайдер для коллажа
                  <div
                    class="absolute inset-0"
                    data-slideshow={`card-${post.id}`}
                  >
                    {post.data.heroImages.slice(0, 8).map((img, i) => (
                      <div
                        class="absolute inset-0 transition-opacity duration-1000 ease-in-out"
                        data-slide={i}
                        data-slideshow-group={`card-${post.id}`}
                      >
                        <Image
                          src={img}
                          alt={`${post.data.title} — фото ${i + 1}`}
                          width={600}
                          height={450}
                          loading={index < 3 ? 'eager' : 'lazy'}
                          class="object-cover w-full h-full transition-transform duration-slow ease-out group-hover:scale-[1.04]"
                        />
                      </div>
                    ))}
                  </div>
                ) : (post.data.heroImages?.[0] ?? post.data.heroImage) ? (
                  <Image
                    src={post.data.heroImages?.[0] ?? post.data.heroImage!}
                    alt={post.data.title}
                    width={600}
                    height={450}
                    loading={index < 3 ? 'eager' : 'lazy'}
                    class="object-cover w-full h-full transition-transform duration-slow ease-out group-hover:scale-[1.04]"
                  />
                ) : (
                  <div class="w-full h-full bg-linear-to-br from-primary/10 to-primary/20 flex items-center justify-center">
                    <svg
                      class="w-12 h-12 text-primary/30"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                      />
                    </svg>
                  </div>
                )}
                {post.data.destination && (
                  <div class="absolute top-4 left-4">
                    <span
                      class:list={[
                        'inline-block rounded-full px-3 py-1 text-[10px] font-black uppercase tracking-wider font-montserrat',
                        getTourStyleBadge(post.data.destination).className,
                      ]}
                    >
                      {getTourStyleBadge(post.data.destination).label}
                    </span>
                  </div>
                )}
              </a>
              <div class="relative overflow-hidden p-5 md:p-6 flex flex-col grow">
                {/* Паттерн 0: primary верхний правый + secondary нижний левый */}
                {index % 3 === 0 && (
                  <div
                    class="absolute top-0 right-0 size-32 rounded-full bg-primary/8 blur-none md:blur-xl pointer-events-none translate-x-1/4 -translate-y-1/4"
                    aria-hidden="true"
                  />
                )}
                {index % 3 === 0 && (
                  <div
                    class="absolute bottom-0 left-0 size-20 rounded-full bg-secondary/6 blur-none md:blur-lg pointer-events-none -translate-x-1/3 translate-y-1/3"
                    aria-hidden="true"
                  />
                )}
                {/* Паттерн 1: cta верхний левый + primary нижний правый */}
                {index % 3 === 1 && (
                  <div
                    class="absolute top-0 left-0 size-28 rounded-full bg-cta/9 blur-none md:blur-xl pointer-events-none -translate-x-1/4 -translate-y-1/4"
                    aria-hidden="true"
                  />
                )}
                {index % 3 === 1 && (
                  <div
                    class="absolute bottom-0 right-0 size-24 rounded-full bg-primary/7 blur-none md:blur-lg pointer-events-none translate-x-1/3 translate-y-1/3"
                    aria-hidden="true"
                  />
                )}
                {/* Паттерн 2: secondary середина правый + primary нижний + cta верхний центр */}
                {index % 3 === 2 && (
                  <div
                    class="absolute top-1/2 right-0 size-24 rounded-full bg-secondary/8 blur-none md:blur-xl pointer-events-none translate-x-1/3 -translate-y-1/2"
                    aria-hidden="true"
                  />
                )}
                {index % 3 === 2 && (
                  <div
                    class="absolute top-0 left-1/3 size-20 rounded-full bg-primary/6 blur-none md:blur-lg pointer-events-none -translate-x-1/2 -translate-y-1/2"
                    aria-hidden="true"
                  />
                )}
                {index % 3 === 2 && (
                  <div
                    class="absolute bottom-0 left-0 size-20 rounded-full bg-cta/7 blur-none md:blur-lg pointer-events-none -translate-x-1/3 translate-y-1/3"
                    aria-hidden="true"
                  />
                )}
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-xs text-gray-400 font-inter mb-2 block"
                >
                  {post.data.pubDate.toLocaleDateString('ru-RU', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
                <h2 class="text-base font-extrabold text-gray-900 mb-2 font-montserrat leading-snug line-clamp-2 group-hover:text-primary transition-colors duration-fast">
                  <a href={`${base}/blog/${post.id}`}>{post.data.title}</a>
                </h2>
                <p class="text-sm text-gray-500 line-clamp-2 mb-4 grow font-inter leading-relaxed">
                  {post.data.description}
                </p>
                <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                  <span class="text-xs font-semibold text-gray-500 font-inter">
                    {post.data.author}
                  </span>
                  <a
                    href={`${base}/blog/${post.id}`}
                    class="group/link inline-flex items-center gap-1.5 text-xs font-semibold text-primary hover:text-primary-dark transition-colors duration-fast font-montserrat uppercase tracking-wide"
                    aria-label={`Читать: ${post.data.title}`}
                  >
                    Читать
                    <svg
                      class="w-3.5 h-3.5 group-hover/link:translate-x-0.5 transition-transform duration-fast"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <!-- Пагинация -->
      {
        page.lastPage > 1 && (
          <div class="flex justify-center items-center gap-4">
            {page.url.prev ? (
              <a
                href={page.url.prev}
                class="group inline-flex items-center gap-2 text-sm font-semibold text-gray-400 hover:text-primary transition-colors duration-fast font-montserrat uppercase tracking-wide"
              >
                <svg
                  class="w-4 h-4 group-hover:-translate-x-1 transition-transform duration-fast"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2.5"
                    d="M15 19l-7-7 7-7"
                  />
                </svg>
                Назад
              </a>
            ) : (
              <span class="inline-flex items-center gap-2 text-sm font-semibold text-gray-200 font-montserrat uppercase tracking-wide cursor-not-allowed">
                <svg
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2.5"
                    d="M15 19l-7-7 7-7"
                  />
                </svg>
                Назад
              </span>
            )}

            <span class="text-sm text-gray-400 font-inter">
              {page.currentPage} / {page.lastPage}
            </span>

            {page.url.next ? (
              <a
                href={page.url.next}
                class="group inline-flex items-center gap-2 text-sm font-semibold text-gray-400 hover:text-primary transition-colors duration-fast font-montserrat uppercase tracking-wide"
              >
                Вперёд
                <svg
                  class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-fast"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2.5"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </a>
            ) : (
              <span class="inline-flex items-center gap-2 text-sm font-semibold text-gray-200 font-montserrat uppercase tracking-wide cursor-not-allowed">
                Вперёд
                <svg
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2.5"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </span>
            )}
          </div>
        )
      }
    </div>
  </main>

  <FooterMinimal />
</Layout>

<script>
  const blogCardSlideshowTimers = new WeakMap<
    HTMLElement,
    ReturnType<typeof setInterval>
  >();

  function initCardSlideshows() {
    const slideshows = document.querySelectorAll('[data-slideshow^="card-"]');

    slideshows.forEach((slideshow) => {
      const el = slideshow as HTMLElement;
      const prev = blogCardSlideshowTimers.get(el);
      if (prev !== undefined) {
        clearInterval(prev);
        blogCardSlideshowTimers.delete(el);
      }

      const group = slideshow.getAttribute('data-slideshow');
      if (!group) return;

      const slides = slideshow.querySelectorAll(
        `[data-slideshow-group="${group}"]`,
      );
      if (slides.length < 2) return;

      slides.forEach((slide, i) => {
        (slide as HTMLElement).style.opacity = i === 0 ? '1' : '0';
      });

      let current = 0;
      const intervalMs = 5000;

      const nextSlide = () => {
        const next = (current + 1) % slides.length;
        (slides[current] as HTMLElement).style.opacity = '0';
        (slides[next] as HTMLElement).style.opacity = '1';
        current = next;
      };

      blogCardSlideshowTimers.set(el, setInterval(nextSlide, intervalMs));
    });
  }

  document.addEventListener('DOMContentLoaded', initCardSlideshows);
  document.addEventListener('astro:page-load', initCardSlideshows);
</script>
