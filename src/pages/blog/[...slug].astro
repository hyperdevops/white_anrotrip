---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import Footer from '../../components/Footer.astro';
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Определяем режим Hero: коллаж или одиночное изображение
const hasCollage = post.data.heroImages && post.data.heroImages.length >= 2;
const collageImages = post.data.heroImages?.slice(0, 5) ?? [];
const hasHero = hasCollage || !!post.data.heroImage;
---

<Layout title={`${post.data.title} | Журнал ANRO TRIP`} description={post.data.description} showFavorites={false} showOfficeWidget={false}>
  <!-- Hero-зона (relative вместо sticky, чтобы не перекрывать Footer) -->
  {hasHero && (
    <div class="relative z-0 h-[55vh] md:h-[65vh] overflow-hidden">
      {hasCollage ? (
        <!-- Слайд-шоу с плавной сменой -->
        <div class="absolute inset-0" data-slideshow="hero-collage">
          {collageImages.map((img, i) => (
            <div class="absolute inset-0 transition-opacity duration-1000 ease-in-out" data-slide={i} data-slideshow-group="hero-collage">
              <Image
                src={img}
                alt={`${post.data.title} — фото ${i + 1}`}
                width={1600}
                height={900}
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : 'auto'}
                class="w-full h-full object-cover"
              />
            </div>
          ))}
        </div>
      ) : (
        <!-- Одиночное изображение -->
        <Image
          src={post.data.heroImage!}
          alt={post.data.title}
          width={1600}
          height={900}
          loading="eager"
          fetchpriority="high"
          class="w-full h-full object-cover"
        />
      )}

      <!-- Градиент снизу -->
      <div class="absolute inset-0 bg-[linear-gradient(to_top,rgb(0_0_0/70%)_0%,rgb(0_0_0/20%)_50%,transparent_100%)] pointer-events-none"></div>

      <!-- Заголовок поверх Hero -->
      <div class="absolute bottom-0 left-0 right-0 px-4 sm:px-6 pb-8 md:pb-12 max-w-4xl mx-auto">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          {post.data.destination && (
            <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider bg-primary/90 text-white font-montserrat">
              {post.data.destination === '' ? 'Направления' : post.data.destination}
            </span>
          )}
          <time datetime={post.data.pubDate.toISOString()} class="text-white/70 text-xs font-inter">
            {post.data.pubDate.toLocaleDateString('ru-RU', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          <span class="text-white/50 text-xs" aria-hidden="true">·</span>
          <span class="text-white/70 text-xs font-inter">{post.data.author}</span>
        </div>
        <h1 class="font-montserrat font-extrabold text-white uppercase tracking-tight leading-tight" style="font-size: clamp(1.5rem, 1.2rem + 3vw, 3rem);">
          {post.data.title}
        </h1>
      </div>
    </div>
  )}

  <!-- Контент — наползает поверх Hero как на главной -->
  <main
    class:list={[
      'relative z-10 bg-[linear-gradient(to_bottom,rgb(255_255_255)_0px,rgb(255_255_255)_60px,rgb(248_252_255)_120px,rgb(255_255_255)_100%)] shadow-[0_-10px_40px_rgba(15,76,129,0.12)]',
      hasHero ? '-mt-8 rounded-t-3xl' : 'pt-32 md:pt-40',
    ]}
  >
    <!-- Если нет Hero — показываем заголовок здесь -->
    {!hasHero && (
      <div class="px-4 sm:px-6 max-w-4xl mx-auto pt-12 pb-8">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          {post.data.destination && (
            <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider bg-primary/10 text-primary font-montserrat">
              {post.data.destination === 'Мальдивы' ? 'Направления' : post.data.destination}
            </span>
          )}
          <time datetime={post.data.pubDate.toISOString()} class="text-gray-400 text-xs font-inter">
            {post.data.pubDate.toLocaleDateString('ru-RU', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          <span class="text-gray-300 text-xs" aria-hidden="true">·</span>
          <span class="text-gray-400 text-xs font-inter">{post.data.author}</span>
        </div>
        <h1 class="font-montserrat font-extrabold text-gray-900 uppercase tracking-tight leading-tight" style="font-size: clamp(1.5rem, 1.2rem + 3vw, 3rem);">
          {post.data.title}
        </h1>
      </div>
    )}

    <div class="px-4 sm:px-6 max-w-4xl mx-auto pb-16 md:pb-24">
      <!-- Хлебные крошки -->
      <nav class="flex items-center gap-2 text-xs text-gray-400 font-inter pt-8 mb-8" aria-label="Навигация">
        <a href={`${base}/`} class="hover:text-primary transition-colors duration-fast">Главная</a>
        <svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <a href={`${base}/blog`} class="hover:text-primary transition-colors duration-fast">Журнал</a>
        <svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-gray-600 line-clamp-1">{post.data.title}</span>
      </nav>

      <!-- Лид-абзац -->
      <p class="text-lg md:text-xl text-gray-500 font-inter leading-relaxed mb-10 max-w-3xl">
        {post.data.description}
      </p>

      <!-- Контент статьи -->
      <article class="blog-content font-inter text-gray-800 text-base md:text-lg leading-relaxed">
        <Content />
      </article>

      <!-- CTA блок -->
      {post.data.destination && (
        <div class="mt-16 p-8 md:p-10 bg-[linear-gradient(135deg,rgb(0_171_179/5%)_0%,rgb(0_171_179/10%)_100%)] rounded-3xl border border-primary/15 text-center">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/8 border border-primary/15 mb-5">
            <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
            <span class="text-xs font-semibold text-primary uppercase tracking-widest font-montserrat">Подобрать тур</span>
          </div>
          <h3 class="font-montserrat font-extrabold text-gray-900 uppercase tracking-tight mb-4" style="font-size: clamp(1.25rem, 1rem + 2vw, 2rem);">
            Вдохновились<br /><span class="text-primary">{post.data.destination === 'Направления' ? 'направлениями' : post.data.destination}?</span>
          </h3>
          <p class="text-gray-500 mb-8 font-inter max-w-xl mx-auto text-sm md:text-base">
            Мы поможем организовать идеальное путешествие. Оставьте заявку — наши эксперты подберут лучшие варианты туров.
          </p>
          <button
            type="button"
            data-modal-target="callback-modal"
            class="group relative inline-flex items-center justify-center gap-2 overflow-hidden rounded-full bg-linear-to-r from-cta to-[#e5be14] px-8 py-4 font-black text-gray-900 shadow-[0_4px_14px_4px_rgba(255,212,23,0.35)] hover:shadow-[0_6px_18px_4px_rgba(255,212,23,0.4)] transition-shadow duration-normal cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 text-sm uppercase tracking-wider font-montserrat"
          >
            <span class="absolute inset-0 w-[200%] bg-linear-to-r from-transparent via-white/30 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-slow ease-out pointer-events-none"></span>
            <span class="relative z-10">Подобрать тур</span>
          </button>
        </div>
      )}

      <!-- Назад к журналу -->
      <div class="mt-12 pt-8 border-t border-gray-100">
        <a
          href={`${base}/blog`}
          class="group inline-flex items-center gap-2 text-sm font-semibold text-gray-400 hover:text-primary transition-colors duration-fast font-montserrat uppercase tracking-wide"
        >
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform duration-fast" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
          </svg>
          Все статьи журнала
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  // Слайд-шоу с плавной сменой изображений в Hero
  function initHeroSlideshow() {
    const heroSlideshow = document.querySelector('[data-slideshow="hero-collage"]');

    if (!heroSlideshow) return;

    const group = 'hero-collage';
    const slides = heroSlideshow.querySelectorAll(`[data-slideshow-group="${group}"]`);

    if (slides.length < 2) return;

    // Скрыть все слайды кроме первого
    slides.forEach((slide, i) => {
      (slide as HTMLElement).style.opacity = i === 0 ? '1' : '0';
    });

    let current = 0;
    const interval = 5000; // 5 секунд

    const nextSlide = () => {
      const next = (current + 1) % slides.length;
      (slides[current] as HTMLElement).style.opacity = '0';
      (slides[next] as HTMLElement).style.opacity = '1';
      current = next;
    };

    setInterval(nextSlide, interval);
  }

  // Запуск при первой загрузке
  document.addEventListener('DOMContentLoaded', initHeroSlideshow);
  // Запуск при View Transition
  document.addEventListener('astro:page-load', initHeroSlideshow);
</script>
