---
import { getImage, Image } from 'astro:assets';
import corpHero from '../assets/corp/corp.webp';
import corp1 from '../assets/corp/corp1.webp';
import corp2 from '../assets/corp/corp2.webp';
import corp3 from '../assets/corp/corp3.webp';
import corp4 from '../assets/corp/corp4.webp';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import { maxIconPath, socialLogoTransform80 } from '../lib/social-icons';

const corpHeroPreload = await getImage({ src: corpHero, quality: 90 });
// Tiny placeholder (20px) — как Tilda: размытый превью до загрузки полного изображения
const tinyCorpHero = await getImage({ src: corpHero, width: 20, quality: 20 });
---

<Layout
  title="Коммерческое предложение — ANRO TRIP"
  description="Уникальный сервис для командировок по России и миру. Корпоративное обслуживание, авиабилеты, отели, туры, визы, трансфер."
  showFavorites={false}
>
  <Fragment slot="head">
    <link
      rel="preload"
      as="image"
      href={corpHeroPreload.src}
      fetchpriority="high"
    />
  </Fragment>
  <Header
    navItems={[
      { name: 'О компании', href: '#content' },
      { name: 'Авиабилеты', href: '#corp-avia' },
      { name: 'Отели', href: '#corp-hotels' },
      { name: 'Туры', href: '#corp-tours' },
      { name: 'Трансфер', href: '#corp-transfer' },
      { name: 'Преимущества', href: '#corp-benefits' },
      { name: 'Контакты', href: '#corp-contacts' },
    ]}
    ctaText="Связаться"
    ctaHref="#corp-contacts"
    navVariant="corp"
  />

  <main>
    <!-- ═══════════════════════════════════════════════════════════════
         БЛОК 1 — HERO (Коммерческое предложение)
         Sticky: фото остаётся на месте, контент наползает сверху
    ═══════════════════════════════════════════════════════════════ -->
    <section
      class="sticky top-0 z-0 min-h-dvh w-full flex items-center justify-center overflow-hidden"
    >
      <!-- Фоновое изображение: tiny blur placeholder (как Tilda) + fade-in при загрузке -->
      <div
        class="absolute inset-0 bg-cover bg-center bg-no-repeat"
        style={`background-image: url('${tinyCorpHero.src}'); background-color: #334155`}
      >
        <Image
          src={corpHero}
          alt="Корпоративный туризм и командировки"
          class="corp-hero-bg-image h-full w-full object-cover opacity-0 transition-opacity duration-500 ease-out"
          quality={90}
          loading="eager"
          fetchpriority="high"
        />
        <!-- Затемняющий overlay для читаемости -->
        <div
          class="absolute inset-0 bg-linear-to-t from-gray-900/85 via-gray-900/50 to-gray-900/30"
        >
        </div>
        <!-- Декоративные орбы (desktop) -->
        <div
          class="absolute -top-32 -left-32 w-80 h-80 bg-primary/10 rounded-full blur-3xl pointer-events-none hidden md:block"
        >
        </div>
        <div
          class="absolute -bottom-32 -right-32 w-96 h-96 bg-secondary/10 rounded-full blur-3xl pointer-events-none hidden md:block"
        >
        </div>
      </div>

      <!-- Контент Hero -->
      <div
        class="relative z-10 container mx-auto px-4 sm:px-6 max-w-7xl text-white text-center py-20"
      >
        <!-- Бейдж -->
        <div class="reveal-hidden mb-6">
          <div
            class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 border border-white/20 text-white/90 text-xs font-semibold uppercase tracking-widest font-montserrat"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-cta md:animate-pulse"
            ></span>
            Для бизнеса
          </div>
        </div>

        <!-- Заголовок: обычный текст, шире на десктопе чтобы вмещался по ширине -->
        <h1
          class="font-montserrat font-extrabold uppercase tracking-tight leading-[1.15] drop-shadow-2xl mb-6 reveal-hidden max-w-2xl md:max-w-4xl lg:max-w-5xl mx-auto px-1"
          style="font-size: clamp(1.875rem, 1.5rem + 2.5vw, 4rem);"
        >
          Коммерческое<br />
          <span class="text-primary">предложение</span>
        </h1>

        <!-- Подзаголовок: обычный регистр на мобиле, uppercase на десктопе -->
        <p
          class="font-montserrat font-semibold text-white/90 sm:uppercase sm:tracking-wider mb-4 text-base sm:text-xl reveal-hidden"
        >
          туристической компании ANRO TRIP
        </p>

        <p
          class="max-w-2xl mx-auto text-white/80 text-base sm:text-lg leading-relaxed mb-12 reveal-hidden"
        >
          Уникальный сервис для командировок по&nbsp;России и&nbsp;миру
        </p>

        <!-- CTA-кнопки -->
        <div
          class="flex flex-wrap items-center justify-center gap-3 sm:gap-4 reveal-hidden"
        >
          <a
            href="#corp-contacts"
            class="corp-hero-cta-btn inline-flex items-center justify-center gap-2.5 px-7 py-4 rounded-full bg-primary text-white font-bold font-montserrat text-sm uppercase tracking-wider hover:bg-primary-dark hover:shadow-lg hover:shadow-primary/30 btn-ripple cursor-pointer"
          >
            Связаться
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href="mailto:anro@anrotrip.ru"
            class="inline-flex items-center justify-center gap-2 px-5 py-3.5 rounded-full border border-white/30 text-white font-semibold font-montserrat text-sm uppercase tracking-wider hover:bg-white/10 hover:border-white/50 transition-all duration-normal cursor-pointer"
            aria-label="Написать на почту"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            Mail
          </a>
          <a
            href="tel:88002224473"
            class="inline-flex items-center justify-center gap-2 px-5 py-3.5 rounded-full border border-white/30 text-white font-semibold font-montserrat text-sm uppercase tracking-wider hover:bg-white/10 hover:border-white/50 transition-all duration-normal cursor-pointer"
            aria-label="Позвонить"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            Phone
          </a>
          <a
            href="https://max.ru/id6658540239_biz"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-5 py-3.5 rounded-full border border-white/30 text-white font-semibold font-montserrat text-sm uppercase tracking-wider hover:bg-white/10 hover:border-white/50 transition-all duration-normal cursor-pointer"
            aria-label="MAX — страница компании"
          >
            <svg
              class="h-4 w-4 shrink-0 overflow-visible text-white"
              viewBox="80 80 80 80"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <g transform={socialLogoTransform80}>
                <path
                  fill="currentColor"
                  fill-rule="evenodd"
                  clip-rule="evenodd"
                  d={maxIconPath}
                ></path>
              </g>
            </svg>
            MAX
          </a>
        </div>

        <!-- Скролл-индикатор -->
        <div class="mt-16 reveal-hidden animate-hero-scroll">
          <a
            id="corp-scroll-arrow"
            href="#content"
            class="inline-flex flex-col items-center gap-2 text-white/60 hover:text-white transition-colors cursor-pointer"
            aria-label="Прокрутить вниз"
          >
            <span class="text-xs font-medium uppercase tracking-widest"
              >Листать</span
            >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Контент: наползает сверху при скролле (z-10 > z-0 Hero) -->
    <div
      class="relative z-10 mt-[20vh] bg-white rounded-t-3xl shadow-[0_-10px_40px_rgba(0,0,0,0.08)] overflow-hidden"
    >
      <!-- ═══════════════════════════════════════════════════════════════
         БЛОК 2 — ВВОДНЫЙ ТЕКСТ (О корпоративном обслуживании)
         В стиле About: асимметрия, декор, карточки, теги
    ═══════════════════════════════════════════════════════════════ -->
      <section
        id="content"
        class="relative bg-white py-16 md:py-24 overflow-hidden"
      >
        <!-- Декор: большая буква фоном (desktop) -->
        <div
          class="absolute right-0 top-1/2 -translate-y-1/2 text-[16rem] md:text-[22rem] font-montserrat font-black text-primary/[0.04] leading-none select-none pointer-events-none -mr-16 hidden lg:block"
        >
          B
        </div>

        <div class="container mx-auto px-4 sm:px-6 max-w-7xl relative">
          <div
            class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-12 lg:gap-16 items-start"
          >
            <!-- Левая колонка: основной текст + теги -->
            <div class="reveal-hidden">
              <div
                class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/8 border border-primary/15 mb-6"
              >
                <span
                  class="w-1.5 h-1.5 rounded-full bg-primary md:animate-pulse"
                ></span>
                <span
                  class="text-xs font-semibold text-primary uppercase tracking-widest font-montserrat"
                  >Корпоративным клиентам</span
                >
              </div>

              <h2
                class="font-montserrat font-extrabold text-gray-900 uppercase tracking-tight mb-6 leading-[1.2]"
                style="font-size: clamp(1.75rem, 1.25rem + 2.5vw, 3rem);"
              >
                <span class="max-sm:tracking-tighter">Профессиональный</span><br
                />
                сервис — <span class="text-primary">ведущее направление</span>
              </h2>

              <p
                class="text-gray-600 text-base md:text-lg leading-relaxed mb-6 wrap-break-word"
              >
                Обслуживание корпоративных клиентов – задача для настоящих
                профессионалов. Сотрудничество на взаимовыгодных условиях: с
                крупными организациями и небольшими компаниями, с учётом
                индивидуальных потребностей.
              </p>

              <div class="flex flex-wrap gap-2">
                {
                  [
                    'Крупные организации',
                    'Малый бизнес',
                    'Командировки',
                    'Конференции',
                    'Поощрительные поездки',
                  ].map((tag) => (
                    <span class="px-3 py-1.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-600 hover:bg-primary/10 hover:text-primary transition-colors cursor-default">
                      {tag}
                    </span>
                  ))
                }
              </div>
            </div>

            <!-- Правая колонка: карточка-выноска -->
            <div class="reveal-hidden">
              <div
                class="relative rounded-3xl bg-gray-50 border border-gray-100 p-8 md:p-10 overflow-hidden group hover:border-primary/20 hover:shadow-xl transition-all duration-normal"
              >
                <!-- Акцентная полоса слева -->
                <div
                  class="absolute left-0 top-0 bottom-0 w-1 bg-linear-to-b from-primary to-secondary rounded-l-3xl"
                >
                </div>

                <div
                  class="absolute -right-8 -top-8 w-32 h-32 rounded-full bg-primary/5 pointer-events-none"
                >
                </div>

                <div class="relative">
                  <div
                    class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center mb-6 group-hover:bg-primary/15 transition-colors shrink-0"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-6 w-6 text-primary"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="1.8"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                      ></path>
                    </svg>
                  </div>

                  <p
                    class="text-gray-700 text-base md:text-lg leading-relaxed font-medium mb-4"
                  >
                    Организуем командировку, поездку на конференцию или деловую
                    встречу партнёров.
                  </p>
                  <p
                    class="text-gray-600 text-sm md:text-base leading-relaxed wrap-break-word"
                  >
                    Предлагаем актуальные варианты командировочных туров,
                    поощрительных поездок и отдыха для вашего коллектива.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════════
         БЛОК 3 — ОФОРМЛЕНИЕ АВИА И Ж/Д БИЛЕТОВ
         Фото corp1, оригинальный текст
    ═══════════════════════════════════════════════════════════════ -->
      <section
        id="corp-avia"
        class="relative z-10 bg-gray-50 py-16 md:py-24 overflow-hidden"
      >
        <div class="container mx-auto px-4 sm:px-6 max-w-7xl">
          <div
            class="grid grid-cols-1 lg:grid-cols-[0.9fr_1.1fr] gap-10 lg:gap-16 items-center"
          >
            <!-- Фото -->
            <div class="reveal-hidden order-2 lg:order-1">
              <div class="relative rounded-3xl overflow-hidden shadow-xl group">
                <Image
                  src={corp1}
                  alt="Оформление авиа и ж/д билетов"
                  quality={90}
                  class="w-full h-[280px] md:h-[360px] object-cover object-top group-hover:scale-105 transition-transform duration-slow"
                />
                <div
                  class="absolute inset-0 bg-linear-to-t from-gray-900/40 to-transparent pointer-events-none"
                >
                </div>
                <div class="absolute bottom-4 left-4 right-4">
                  <span
                    class="inline-block px-4 py-2 rounded-full bg-white/90 text-gray-900 text-sm font-bold font-montserrat uppercase tracking-wider"
                  >
                    Авиа и ж/д
                  </span>
                </div>
              </div>
            </div>

            <!-- Контент -->
            <div class="reveal-hidden order-1 lg:order-2">
              <div
                class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/8 border border-primary/15 mb-6"
              >
                <span
                  class="w-1.5 h-1.5 rounded-full bg-primary md:animate-pulse"
                ></span>
                <span
                  class="text-xs font-semibold text-primary uppercase tracking-widest font-montserrat"
                  >Услуги</span
                >
              </div>

              <h3
                class="font-montserrat font-extrabold text-gray-900 uppercase tracking-tight mb-6"
                style="font-size: clamp(1.5rem, 1.25rem + 2vw, 2.5rem);"
              >
                Оформление авиа и&nbsp;<br />ж/д билетов
              </h3>

              <p
                class="text-gray-600 text-base leading-relaxed mb-6 wrap-break-word"
              >
                Подбор и оформление авиабилетов — одно из основных направлений
                деятельности компании ANRO TRIP. Мы готовы предложить Вам весь
                возможный ассортимент авиапродуктов. <strong
                  class="text-gray-900 font-semibold"
                  >Собственная авиакасса</strong
                > позволяет нам выписать практически любой авиаперелёт на планете.
              </p>

              <ul class="space-y-4 text-gray-600 text-base leading-relaxed">
                <li class="flex gap-3 min-w-0">
                  <span
                    class="shrink-0 w-6 h-6 rounded-full bg-primary/15 flex items-center justify-center mt-0.5"
                  >
                    <svg
                      class="w-3 h-3 text-primary"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                      ><path
                        fill-rule="evenodd"
                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                        clip-rule="evenodd"></path></svg
                    >
                  </span>
                  <span class="min-w-0 wrap-break-word"
                    >Наши специалисты работают напрямую в системах авиакомпаний,
                    поэтому <strong class="text-gray-900 font-semibold"
                      >оформить, поменять, вернуть</strong
                    > билет по вашей просьбе мы можем в считанные минуты. Вам не нужно
                    лично дозваниваться в авиакомпании, чтобы внести изменения в заказ.</span
                  >
                </li>
                <li class="flex gap-3 min-w-0">
                  <span
                    class="shrink-0 w-6 h-6 rounded-full bg-primary/15 flex items-center justify-center mt-0.5"
                  >
                    <svg
                      class="w-3 h-3 text-primary"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                      ><path
                        fill-rule="evenodd"
                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                        clip-rule="evenodd"></path></svg
                    >
                  </span>
                  <span class="min-w-0 wrap-break-word"
                    >Регистрация в <strong class="text-gray-900 font-semibold"
                      >бонусных программах</strong
                    > авиакомпаний оформляется нашим менеджером корпоративного отдела,
                    даже если Вы летите первый раз! Это позволит Вам накапливать бонусы,
                    приобретать авиабилеты за мили, повышать класс обслуживания на
                    борту.</span
                  >
                </li>
                <li class="flex gap-3 min-w-0">
                  <span
                    class="shrink-0 w-6 h-6 rounded-full bg-primary/15 flex items-center justify-center mt-0.5"
                  >
                    <svg
                      class="w-3 h-3 text-primary"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                      ><path
                        fill-rule="evenodd"
                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                        clip-rule="evenodd"></path></svg
                    >
                  </span>
                  <span class="min-w-0 wrap-break-word"
                    >Так же специалисты проведут по запросу апгрейд на
                    бизнес-класс, заказ спецуслуг (питание, перевоз
                    спортинвентаря, оружия, домашних животных и другое).</span
                  >
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════════
         БЛОК 4 — ПРОФЕССИОНАЛЬНЫЙ ПОДБОР ОТЕЛЯ
         Фото corp.webp, оригинальный текст
    ═══════════════════════════════════════════════════════════════ -->
      <section
        id="corp-hotels"
        class="relative z-10 bg-white py-16 md:py-24 overflow-hidden"
      >
        <div class="container mx-auto px-4 sm:px-6 max-w-7xl">
          <div
            class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-16 items-center"
          >
            <!-- Контент (слева) -->
            <div class="reveal-hidden order-1">
              <div
                class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-secondary/8 border border-secondary/15 mb-6"
              >
                <span
                  class="w-1.5 h-1.5 rounded-full bg-secondary md:animate-pulse"
                ></span>
                <span
                  class="text-xs font-semibold text-secondary uppercase tracking-widest font-montserrat"
                  >Услуги</span
                >
              </div>

              <h3
                class="font-montserrat font-extrabold text-gray-900 uppercase tracking-tight mb-6"
                style="font-size: clamp(1.5rem, 1.25rem + 2vw, 2.5rem);"
              >
                Профессиональный подбор отеля
              </h3>

              <p
                class="text-gray-600 text-base md:text-lg leading-relaxed wrap-break-word"
              >
                Наши менеджеры корпоративного отдела знают специфику делового
                туризма и подберут для Вас лучший вариант размещения. Мы
                гарантируем выгодные цены на отели.
              </p>
            </div>

            <!-- Фото (справа) -->
            <div class="reveal-hidden order-2">
              <div class="relative rounded-3xl overflow-hidden shadow-xl group">
                <Image
                  src={corpHero}
                  alt="Профессиональный подбор отеля"
                  quality={90}
                  class="w-full h-[280px] md:h-[360px] object-cover object-top group-hover:scale-105 transition-transform duration-slow"
                />
                <div
                  class="absolute inset-0 bg-linear-to-t from-gray-900/40 to-transparent pointer-events-none"
                >
                </div>
