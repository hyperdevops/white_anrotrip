---
---
<div class="px-4 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-5xl">

    <!-- Используем glass-panel из CSS -->
    <div class="glass-panel rounded-3xl p-4 transition-all">

      <!-- Табы -->
      <div class="mb-4 flex gap-6 px-4 border-b border-gray-900/10 pb-2">
        <button class="text-sm font-bold text-gray-900 border-b-2 border-primary pb-2 -mb-2.5">Авиабилеты</button>
        <button class="text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors">Отели</button>
        <button class="text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors">Туры</button>
      </div>

      <!-- Форма -->
      <a href="https://www.aviasales.ru" target="_blank" rel="noopener noreferrer" class="group grid grid-cols-1 gap-4 md:grid-cols-[1.5fr_1.5fr_1fr_1fr_auto] items-center">

        <!--
           ИСПРАВЛЕНИЕ: bg-white/40 (было 50 или 60).
           Делаем поля прозрачнее, чтобы стекло работало.
        -->
        <div class="relative rounded-2xl bg-white/40 px-4 py-3 transition-colors group-hover:bg-white cursor-pointer hover:shadow-lg backdrop-blur-sm border border-white/30">
          <span class="block text-xs font-medium text-gray-600 uppercase tracking-wider">Откуда</span>
          <div class="flex items-center justify-between">
            <span class="text-lg font-bold text-gray-900">Москва</span>
            <span class="text-gray-500 text-sm">MOW</span>
          </div>
        </div>

        <div class="relative rounded-2xl bg-white/40 px-4 py-3 transition-colors group-hover:bg-white cursor-pointer hover:shadow-lg backdrop-blur-sm border border-white/30">
          <span class="block text-xs font-medium text-gray-600 uppercase tracking-wider">Куда</span>
          <div class="flex items-center justify-between">
            <span class="text-lg font-bold text-gray-900">Пхукет</span>
            <span class="text-gray-500 text-sm">HKT</span>
          </div>
        </div>

        <div class="relative rounded-2xl bg-white/40 px-4 py-3 transition-colors group-hover:bg-white cursor-pointer hover:shadow-lg backdrop-blur-sm border border-white/30">
          <span class="block text-xs font-medium text-gray-600 uppercase tracking-wider">Когда</span>
          <span class="text-lg font-bold text-gray-900">24 фев</span>
        </div>

        <div class="relative rounded-2xl bg-white/40 px-4 py-3 transition-colors group-hover:bg-white cursor-pointer hover:shadow-lg backdrop-blur-sm border border-white/30">
          <span class="block text-xs font-medium text-gray-600 uppercase tracking-wider">Кто</span>
          <span class="text-lg font-bold text-gray-900">1 чел</span>
        </div>

        <!-- Кнопка -->
        <div class="h-full">
          <button class="h-full w-full rounded-xl bg-cta hover:bg-cta-hover text-[#11111b] font-bold px-8 py-4 md:py-0 transition-all shadow-lg hover:shadow-xl hover:scale-105 active:scale-95 flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <span>Найти</span>
          </button>
        </div>
      </a>
    </div>
  </div>
</div>
