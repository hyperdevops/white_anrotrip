---
---
<div class="px-4 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-5xl">

    <!--
      ПРАВКА БЛЮРА:
      backdrop-blur-[40px] - эффект сильного матового стекла.
    -->
    <div class="rounded-3xl bg-white/60 dark:bg-slate-900/60 p-4 shadow-2xl backdrop-blur-[40px] border border-white/40 dark:border-white/10 ring-1 ring-white/50">

      <!-- Заголовки -->
      <div class="mb-4 flex gap-6 px-4 border-b border-gray-200/30 dark:border-gray-700/30 pb-2">
        <button class="text-sm font-bold text-gray-900 dark:text-white border-b-2 border-primary pb-2 -mb-2.5">Авиабилеты</button>
        <button class="text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-gray-300 transition-colors">Отели</button>
        <button class="text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-gray-300 transition-colors">Туры</button>
      </div>

      <!-- Форма -->
      <a href="https://www.aviasales.ru" target="_blank" rel="noopener noreferrer" class="group grid grid-cols-1 gap-4 md:grid-cols-[1.5fr_1.5fr_1fr_1fr_auto] items-center">
        <!-- Поля -->
        <div class="relative rounded-2xl bg-white/50 dark:bg-slate-800/50 px-4 py-3 transition-colors group-hover:bg-white dark:group-hover:bg-slate-700 cursor-pointer hover:shadow-lg">
          <span class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Откуда</span>
          <div class="flex items-center justify-between">
            <span class="text-lg font-bold text-gray-900 dark:text-white">Москва</span>
            <span class="text-gray-500 text-sm">MOW</span>
          </div>
        </div>
        <div class="relative rounded-2xl bg-white/50 dark:bg-slate-800/50 px-4 py-3 transition-colors group-hover:bg-white dark:group-hover:bg-slate-700 cursor-pointer hover:shadow-lg">
          <span class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Куда</span>
          <div class="flex items-center justify-between">
            <span class="text-lg font-bold text-gray-900 dark:text-white">Пхукет</span>
            <span class="text-gray-500 text-sm">HKT</span>
          </div>
        </div>
        <div class="relative rounded-2xl bg-white/50 dark:bg-slate-800/50 px-4 py-3 transition-colors group-hover:bg-white dark:group-hover:bg-slate-700 cursor-pointer hover:shadow-lg">
          <span class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Когда</span>
          <span class="text-lg font-bold text-gray-900 dark:text-white">24 фев</span>
        </div>
        <div class="relative rounded-2xl bg-white/50 dark:bg-slate-800/50 px-4 py-3 transition-colors group-hover:bg-white dark:group-hover:bg-slate-700 cursor-pointer hover:shadow-lg">
          <span class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Кто</span>
          <span class="text-lg font-bold text-gray-900 dark:text-white">1 чел</span>
        </div>
        <!-- Кнопка -->
        <div class="h-full">
          <button class="h-full w-full rounded-xl bg-cta hover:bg-cta-hover text-[#11111b] font-bold px-8 py-4 md:py-0 transition-all shadow-lg hover:shadow-xl hover:scale-105 active:scale-95 flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <span>Найти</span>
          </button>
        </div>
      </a>
    </div>
  </div>
</div>
