---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  {
    name: "О нас",
    href: "#about",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`
  },
  {
    name: "Отзывы",
    href: "#reviews",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />`
  },
  {
    name: "Туры",
    href: "#search",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`
  },
  {
    name: "Команда",
    href: "#team",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />`
  },
  {
    name: "Контакты",
    href: "#contacts",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />`
  },
];
---

<header class="fixed top-4 left-0 right-0 z-50 mx-auto w-[95%] max-w-7xl">
  <div class="relative flex items-center justify-between rounded-2xl bg-white/90 dark:bg-slate-900/90 px-4 py-3 shadow-xl backdrop-blur-xl border border-white/20 dark:border-white/5 transition-all duration-300">

    <!-- Логотип с ID для JS -->
    <a href="#" id="logo-btn" class="flex items-center gap-2 group z-50 cursor-pointer">
      <div class="flex h-9 w-9 items-center justify-center rounded-full bg-primary text-white font-bold text-lg group-hover:scale-110 transition-transform duration-300 shadow-md">
        AT
      </div>
      <span class="text-lg font-bold tracking-tight text-primary dark:text-white font-montserrat block group-hover:text-primary-light transition-colors">
        ANRO TRIP
      </span>
    </a>

    <!-- Десктоп Меню -->
    <nav class="hidden lg:flex items-center gap-6">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-[13px] font-semibold text-gray-700 dark:text-gray-200 hover:text-primary dark:hover:text-cta transition-colors duration-200 uppercase tracking-wide"
        >
          {item.name}
        </a>
      ))}
    </nav>

    <!-- Правая часть -->
    <div class="flex items-center gap-3 z-50">
      <ThemeToggle />

      <a
        href="#cabinet"
        class="hidden lg:block rounded-full bg-surface dark:bg-slate-800 px-5 py-2 text-xs font-bold text-primary dark:text-white transition-all duration-300 hover:bg-primary hover:text-white hover:shadow-lg active:scale-95 uppercase tracking-wider"
      >
        Личный кабинет
      </a>

      <!-- Гамбургер -->
      <button id="menu-toggle" class="lg:hidden flex flex-col gap-1.5 p-2 group relative focus:outline-none" aria-label="Меню">
        <span class="h-0.5 w-6 bg-primary dark:bg-white transition-all duration-300 group-aria-expanded:rotate-45 group-aria-expanded:translate-y-2"></span>
        <span class="h-0.5 w-6 bg-primary dark:bg-white transition-all duration-300 group-aria-expanded:opacity-0"></span>
        <span class="h-0.5 w-6 bg-primary dark:bg-white transition-all duration-300 group-aria-expanded:-rotate-45 group-aria-expanded:-translate-y-2"></span>
      </button>
    </div>
  </div>

  <!-- Мобильное меню -->
  <div
    id="mobile-menu"
    class="fixed top-[70px] right-[2.5%] w-48 origin-top-right scale-95 opacity-0 invisible transition-all duration-200 rounded-2xl bg-white/95 dark:bg-slate-900/95 shadow-2xl backdrop-blur-xl border border-gray-100 dark:border-gray-800 p-2 lg:hidden z-40"
  >
    <nav class="flex flex-col gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-semibold text-gray-700 dark:text-gray-200 hover:bg-surface dark:hover:bg-white/10 hover:text-primary dark:hover:text-cta transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400 group-hover:text-primary dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={item.icon} />
          {item.name}
        </a>
      ))}

      <div class="my-1 h-px bg-gray-100 dark:bg-gray-700"></div>

      <a href="#cabinet" class="block w-full rounded-xl bg-primary px-3 py-2.5 text-center text-sm font-bold text-white shadow-md active:scale-95 transition-transform">
        Личный кабинет
      </a>
    </nav>
  </div>
</header>

<script>
  const toggleBtn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const logoBtn = document.getElementById('logo-btn');

  // --- ЛОГИКА ЛОГОТИПА (Плавный скролл наверх) ---
  logoBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    window.scrollTo({
      top: 0,
      behavior: 'smooth'
    });
  });

  // --- ЛОГИКА МЕНЮ ---
  const openMenu = () => {
    menu?.classList.remove('invisible', 'scale-95', 'opacity-0');
    menu?.classList.add('scale-100', 'opacity-100');
    toggleBtn?.setAttribute('aria-expanded', 'true');
  };

  const closeMenu = () => {
    menu?.classList.remove('scale-100', 'opacity-100');
    menu?.classList.add('scale-95', 'opacity-0');
    toggleBtn?.setAttribute('aria-expanded', 'false');
    setTimeout(() => menu?.classList.add('invisible'), 200);
  };

  toggleBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
    isExpanded ? closeMenu() : openMenu();
  });

  document.addEventListener('click', (e) => {
    const isExpanded = toggleBtn?.getAttribute('aria-expanded') === 'true';
    if (isExpanded && menu && !menu.contains(e.target as Node) && !toggleBtn?.contains(e.target as Node)) {
      closeMenu();
    }
  });
</script>
