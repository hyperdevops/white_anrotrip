---
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import PopularTours from '../components/PopularTours.astro';
import SearchWidget from '../components/SearchWidget.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="ANRO TRIP — Будь на высоте!">
  <Header />

  <main>
    <!-- 1. Hero -->
    <Hero />

    <!--
      2. Контентная шторка
      FIX для мобильных:
      mt-[45vh] — на мобильных отступаем вниз на 45% экрана (так как форма высокая).
      md:mt-[20vh] — на компьютерах оставляем 20% (форма узкая).
      Это "спрячет" форму за нижний край гарантированно.
    -->
    <div class="relative z-10 mt-[45vh] md:mt-[20vh] bg-white dark:bg-darkbg shadow-[0_-20px_60px_rgba(0,0,0,0.2)] pb-20 min-h-screen">

      <!-- Виджет поиска -->
      <div class="relative z-20 -translate-y-1/2 reveal-hidden">
        <SearchWidget />
      </div>

      <!-- Блок с турами -->
      <div class="-mt-16">
        <PopularTours />
      </div>

      <!-- Подвал -->
      <div class="h-20"></div>
    </div>
  </main>
</Layout>
