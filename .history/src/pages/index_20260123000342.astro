---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import SearchWidget from '../components/SearchWidget.astro';
import PopularTours from '../components/PopularTours.astro';
---

<Layout title="ANRO TRIP — Будь на высоте!">
  <Header />
  
  <main>
    <Hero />
    
    <!-- Обертка контента -->
    <div class="relative z-10 bg-white dark:bg-darkbg">
      
      <!-- 
        Ключевой момент:
        1. Мы поднимаем SearchWidget выше (-translate-y-1/2), чтобы он вылез наполовину вверх.
        2. relative z-20 гарантирует, что он будет поверх всего.
      -->
      <div class="relative z-20 -translate-y-1/2">
        <SearchWidget />
      </div>
      
      <!-- 
        Остальной контент (Туры).
        Так как мы подняли виджет, нам нужно компенсировать место под ним, 
        иначе будет дырка. Делаем отрицательный margin-top.
      -->
      <div class="-mt-20 pb-20 rounded-t-[40px] overflow-hidden">
        <PopularTours />
      </div>
      
    </div>
  </main>
</Layout>
