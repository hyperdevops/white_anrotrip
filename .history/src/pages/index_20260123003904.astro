---
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import PopularTours from '../components/PopularTours.astro';
import SearchWidget from '../components/SearchWidget.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="ANRO TRIP — Будь на высоте!">
  <Header />

  <main>
    <!-- 1. Hero: Липкий, на весь экран -->
    <Hero />

    <!--
      2. Контентная шторка
      mt-[20vh] — Ключевая правка!
      Мы сдвигаем начало белого блока вниз на 20% высоты экрана.
      Поскольку форма "торчит" вверх, этот отступ спрячет её за нижний край экрана при загрузке.
    -->
    <div class="relative z-10 mt-[20vh] bg-white dark:bg-darkbg shadow-[0_-20px_60px_rgba(0,0,0,0.2)] pb-20 min-h-screen">

      <!--
         Виджет поиска.
         -translate-y-1/2 — поднимает его, создавая эффект наложения на границу.
         reveal-hidden — анимация плавного появления.
      -->
      <div class="relative z-20 -translate-y-1/2 reveal-hidden">
        <SearchWidget />
      </div>

      <!-- Блок с турами -->
      <!-- -mt-16 компенсирует пустоту под поднятым виджетом -->
      <div class="-mt-16">
        <PopularTours />
      </div>

      <!-- Подвал (заглушка) -->
      <div class="h-20"></div>
    </div>
  </main>
</Layout>
