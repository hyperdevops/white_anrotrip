{
  // Настройки для обычного JSON
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true
  },

  // Настройки для JSON с комментариями (tsconfig.json, .vscode/settings.json)
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true
  },

  // Настройки для Astro
  "[astro]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // Настройки для HTML (ускорение верстки)
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.suggest.insertMode": "replace"
  },

  // Настройки для CSS
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // Настройки для JavaScript
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // Настройки для TypeScript
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // Глобальные настройки форматирования
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "prettier.trailingComma": "none",
  "prettier.semi": false,
  "prettier.singleQuote": true,

  // Настройки Emmet для Astro
  "emmet.includeLanguages": {
    "astro": "html"
  },
  "emmet.triggerExpansionOnTab": true,

  // Рекомендуется для Astro
  "editor.linkedEditing": true,
  "editor.guides.bracketPairs": "active",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairsHorizontal": true,
  "editor.smoothScrolling": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.fontFamily": "'JetBrainsMono Nerd Font'",
  "editor.fontSize": 14,
  "editor.wordWrap": "off",
  "editor.tabSize": 2,
  "editor.insertSpaces": false,
  "editor.detectIndentation": false,
  "editor.autoIndentOnPaste": true,
  "editor.renderWhitespace": "none",
  "editor.fontLigatures": true,

  // Настройки для удобства работы
  "files.trimTrailingWhitespace": true,
  "files.autoGuessEncoding": true,
  "workbench.editor.decorations.colors": false,
  "workbench.editor.scrollToSwitchTabs": true,
  "workbench.colorTheme": "Catppuccin Mocha",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.productIconTheme": "material-product-icons",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "breadcrumbs.enabled": false,
  "git.autofetch": true,
  "git.confirmSync": false,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.smoothScrolling": true,
  "workbench.list.smoothScrolling": true
}
